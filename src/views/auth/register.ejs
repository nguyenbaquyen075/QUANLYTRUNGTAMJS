<!DOCTYPE html>
<html class="scroll-smooth" lang="vi">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Đăng Ký Tài Khoản - Trung Tâm Học Thêm Online</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-container": "#fd761a",
                        "on-tertiary-container": "#8fbeff",
                        "surface-container-lowest": "#ffffff",
                        "primary": "#00288e",
                        "secondary-fixed": "#ffdbca",
                        "outline": "#757684",
                        "surface-variant": "#e0e3e5",
                        "outline-variant": "#c4c5d5",
                        "on-error-container": "#93000a",
                        "inverse-on-surface": "#eff1f3",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#341100",
                        "tertiary": "#003564",
                        "on-secondary": "#ffffff",
                        "surface-tint": "#3755c3",
                        "on-tertiary-fixed-variant": "#004883",
                        "surface": "#f7f9fb",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#b8c4ff",
                        "on-background": "#191c1e",
                        "tertiary-container": "#004c8b",
                        "surface-dim": "#d8dadc",
                        "inverse-surface": "#2d3133",
                        "on-surface": "#191c1e",
                        "on-primary-container": "#a8b8ff",
                        "on-error": "#ffffff",
                        "background": "#f7f9fb",
                        "on-secondary-container": "#5c2400",
                        "tertiary-fixed-dim": "#a4c9ff",
                        "tertiary-fixed": "#d4e3ff",
                        "surface-container-high": "#e6e8ea",
                        "primary-fixed-dim": "#b8c4ff",
                        "on-tertiary-fixed": "#001c39",
                        "error": "#ba1a1a",
                        "secondary-fixed-dim": "#ffb690",
                        "primary-fixed": "#dde1ff",
                        "on-primary-fixed-variant": "#173bab",
                        "surface-container-highest": "#e0e3e5",
                        "on-secondary-fixed-variant": "#783200",
                        "on-surface-variant": "#444653",
                        "surface-bright": "#f7f9fb",
                        "on-primary": "#ffffff",
                        "surface-container-low": "#f2f4f6",
                        "on-primary-fixed": "#001453",
                        "secondary": "#9d4300",
                        "primary-container": "#1e40af",
                        "surface-container": "#eceef0"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem",
                        "3xl": "2.5rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "sm": "8px",
                        "xl": "32px",
                        "xs": "4px",
                        "gutter-mobile": "12px",
                        "margin-mobile": "20px",
                        "lg": "24px",
                        "md": "16px",
                        "base": "4px"
                    },
                    "fontFamily": {
                        "sans": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
</head>
<body class="antialiased font-sans bg-surface">
    <%- include('../partials/home-navbar', { activePage: '', isLoggedIn: (typeof isLoggedIn !== 'undefined' ? isLoggedIn : false), currentUserFullName: (typeof currentUserFullName !== 'undefined' ? currentUserFullName : ''), currentUserRole: (typeof currentUserRole !== 'undefined' ? currentUserRole : null) }) %>
    <main class="pt-[90px]">
        
<style>
    .register-container {
        min-height: calc(100vh - 60px);
        display: flex;
        justify-content: center;
        align-items: center;
        background: radial-gradient(ellipse at 40% 60%, #00288e 0%, #001050 40%, #000820 100%);
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }
    .register-container::after {
        content: '';
        position: absolute;
        bottom: -20%;
        left: -10%;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0,40,142,0.4) 0%, transparent 70%);
        pointer-events: none;
    }
    .register-card {
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1.5px solid rgba(255,255,255,0.12);
        border-radius: 24px;
        padding: 2.5rem 2.25rem;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 24px 60px rgba(0,0,0,0.35), 0 1px 0 rgba(255,255,255,0.1) inset;
        animation: fadeSlideIn 0.4s ease;
        position: relative;
        z-index: 1;
    }
    @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .register-card h2 { color: #fff !important; }
    .register-card p { color: rgba(255,255,255,0.6) !important; }
    .form-label-custom {
        color: rgba(255,255,255,0.75) !important;
        font-weight: 600;
        font-size: 0.88rem;
        margin-bottom: 0.5rem;
        display: block;
    }
    .register-card .form-input-custom {
        background: rgba(255,255,255,0.08) !important;
        border: 1.5px solid rgba(255,255,255,0.15) !important;
        color: #fff !important;
        border-radius: 10px;
        padding: 0.7rem 1rem;
        width: 100%;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }
    .register-card .form-input-custom::placeholder { color: rgba(255,255,255,0.3) !important; }
    .register-card .form-input-custom:focus {
        outline: none;
        border-color: rgba(255,255,255,0.45) !important;
        background: rgba(255,255,255,0.12) !important;
        box-shadow: 0 0 0 3px rgba(255,255,255,0.08) !important;
    }
    .register-card select.form-input-custom option {
        background: #001050;
        color: #fff;
    }
    .btn-submit {
        width: 100%;
        background: #fff;
        color: #00288e;
        border: none;
        padding: 0.9rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    }
    .btn-submit:hover {
        background: #e0eaff;
        transform: translateY(-2px);
        box-shadow: 0 16px 32px rgba(0,0,0,0.3);
    }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .register-divider {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 1.25rem;
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.45);
    }
    .register-divider a { color: #7eb8ff; font-weight: 700; text-decoration: none; }
    .register-divider a:hover { color: #fff; }
    .reg-icon-box {
        width: 64px; height: 64px; border-radius: 18px;
        background: rgba(255,255,255,0.15);
        border: 1.5px solid rgba(255,255,255,0.2);
        color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.75rem; margin-bottom: 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
        backdrop-filter: blur(8px);
    }
    .error-box {
        color: #ff9a9a;
        font-size: 0.88rem;
        font-weight: 600;
        background: rgba(255,80,80,0.12);
        border: 1px solid rgba(255,80,80,0.22);
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
        margin-bottom: 1.25rem;
    }
</style>

<div class="register-container">
    <div class="register-card">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div class="reg-icon-box">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h2 style="font-size: 1.55rem; font-weight: 800; margin-bottom: 0.25rem;">Tạo Tài Khoản Mới</h2>
            <p style="font-size: 0.9rem; margin-top: 0.25rem;">Đăng ký để bắt đầu hành trình học tập.</p>
        </div>

        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="error-box"><i class="fa-solid fa-circle-exclamation"></i> <%= errorMessage %></div>
        <% } %>

        <form action="/Auth/Register" method="post" autocomplete="off" id="registerForm">
            <div class="form-group-custom">
                <label class="form-label-custom">Họ và Tên</label>
                <input type="text" name="fullName" class="form-input-custom" placeholder="Nguyễn Văn A" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Email</label>
                <input type="email" name="email" class="form-input-custom" placeholder="email@example.com" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Số điện thoại</label>
                <input type="tel" name="phone" class="form-input-custom" placeholder="0901234567" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Mật khẩu</label>
                <input type="password" name="password" class="form-input-custom" placeholder="Tối thiểu 6 ký tự" required autocomplete="new-password" />
            </div>
            <div class="form-group-custom" style="margin-bottom: 2rem;">
                <label class="form-label-custom">Vai trò</label>
                <select name="role" class="form-input-custom">
                    <option value="STUDENT">Học Viên</option>
                    <option value="TEACHER">Giáo Viên</option>
                    <option value="PARENT">Phụ Huynh</option>
                </select>
            </div>
            <button type="submit" class="btn-submit" id="submitBtn">
                <i class="fa-solid fa-user-check"></i> Đăng Ký Ngay
            </button>
        </form>

        <div class="register-divider">
            Đã có tài khoản? <a href="/Auth/Login">Đăng nhập</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('registerForm').addEventListener('submit', function() {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...';
    });
</script>

    </main>
</body>
</html>