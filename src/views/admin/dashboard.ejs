        </div>

        <!-- Modal: Thêm Khách Hàng Tiềm Năng -->
        <div class="modal-custom" id="leadModal" style="display: none;">
            <div class="modal-content-custom" style="max-width: 480px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="font-weight: 700; font-size: 1.25rem;">
                        Thêm Khách
                        Hàng Tiềm
