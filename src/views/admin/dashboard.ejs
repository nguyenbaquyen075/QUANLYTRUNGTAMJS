<% 
    title="Bảng Điều Khiển Quản Trị Viên"; 
    hideHeader = true;
%>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
<% 
    /* Calculate invoice stats in JS using var for template scope */
    var paidRevenue = 0; 
    var unpaidRevenue = 0; 
    var totalInvoicesCount = invoices.length; 
    var paidInvoicesCount = 0; 
    var unpaidInvoicesCount = 0; 
    
    invoices.forEach(i => {
        if (i.Status === 1) {
            paidRevenue += Number(i.Amount);
            paidInvoicesCount++;
        } else {
            unpaidRevenue += Number(i.Amount);
            unpaidInvoicesCount++;
        }
    });

    var paidPercentage = totalInvoicesCount > 0 ? (paidInvoicesCount / totalInvoicesCount) * 100 : 0;
%>
        <style>
            .btn-minimal-action {
                color: #94a3b8;
                background: none;
                border: none;
                padding: 0.25rem;
                cursor: pointer;
                transition: all 0.2s ease;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
            .btn-minimal-action:hover {
                transform: scale(1.15);
            }
            .btn-minimal-action.action-edit:hover {
                color: #2563eb !important;
            }
            .btn-minimal-action.action-view:hover {
                color: #10b981 !important;
            }
            .btn-minimal-action.action-lock:hover {
                color: #d97706 !important;
            }
            .btn-minimal-action.action-delete:hover {
                color: #dc2626 !important;
            }
            .btn-minimal-action.action-more:hover {
                color: #1e293b !important;
            }
            .course-title-link:hover,
            .course-title-link:hover strong {
                color: #2563eb !important;
                text-decoration: none !important;
            }
            .dashboard-layout {
                display: flex;
                height: 100vh;
                background: #ffffff;
                overflow: hidden;
            }

            .sidebar {
                width: 280px;
                background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #e0f2fe 100%); border-right: 1px solid rgba(30, 58, 138, 0.08);
                display: flex;
                flex-direction: column;
                padding: 0 1rem 0.75rem 1rem;
                flex-shrink: 0;
                z-index: 10;
                position: relative;
            }

            .main-content {
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                height: 100%;
                overflow: hidden;
            }

            .admin-content-body {
                flex: 1;
                padding: 2.5rem;
                overflow-y: auto;
                background: #ffffff;
            }

            @media (max-width: 992px) {
                .dashboard-layout {
                    flex-direction: column;
                    height: auto;
                    overflow: visible;
                }

                .sidebar {
                    width: 100%;
                    border-right: none;
                    border-bottom: 1px solid rgba(30, 58, 138, 0.08);
                    padding: 1.25rem 0.75rem;
                }

                .sidebar div[style*="flex-direction: column"] {
                    flex-direction: row !important;
                    overflow-x: auto;
                    white-space: nowrap;
                    padding-bottom: 0.5rem;
                    gap: 0.5rem;
                    -webkit-overflow-scrolling: touch;
                }

                .admin-tab-btn {
                    width: auto;
                    display: inline-flex;
                    white-space: nowrap;
                    padding: 0.6rem 1rem;
                }

                .main-content {
                    height: auto !important;
                    overflow: visible !important;
                }

                .admin-content-header {
                    padding: 0 1.25rem !important;
                    height: 60px !important;
                }

                .admin-content-body {
                    padding: 1.25rem !important;
                    overflow-y: visible !important;
                }
            }

            .chart-container-custom {
                background-color: var(--white);
                border: 1px solid var(--border-color);
                border-radius: var(--radius-lg);
                padding: 1.5rem;
                box-shadow: var(--shadow-sm);
                margin-bottom: 2rem;
            }

            .chart-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 1.5rem;
                border-bottom: 1px solid var(--border-color);
                padding-bottom: 0.75rem;
            }

            .chart-title {
                font-size: 1.05rem;
                font-weight: 700;
                color: var(--text-dark);
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            /* Sidebar Links */
            .admin-tab-btn {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                width: 100%;
                text-align: left;
                padding: 0.85rem 1.1rem;
                border-radius: 12px;
                font-weight: 600;
                font-size: 0.92rem;
                border: none;
                cursor: pointer;
                transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
                background: none;
                color: #475569;
            }

            .admin-tab-btn:hover {
                background: rgba(30, 58, 138, 0.04);
                color: #1e3a8a;
                padding-left: 1.30rem;
            }

            .admin-tab-btn.active {
                background: rgba(30, 58, 138, 0.06);
                color: #1e3a8a;
                font-weight: 700;
                border-left: 4px solid #1e3a8a;
                border-radius: 4px 12px 12px 4px;
            }

            .admin-tab-btn i {
                font-size: 1.15rem;
                width: 20px;
                text-align: center;
                transition: transform 0.2s ease;
            }

            .admin-tab-btn:hover i {
                transform: scale(1.1);
            }

            .tab-content {
                display: none;
            }

            .tab-content.active {
                display: block;
            }

            .admin-logout-btn {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                width: 100%;
                padding: 0.85rem 1.1rem;
                border-radius: 12px;
                font-weight: 700;
                font-size: 0.92rem;
                border: none;
                cursor: pointer;
                transition: all 0.2s ease;
                background: none;
                color: #ff8b8b;
                text-decoration: none;
                margin-top: auto;
            }
            .admin-logout-btn:hover {
                background: rgba(255, 255, 255, 0.06);
                color: #ff8b8b;
            }

            .donut-chart-svg {
                transform: rotate(-90deg);
            }

            .donut-circle-bg {
                fill: none;
                stroke: var(--border-color);
                stroke-width: 3.8;
            }

            .donut-circle-val {
                fill: none;
                stroke: #2563EB;
                stroke-width: 3.8;
                stroke-linecap: round;
                stroke-dashoffset: 100;
                animation: drawDonut 1.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            }

            @keyframes drawDonut {
                from {
                    stroke-dashoffset: 100;
                }

                to {
                    stroke-dashoffset: 0;
                }
            }

            @keyframes drawLine {
                from {
                    stroke-dashoffset: 1000;
                }

                to {
                    stroke-dashoffset: 0;
                }
            }

            @keyframes fadeInChart {
                from {
                    opacity: 0;
                }

                to {
                    opacity: 1;
                }
            }

            .animated-line {
                stroke-dasharray: 1000;
                stroke-dashoffset: 1000;
                animation: drawLine 2.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            }

            .animated-area {
                animation: fadeInChart 1.5s ease-out forwards;
                opacity: 0;
            }

            @keyframes fillProgress {
                from {
                    width: 0%;
                }
            }

            .kpi-progress-bar {
                animation: fillProgress 1.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            }

            @media (max-width: 1200px) {
                .stats-grid {
                    grid-template-columns: 1fr 1fr;
                }
            }

            .theme-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08) !important;
            }
        </style>

        <div class="dashboard-layout">
            <!-- Sidebar Navigation -->
            <div class="sidebar">
                <div class="sidebar-header" style="height: 70px; display: flex; align-items: center; padding: 0 0.5rem; border-bottom: 1px solid rgba(30, 58, 138, 0.08); margin-bottom: 1.25rem; box-sizing: border-box;">
                    <div class="sidebar-user-info" style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #1e3a8a, #3B82F6); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1rem; border: 2px solid white; box-shadow: 0 4px 10px rgba(30, 58, 138, 0.15); flex-shrink: 0;">
                            <%= typeof currentUserFullName !== 'undefined' && currentUserFullName ? currentUserFullName.charAt(0).toUpperCase() : 'A' %>
                        </div>
                        <div>
                            <h5 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #0b1120; line-height: 1.2;"><%= typeof currentUserFullName !== 'undefined' ? currentUserFullName : 'Admin' %></h5>
                            <span style="font-size: 0.7rem; color: #64748B; display: flex; align-items: center; gap: 0.25rem; margin-top: 0.25rem;">
                                <span style="display:inline-block; width: 6px; height: 6px; background:#10B981; border-radius:50%;"></span> Quản Trị Viên
                            </span>
                        </div>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.45rem; flex-grow: 1;">
                    <button class="admin-tab-btn active" onclick="switchTab('tabCourses')">
                        <i class="fa-solid fa-graduation-cap"></i> Quản lý Khóa / Lớp Học
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabRevenue')">
                        <i class="fa-solid fa-chart-line"></i> Doanh thu & Báo cáo
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabTeachers')">
                        <i class="fa-solid fa-chalkboard-user"></i> Quản lý Giáo viên
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabStudents')">
                        <i class="fa-solid fa-user-graduate"></i> Quản lý Học sinh
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabPayments')">
                        <i class="fa-solid fa-file-invoice-dollar"></i> Thanh toán học phí
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabProgress')">
                        <i class="fa-solid fa-spinner"></i> Tiến độ học tập khóa học
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabKpi')">
                        <i class="fa-solid fa-award"></i> Đánh giá KPI
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabAiLeads')">
                        <i class="fa-solid fa-robot"></i> Khách hàng AI (<%= leads.length %>)
                    </button>
                    <button class="admin-tab-btn" onclick="switchTab('tabSettings')">
                        <i class="fa-solid fa-gear"></i> Cài đặt hệ thống
                    </button>
                </div>

                <!-- Logout Button at bottom of sidebar -->
                <div style="margin-top: auto; padding: 1.25rem 0.5rem 0.5rem 0.5rem; border-top: 1px solid rgba(30, 58, 138, 0.08);">
                    <a href="/Auth/Logout" class="admin-logout-btn" onclick="return confirm('Bạn có chắc muốn đăng xuất không?')">
                        <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                    </a>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="main-content">
                <!-- Internal white header -->
                <div class="admin-content-header" style="height: 70px; background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #e0f2fe 100%); border-bottom: 1px solid rgba(30, 58, 138, 0.08); display: flex; justify-content: space-between; align-items: center; padding: 0 2.5rem; flex-shrink: 0; z-index: 5; box-shadow: 0 1px 3px rgba(15,23,42,0.02);">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <h3 style="font-size: 1.15rem; font-weight: 800; color: #0F172A; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                            <i class="fa-solid fa-user-shield text-[#1e3a8a]"></i> Bảng Quản Trị Hệ Thống
                        </h3>
                    </div>
                    
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <a href="/Notification" style="position: relative; padding: 0; display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: #F1F5F9; color: #475569; border: 1.5px solid #E2E8F0; text-decoration: none;" title="Thông báo">
                            <i class="fa-solid fa-bell" style="font-size: 1.15rem; margin: 0;"></i>
                            <span id="notifBadge" style="position: absolute; top: -3px; right: -3px; background: #EF4444; color: white; font-size: 0.65rem; font-weight: 800; border-radius: 50%; width: 18px; height: 18px; display: none; align-items: center; justify-content: center; border: 2px solid white; line-height: 1;">0</span>
                        </a>
                    </div>
                </div>

                <!-- Body wrapper -->
                <div class="admin-content-body">
                <!-- Header Area -->
                <div class="dashboard-header"
                    style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
                    <div>
                        <h1 style="font-size: 1.75rem; font-weight: 800;">Bảng Quản Trị Trung Tâm</h1>
                        <p style="color: var(--text-muted);">Phân tích tài chính, quản lý chất lượng và kết quả đào tạo.</p>
                    </div>
                </div>

                <!-- Tab: Quản lý Khóa học -->
                <div class="tab-content active" id="tabCourses">
                    <div class="chart-container-custom">
                        <div class="chart-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                            <span class="chart-title"><i class="fa-solid fa-layer-group" style="color: #2563EB;"></i> Khóa Học Khung</span>
                            <div style="display: flex; gap: 0.5rem;">
                                <button class="btn-secondary-custom" onclick="openModal('courseModal')" style="padding: 0.4rem 0.8rem; font-size: 0.82rem; height: 34px;">
                                    <i class="fa-solid fa-plus"></i> Tạo Khóa Học
                                </button>
                                <button class="btn-custom" onclick="openModal('classModal')" style="padding: 0.4rem 0.8rem; font-size: 0.82rem; height: 34px; background: linear-gradient(135deg, #4f46e5, #7c3aed); border: none;">
                                    <i class="fa-solid fa-calendar-plus"></i> Tạo Lớp Học
                                </button>
                            </div>
                        </div>
                        <div class="table-wrapper" style="margin-bottom: 2rem;">
                            <table class="table-custom">
                                <thead>
                                    <tr>
                                        <th>Mã
                                            Khóa
                                        </th>
                                        <th>Tên
                                            Khóa
                                            Học
                                        </th>
                                        <th>Số
                                            Buổi
                                        </th>
                                        <th>Học
                                            Phí
                                            Gốc
                                        </th>
                                        <th style="text-align: right;">
                                            Thao
                                            tác
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% courses.forEach(c=> { %>
                                        <tr>
                                            <td style="font-weight: 600;">
                                                <%= c.CourseCode %>
                                            </td>
                                            <td>
                                                <a href="/Admin/Courses/<%= c.Id %>/Classes" class="course-title-link" style="text-decoration: none; display: flex; align-items: center; gap: 0.75rem; color: inherit;">
                                                    <% if (c.ImageUrl) { %>
                                                        <img src="<%= c.ImageUrl %>" alt="<%= c.Title %>" style="width: 50px; height: 35px; border-radius: 4px; object-fit: cover; border: 1px solid #E2E8F0;" />
                                                    <% } else { %>
                                                        <div style="width: 50px; height: 35px; border-radius: 4px; background: #F1F5F9; display: flex; align-items: center; justify-content: center; color: #94A3B8; font-size: 0.75rem; border: 1px solid #E2E8F0;"><i class="fa-regular fa-image"></i></div>
                                                    <% } %>
                                                    <strong><%= c.Title %></strong>
                                                </a>
                                            </td>
                                            <td>
                                                <a href="/Admin/Courses/<%= c.Id %>/Classes" class="course-title-link" style="text-decoration: none; color: inherit; display: block;">
                                                    <%= c.TotalLessons %> buổi
                                                </a>
                                            </td>
                                            <td>
                                                <%= Number(c.BasePrice).toLocaleString("vi-VN") %>
                                                    đ
                                            </td>
                                            <td style="text-align: right; white-space: nowrap;">
                                                <div style="display: flex; gap: 0.8rem; justify-content: flex-end; align-items: center;">
                                                    <!-- Xem lớp (Groups icon with count) -->
                                                    <a href="/Admin/Courses/<%= c.Id %>/Classes" class="btn-minimal-action action-view" title="Xem lớp học" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.15rem;">
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">groups</span>
                                                        <span style="font-size: 13px; font-weight: 600; font-family: inherit;">(<%= classes.filter(cls => cls.CourseId === c.Id).length %>)</span>
                                                    </a>
                                                    
                                                    <!-- Sửa khóa học (Pencil) -->
                                                    <button type="button" class="btn-minimal-action action-edit"
                                                        data-id="<%= c.Id %>"
                                                        data-code="<%= c.CourseCode %>"
                                                        data-title="<%= c.Title %>"
                                                        data-desc="<%= c.Description || '' %>"
                                                        data-price="<%= c.BasePrice %>"
                                                        data-lessons="<%= c.TotalLessons %>"
                                                        data-tags="<%= c.MetadataTags || '' %>"
                                                        data-image="<%= c.ImageUrl || '' %>"
                                                        onclick="handleEditCourseClick(this)"
                                                        title="Sửa khóa học">
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">edit</span>
                                                    </button>
                                                    
                                                    <!-- Xóa khóa học (Trash) -->
                                                    <form action="/Admin/DeleteCourse/<%= c.Id %>" method="post" style="display:inline; margin: 0;" onsubmit="return confirm('Xác nhận xóa khóa học?')">
                                                        <input type="hidden" name="id" value="<%= c.Id %>" />
                                                        <button type="submit" class="btn-minimal-action action-delete" title="Xóa khóa học">
                                                            <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>


                    </div>
                </div>

                <!-- Tab: Doanh thu -->
                <div class="tab-content" id="tabRevenue">
                    <!-- Overview Statistics Cards inside Revenue -->
                    <div class="stats-grid" style="margin-bottom: 2rem;">
                        <div class="stat-card" style="border-left: 4px solid #2563EB;">
                            <span class="stat-title"><i class="fa-solid fa-wallet"></i>
                                Thực
                                Nhận
                                (CASH/BANK)</span>
                            <span class="stat-value" style="color: #1D4ED8;">
                                <%= Number(paidRevenue).toLocaleString("vi-VN") %>
                                    VNĐ
                            </span>
                        </div>
                        <div class="stat-card" style="border-left: 4px solid #F59E0B;">
                            <span class="stat-title"><i class="fa-solid fa-money-bill-wave"></i>
                                Dự
                                Thu
                                (Chưa
                                thanh
                                toán)</span>
                            <span class="stat-value" style="color: #F59E0B;">
                                <%= Number(unpaidRevenue).toLocaleString("vi-VN") %>
                                    VNĐ
                            </span>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-bottom: 2rem;">
                        <!-- Monthly Revenue Chart (SVG Line Chart) -->
                        <div class="chart-container-custom" style="margin-bottom: 0;">
                            <div class="chart-header">
                                <span class="chart-title"><i class="fa-solid fa-chart-line" style="color: #2563EB;"></i>
                                    Biểu
                                    đồ
                                    xu
                                    hướng
                                    doanh
                                    thu
                                    hàng
                                    tháng</span>
                                <span style="font-size: 0.85rem; color: var(--text-muted);">Năm
                                    2026</span>
                            </div>

                            <div style="position: relative; height: 200px;">
                                <svg viewBox="0 0 500 200" style="width: 100%; height: 100%; overflow: visible;">
                                    <defs>
                                        <linearGradient id="chartGradRev" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#2563EB" stop-opacity="0.35" />
                                            <stop offset="100%" stop-color="#2563EB" stop-opacity="0.0" />
                                        </linearGradient>
                                    </defs>
                                    <line x1="40" y1="20" x2="480" y2="20" stroke="#E5E7EB" stroke-dasharray="4" />
                                    <line x1="40" y1="70" x2="480" y2="70" stroke="#E5E7EB" stroke-dasharray="4" />
                                    <line x1="40" y1="120" x2="480" y2="120" stroke="#E5E7EB" stroke-dasharray="4" />
                                    <line x1="40" y1="170" x2="480" y2="170" stroke="#E5E7EB" />

                                    <path class="animated-area"
                                        d="M 40,170 Q 128,110 216,130 T 392,50 T 480,40 L 480,170 L 40,170 Z"
                                        fill="url(#chartGradRev)" />
                                    <path class="animated-line" d="M 40,170 Q 128,110 216,130 T 392,50 T 480,40"
                                        fill="none" stroke="#2563EB" stroke-width="3.5" stroke-linecap="round" />

                                    <circle cx="128" cy="110" r="5" fill="#2563EB" stroke="#FFF" stroke-width="1.5" />
                                    <circle cx="216" cy="130" r="5" fill="#2563EB" stroke="#FFF" stroke-width="1.5" />
                                    <circle cx="392" cy="50" r="5" fill="#2563EB" stroke="#FFF" stroke-width="1.5" />
                                    <circle cx="480" cy="40" r="5" fill="#2563EB" stroke="#FFF" stroke-width="1.5" />

                                    <text x="40" y="190" fill="var(--text-muted)" font-size="9"
                                        text-anchor="middle">T3</text>
                                    <text x="128" y="190" fill="var(--text-muted)" font-size="9"
                                        text-anchor="middle">T4</text>
                                    <text x="216" y="190" fill="var(--text-muted)" font-size="9"
                                        text-anchor="middle">T5</text>
                                    <text x="392" y="190" fill="var(--text-muted)" font-size="9"
                                        text-anchor="middle">T6</text>
                                    <text x="480" y="190" fill="var(--text-muted)" font-size="9"
                                        text-anchor="middle">T7</text>
                                </svg>
                            </div>
                        </div>

                        <!-- Collection Rate (SVG Circle Donut) -->
                        <div class="chart-container-custom"
                            style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; margin-bottom: 0;">
                            <div class="chart-header" style="width: 100%;">
                                <span class="chart-title"><i class="fa-solid fa-chart-pie" style="color: #2563EB;"></i>
                                    Tỉ
                                    lệ
                                    hoàn
                                    thành
                                    học
                                    phí</span>
                            </div>
                            <div style="position: relative; width: 130px; height: 130px; margin: 1rem 0;">
