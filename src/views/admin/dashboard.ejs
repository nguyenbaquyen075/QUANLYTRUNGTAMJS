            </div>
        </div>

        <script>
            let currentCropper = null;
            let cropperType = '';

            function toggleCourseClasses(courseId) {
                const row = document.getElementById('classes-for-course-' + courseId);
                if (row.style.display === 'none') {
                    row.style.display = 'table-row';
                } else {
                    row.style.display = 'none';
                }
            }

            function openCreateClassModalForCourse(courseId) {
                const courseSelect = document.querySelector('#classModal select[name="courseId"]');
                if (courseSelect) {
                    courseSelect.value = courseId;
                }
                openModal('classModal');
            }

            function openModal(id) {
                document.getElementById(id).style.display = 'flex';
            }

            function closeModal(id) {
                document.getElementById(id).style.display = 'none';
                if (currentCropper) {
                    currentCropper.destroy();
                    currentCropper = null;
                }
                const createContainer = document.getElementById('createCropperContainer');
                if (createContainer) createContainer.style.display = 'none';
                const editContainer = document.getElementById('editCropperContainer');
                if (editContainer) editContainer.style.display = 'none';
            }

            function initCropper(input, type) {
                const file = input.files[0];
                if (!file) return;

                const currentContainer = document.getElementById('currentCourseImageContainer');
                if (currentContainer && type === 'edit') {
                    currentContainer.style.display = 'none';
                }

                const container = document.getElementById(type + 'CropperContainer');
                const image = document.getElementById(type + 'CropperImage');

                const reader = new FileReader();
                reader.onload = function(e) {
                    image.src = e.target.result;
                    container.style.display = 'block';

                    if (currentCropper) {
                        currentCropper.destroy();
                    }

                    currentCropper = new Cropper(image, {
                        aspectRatio: 16 / 9,
                        viewMode: 0,
                        dragMode: 'move',
                        autoCropArea: 0.9,
                        restore: false,
                        guides: true,
                        center: true,
                        highlight: false,
                        cropBoxMovable: true,
                        cropBoxResizable: true,
                        toggleDragModeOnDblclick: false,
                        ready: function() {
                            const containerData = this.cropper.getContainerData();
                            const imageData = this.cropper.getImageData();
                            const scale = Math.max(
                                containerData.width / imageData.naturalWidth,
                                containerData.height / imageData.naturalHeight
                            );
                            this.cropper.zoomTo(scale);
                        }
                    });
                    cropperType = type;
                };
                reader.readAsDataURL(file);
            }

            function handleCourseFormSubmit(event, form, type) {
                const fileInput = document.getElementById(type === 'create' ? 'courseImageInput' : 'editCourseImageInput');
                const removeInput = document.getElementById('removeImageInput');
                const isRemoving = removeInput && removeInput.value === 'true';

                if (currentCropper && !isRemoving && (type === 'create' || fileInput.files.length > 0 || (fileInput.files.length === 0 && document.getElementById('editCropperContainer').style.display !== 'none'))) {
                    event.preventDefault();

                    currentCropper.getCroppedCanvas({ fillColor: '#ffffff' }).toBlob((blob) => {
                        const formData = new FormData(form);
                        formData.delete('courseImage');
                        formData.append('courseImage', blob, 'cropped_image.png');

                        const submitBtn = form.querySelector('button[type="submit"]');
                        if (submitBtn) {
                            submitBtn.disabled = true;
                            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang tải lên...';
                        }

                        fetch(form.action, {
                            method: 'POST',
                            body: formData
                        })
                        .then(res => {
                            if (res.ok) {
                                window.location.reload();
                            } else {
                                alert('Lỗi hệ thống khi lưu khóa học.');
                                if (submitBtn) {
                                    submitBtn.disabled = false;
                                    submitBtn.innerHTML = type === 'create' ? '<i class="fa-solid fa-save"></i> Lưu Khóa Học' : '<i class="fa-solid fa-save"></i> Cập Nhật Khóa Học';
                                }
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            alert('Lỗi kết nối mạng.');
                            if (submitBtn) {
                                submitBtn.disabled = false;
                                submitBtn.innerHTML = type === 'create' ? '<i class="fa-solid fa-save"></i> Lưu Khóa Học' : '<i class="fa-solid fa-save"></i> Cập Nhật Khóa Học';
                            }
                        });
                    }, 'image/png');
                }
            }

            function handleEditCourseClick(btn) {
                const id = btn.getAttribute('data-id');
                const code = btn.getAttribute('data-code');
                const title = btn.getAttribute('data-title');
                const desc = btn.getAttribute('data-desc');
                const price = btn.getAttribute('data-price');
                const lessons = btn.getAttribute('data-lessons');
                const tags = btn.getAttribute('data-tags');
                const imageUrl = btn.getAttribute('data-image');
                
                document.getElementById('editCourseForm').action = '/Course/Update/' + id;
                document.getElementById('editCourseCode').value = code;
                document.getElementById('editCourseTitle').value = title;
                document.getElementById('editCourseDesc').value = desc;
                document.getElementById('editCoursePrice').value = price;
                document.getElementById('editCourseLessons').value = lessons;
                document.getElementById('editCourseTags').value = tags;

                const imgContainer = document.getElementById('currentCourseImageContainer');
                const imgElement = document.getElementById('currentCourseImage');
                const removeInput = document.getElementById('removeImageInput');
                const fileInput = document.getElementById('editCourseImageInput');
                
                if (fileInput) fileInput.value = '';
                if (removeInput) removeInput.value = 'false';
                
                if (imageUrl) {
                    if (imgElement) imgElement.src = imageUrl;
                    if (imgContainer) imgContainer.style.display = 'flex';
                    
                    const editImage = document.getElementById('editCropperImage');
                    if (editImage) {
                        editImage.src = imageUrl;
                        document.getElementById('editCropperContainer').style.display = 'block';
                        
                        if (currentCropper) {
                            currentCropper.destroy();
                        }
                        
                        currentCropper = new Cropper(editImage, {
                            aspectRatio: 16 / 9,
                            viewMode: 0,
                            dragMode: 'move',
                            autoCropArea: 0.9,
                            restore: false,
                            guides: true,
                            center: true,
                            highlight: false,
                            cropBoxMovable: true,
                            cropBoxResizable: true,
                            toggleDragModeOnDblclick: false,
                            ready: function() {
                                const containerData = this.cropper.getContainerData();
                                const imageData = this.cropper.getImageData();
                                const scale = Math.max(
                                    containerData.width / imageData.naturalWidth,
                                    containerData.height / imageData.naturalHeight
                                );
                                this.cropper.zoomTo(scale);
                            }
                        });
                    }
                } else {
                    if (imgContainer) imgContainer.style.display = 'none';
                    document.getElementById('editCropperContainer').style.display = 'none';
                    if (currentCropper) {
                        currentCropper.destroy();
                        currentCropper = null;
                    }
                }
                
                openModal('editCourseModal');
            }

            function removeCurrentCourseImage() {
                const removeInput = document.getElementById('removeImageInput');
                if (removeInput) removeInput.value = 'true';
                
                const container = document.getElementById('currentCourseImageContainer');
                if (container) container.style.display = 'none';
                
                const cropperContainer = document.getElementById('editCropperContainer');
                if (cropperContainer) cropperContainer.style.display = 'none';
                
                if (currentCropper) {
                    currentCropper.destroy();
                    currentCropper = null;
                }
                
                const fileInput = document.getElementById('editCourseImageInput');
                if (fileInput) fileInput.value = '';
            }

            function setCropperRatio(ratio) {
                if (currentCropper) {
                    currentCropper.setAspectRatio(ratio);
                }
            }

            function fitEntireImage() {
                if (currentCropper) {
                    currentCropper.setAspectRatio(16/9);
                    const containerData = currentCropper.getContainerData();
                    const imageData = currentCropper.getImageData();
                    
                    const scale = Math.min(
                        containerData.width / imageData.naturalWidth,
                        containerData.height / imageData.naturalHeight
                    );
                    
                    currentCropper.zoomTo(scale * 0.95);
                    currentCropper.moveTo(
                        (containerData.width - imageData.naturalWidth * scale * 0.95) / 2,
                        (containerData.height - imageData.naturalHeight * scale * 0.95) / 2
                    );
                }
            }

            function switchTab(tabId) {
                // hide all tab contents
                const contents = document.querySelectorAll('.tab-content');
                contents.forEach(c => c.classList.remove('active'));

                // deactivate all tab buttons
                const buttons = document.querySelectorAll('.admin-tab-btn');
                buttons.forEach(b => b.classList.remove('active'));

                // show target
                document.getElementById(tabId).classList.add('active');

                // Find and activate sidebar button
                const activeBtn = Array.from(buttons).find(b => b.getAttribute('onclick').includes(tabId));
                if (activeBtn) activeBtn.classList.add('active');
            }


            function updateThemeSelectionUI() {
                const activeTheme = localStorage.getItem('theme_name') || 'blue';
                const cards = document.querySelectorAll('.theme-card');
                cards.forEach(card => {
                    card.style.borderColor = 'var(--border-color)';
                    card.style.boxShadow = 'none';
                });

                const activeCard = document.getElementById('theme-' + activeTheme);
                if (activeCard) {
                    activeCard.style.borderColor = 'var(--primary)';
                    activeCard.style.boxShadow = '0 0 0 2px rgba(37, 99, 235, 0.1)';
                }
            }

            // On Load
            window.addEventListener('DOMContentLoaded', () => {
                // Check URL query parameters
                const urlParams = new URLSearchParams(window.location.search);
                const tab = urlParams.get('tab');
                if (tab) {
                    switchTab(tab);
                }
                updateThemeSelectionUI();
            });

            function filterTeachersTable() {
                const input = document.getElementById("teacherSearchInput");
                const filter = input.value.toLowerCase();
                const table = document.getElementById("teachersTable");
                const trs = table.getElementsByTagName("tr");

                for (let i = 1; i < trs.length; i++) {
                    let tr = trs[i];
                    let cells = tr.getElementsByTagName("td");
                    let match = false;
                    for (let j = 0; j < cells.length - 1; j++) {
                        if (cells[j].innerText.toLowerCase().indexOf(filter) > -1) {
                            match = true;
                            break;
                        }
                    }
                    tr.style.display = match ? "" : "none";
                }
            }

            function filterStudentsTable() {
                const searchVal = document.getElementById("studentSearchInput").value.toLowerCase().trim();
                const classFilter = document.getElementById("studentClassFilter").value;
                const blockFilter = document.getElementById("studentBlockFilter").value;
                const statusFilter = document.getElementById("studentStatusFilter").value;
                
                const table = document.getElementById("studentsTable");
                const trs = table.querySelectorAll("tbody tr.student-row-data");

                trs.forEach(tr => {
                    const rowName = tr.getAttribute("data-name") || "";
                    const rowEmail = tr.getAttribute("data-email") || "";
                    const rowPhone = tr.getAttribute("data-phone") || "";
                    const rowClass = tr.getAttribute("data-class") || "";
                    const rowBlock = tr.getAttribute("data-block") || "";
                    const rowStatus = tr.getAttribute("data-status") || "";

                    const matchesSearch = rowName.includes(searchVal) || 
                                          rowEmail.includes(searchVal) || 
                                          rowPhone.includes(searchVal);
                                          
                    const matchesClass = classFilter === "ALL" || rowClass === classFilter;
                    const matchesBlock = blockFilter === "ALL" || rowBlock === blockFilter;
                    const matchesStatus = statusFilter === "ALL" || rowStatus === statusFilter;

                    if (matchesSearch && matchesClass && matchesBlock && matchesStatus) {
                        tr.style.display = "";
                    } else {
                        tr.style.display = "none";
                    }
                });
            }

            function exportStudentsCSV() {
                const table = document.getElementById("studentsTable");
                const rows = table.querySelectorAll("tbody tr.student-row-data");
                if (rows.length === 0) {
                    alert("Không có dữ liệu học sinh để xuất");
                    return;
                }

                let csvContent = "data:text/csv;charset=utf-8,\uFEFF";
                csvContent += "STT,Họ và tên,Email,Số điện thoại,Lớp học,Khối lớp,Trạng thái\n";

                let index = 1;
                rows.forEach(tr => {
                    if (tr.style.display !== "none") {
                        const name = tr.querySelector("td:nth-child(2)").innerText.trim().replace(/"/g, '""');
                        const email = tr.querySelector("td:nth-child(3)").innerText.trim().replace(/"/g, '""');
                        const phone = tr.querySelector("td:nth-child(4)").innerText.trim().replace(/"/g, '""');
                        const className = tr.getAttribute("data-class").replace(/"/g, '""');
                        const blockName = tr.getAttribute("data-block").replace(/"/g, '""');
                        const status = tr.getAttribute("data-status").replace(/"/g, '""');

                        csvContent += `${index},"${name}","${email}","${phone}","${className}","${blockName}","${status}"\n`;
                        index++;
                    }
                });

                const encodedUri = encodeURI(csvContent);
                const link = document.createElement("a");
                link.setAttribute("href", encodedUri);
                link.setAttribute("download", "danh_sach_hoc_sinh.csv");
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }

            function openEditTeacherModal(id, fullName, phone, title, subject, exp, students, rating, bio) {
                document.getElementById('editTeacherId').value = id;
                document.getElementById('editTeacherFullName').value = fullName || '';
                document.getElementById('editTeacherPhone').value = phone || '';
                document.getElementById('editTeacherTitle').value = title || '';
                document.getElementById('editTeacherSubject').value = subject || '';
                document.getElementById('editTeacherExp').value = exp !== undefined && exp !== '' ? exp : '';
                document.getElementById('editTeacherStudents').value = students !== undefined && students !== '' ? students : '';
                document.getElementById('editTeacherRating').value = rating !== undefined && rating !== '' ? rating : '';
                document.getElementById('editTeacherBio').value = bio || '';
                document.getElementById('editTeacherSubtitle').textContent = fullName || '';
                const modal = document.getElementById('editTeacherModal');
                modal.style.display = 'flex';
            }

            async function submitEditTeacher(event) {
                event.preventDefault();
                const btn = document.getElementById('btnSaveEditTeacher');
                const origHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

                const formData = new FormData(document.getElementById('formEditTeacher'));
                try {
                    const resp = await fetch('/Admin/UpdateTeacherInfo', { method: 'POST', body: formData });
                    const result = await resp.json();
                    if (result.success) {
                        closeModal('editTeacherModal');
                        if (typeof showToastNotification === 'function') {
                            showToastNotification(result.message || 'Cập nhật thành công!', 'success');
                        } else {
                            alert(result.message || 'Cập nhật thành công!');
                        }
                        // Reload after short delay to refresh table data
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        if (typeof showToastNotification === 'function') {
                            showToastNotification(result.message || 'Có lỗi xảy ra.', 'error');
                        } else {
                            alert(result.message || 'Có lỗi xảy ra.');
                        }
                    }
                } catch(err) {
                    console.error(err);
                    alert('Lỗi kết nối. Vui lòng thử lại.');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = origHtml;
                }
            }

            function openEditStudentModal(id, fullName, phone, gender, dob, address, parentId) {
                document.getElementById('editStudentId').value = id;
                document.getElementById('editStudentFullName').value = fullName || '';
                document.getElementById('editStudentPhone').value = phone || '';
                document.getElementById('editStudentGender').value = gender !== undefined && gender !== '' ? gender : '';
                document.getElementById('editStudentDob').value = dob || '';
                document.getElementById('editStudentAddress').value = address || '';
                document.getElementById('editStudentParentId').value = parentId !== undefined && parentId !== '' ? parentId : '';
                document.getElementById('editStudentSubtitle').textContent = fullName || '';
                const modal = document.getElementById('editStudentModal');
                modal.style.display = 'flex';
            }

            async function submitEditStudent(event) {
                event.preventDefault();
                const btn = document.getElementById('btnSaveEditStudent');
                const origHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

                const formData = new FormData(document.getElementById('formEditStudent'));
                const urlSearchParams = new URLSearchParams(formData);

                try {
                    const resp = await fetch('/Admin/UpdateStudentInfo', { 
                        method: 'POST', 
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: urlSearchParams
                    });
                    const result = await resp.json();
                    if (result.success) {
                        closeModal('editStudentModal');
                        if (typeof showToastNotification === 'function') {
                            showToastNotification(result.message || 'Cập nhật thành công!', 'success');
                        } else {
                            alert(result.message || 'Cập nhật thành công!');
                        }
                        // Reload after short delay to refresh table data
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        if (typeof showToastNotification === 'function') {
                            showToastNotification(result.message || 'Có lỗi xảy ra.', 'error');
                        } else {
                            alert(result.message || 'Có lỗi xảy ra.');
                        }
                    }
                } catch(err) {
                    console.error(err);
                    alert('Lỗi kết nối. Vui lòng thử lại.');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = origHtml;
                }
            }
        </script>