                    </div>
                </div>

                <!-- Tab: Quản lý Giáo viên -->
                <div class="tab-content" id="tabTeachers">
                    <div class="chart-container-custom">
                        <div class="chart-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                            <span class="chart-title"><i class="fa-solid fa-user-graduate" style="color: #2563EB;"></i> Danh sách giáo viên của trung tâm</span>
                            <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                                <input type="text" id="teacherSearchInput" class="form-input-custom"
                                    placeholder="Tìm kiếm giáo viên..." onkeyup="filterTeachersTable()"
                                    style="max-width: 250px; padding: 0.4rem 0.8rem; font-size: 0.9rem; margin: 0; height: 34px;" />
                                <button class="btn-custom" onclick="openModal('userModal')" style="padding: 0.4rem 0.8rem; font-size: 0.82rem; height: 34px; background: linear-gradient(135deg, #4f46e5, #7c3aed); border: none; white-space: nowrap;">
                                    <i class="fa-solid fa-user-plus"></i> Thêm Người Dùng
                                </button>
                            </div>
                        </div>
                        <div class="table-wrapper">
                            <table class="table-custom" id="teachersTable">
                                <thead>
                                    <tr>
                                        <th>Họ Tên</th>
                                        <th>Email</th>
                                        <th>Số Điện Thoại</th>
                                        <th>Học vị / Môn dạy</th>
                                        <th>Trạng Thái</th>
                                        <th style="text-align: right;">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% teachers.forEach(t=> { %>
                                        <%
                                            const tp = t.Profile;
                                            const tTitle = tp && tp.TeacherTitle ? tp.TeacherTitle : '';
                                            const tSubject = tp && tp.Subject ? tp.Subject : '';
                                            const tExp = tp && tp.TeacherExperience !== null ? tp.TeacherExperience : '';
                                            const tStudents = tp && tp.TeacherStudents !== null ? tp.TeacherStudents : '';
                                            const tRating = tp && tp.TeacherRating !== null ? parseFloat(tp.TeacherRating).toFixed(1) : '';
                                            const tBio = tp && tp.TeacherBio ? tp.TeacherBio : '';
                                        %>
                                        <tr>
                                            <td style="font-weight: 600;">
                                                <div style="font-weight: 700; color: #1E293B;"><%= t.FullName %></div>
                                                <% if (tTitle) { %><div style="font-size: 0.75rem; color: #64748B;"><%= tTitle %></div><% } %>
                                            </td>
                                            <td><%= t.Email %></td>
                                            <td><%= t.Phone %></td>
                                            <td>
                                                <% if (tSubject) { %>
                                                    <span style="display:inline-flex; align-items:center; gap:0.3rem; font-size:0.78rem; background:#EDE9FE; color:#5B21B6; padding:0.2rem 0.6rem; border-radius:99px; font-weight:600;">
                                                        <i class="fa-solid fa-book-open" style="font-size:0.7rem;"></i> <%= tSubject %>
                                                    </span>
                                                <% } else { %>
                                                    <span style="font-size:0.78rem; color:#94A3B8;">Chưa cập nhật</span>
                                                <% } %>
                                                <% if (tExp !== '') { %><div style="font-size:0.72rem; color:#64748B; margin-top:0.2rem;"><i class="fa-solid fa-star" style="color:#F59E0B;"></i> <%= tExp %> năm KN</div><% } %>
                                            </td>
                                            <td>
                                                <% if (t.Status===0) { %>
                                                     <span class="badge-custom badge-success"><i class="fa-solid fa-circle-check"></i> Đang giảng dạy</span>
                                                <% } else { %>
                                                     <span class="badge-custom" style="background-color: #EF4444; color: white;"><i class="fa-solid fa-lock"></i> Đang bị khóa</span>
                                                <% } %>
                                            </td>
                                            <td style="text-align: right;">
                                                <div style="display: flex; gap: 0.8rem; justify-content: flex-end; align-items: center;">
                                                    <!-- Sửa thông tin (Pencil) -->
                                                    <button type="button" class="btn-minimal-action action-edit"
                                                        onclick="openEditTeacherModal(<%= t.Id %>, '<%= (t.FullName||'').replace(/'/g, "\\'") %>', '<%= (t.Phone||'').replace(/'/g, "\\'") %>', '<%= tTitle.replace(/'/g, "\\'") %>', '<%= tSubject.replace(/'/g, "\\'") %>', '<%= tExp %>', '<%= tStudents %>', '<%= tRating %>', `<%= tBio.replace(/`/g, '\\`').replace(/\$/g, '\\$') %>`)"
                                                        title="Sửa thông tin"
                                                    >
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">edit</span>
                                                    </button>
                                                    
                                                    <!-- Tạm khóa / Mở khóa (Lock) -->
                                                    <form action="/Admin/ToggleUserStatus/<%= t.Id %>" method="post" style="display:inline; margin: 0;">
                                                        <input type="hidden" name="id" value="<%= t.Id %>" />
                                                        <% if (t.Status===0) { %>
                                                            <button type="submit" class="btn-minimal-action action-lock" title="Tạm khóa">
                                                                <span class="material-symbols-outlined" style="font-size: 20px;">lock_open</span>
                                                            </button>
                                                        <% } else { %>
                                                            <button type="submit" class="btn-minimal-action action-lock" title="Mở khóa">
                                                                <span class="material-symbols-outlined" style="font-size: 20px; color: #EF4444 !important;">lock</span>
                                                            </button>
                                                        <% } %>
                                                    </form>
                                                    
                                                    <!-- Xóa giáo viên (Trash) -->
                                                    <form action="/Admin/DeleteUser/<%= t.Id %>" method="post" style="display:inline; margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn XÓA VĨNH VIỄN giáo viên này khỏi hệ thống không?')">
                                                        <button type="submit" class="btn-minimal-action action-delete" title="Xóa giáo viên">
                                                            <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                                                        </button>
                                                    </form>

                                                    <!-- Thao tác khác (More) -->
                                                    <button type="button" class="btn-minimal-action action-more" title="Thao tác khác">
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">more_vert</span>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tab: Quản lý Học sinh -->
                <div class="tab-content" id="tabStudents">
                    <%
                        const totalStudentsCount = students.length;
                        const activeStudentsCount = students.filter(s => s.Status === 0).length;
                        
                        let ieltsStudentsCount = 0;
                        let basicStudentsCount = 0;
                        students.forEach(s => {
                            let cn = '';
                            if (s.ClassEnrollments && s.ClassEnrollments.length > 0) {
                                const active = s.ClassEnrollments.find(e => e.Status === 0 || e.Status === 1) || s.ClassEnrollments[0];
                                if (active && active.Class) {
                                    cn = active.Class.Course ? active.Class.Course.Title : active.Class.ClassName;
                                }
                            }
                            if (cn.includes('IELTS')) ieltsStudentsCount++;
                            else if (cn.includes('Giao tiếp')) basicStudentsCount++;
                        });
                    %>


                    <div class="chart-container-custom">
                        <!-- Search & Filter Controls -->
                        <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.25rem;">
                            <input type="text" id="studentSearchInput" class="form-input-custom" placeholder="Tìm kiếm học sinh..." onkeyup="filterStudentsTable()" style="max-width: 240px; padding: 0.4rem 0.8rem; font-size: 0.9rem; margin: 0; height: 36px;" />
                            
                            <select id="studentClassFilter" onchange="filterStudentsTable()" class="form-input-custom" style="max-width: 200px; padding: 0.4rem 2rem 0.4rem 0.8rem; font-size: 0.9rem; margin: 0; height: 36px; border: 1px solid rgba(30, 58, 138, 0.15);">
                                <option value="ALL">Lớp học: Tất cả</option>
                                <option value="Chưa liên kết">Chưa liên kết</option>
                                <% 
                                    const uniqueClassNames = new Set();
                                    classes.forEach(cls => {
                                        if (cls.Course && cls.Course.Title) {
                                            uniqueClassNames.add(cls.Course.Title);
                                        } else if (cls.ClassName) {
                                            uniqueClassNames.add(cls.ClassName);
                                        }
                                    });
                                    uniqueClassNames.forEach(name => {
                                %>
                                    <option value="<%= name %>"><%= name %></option>
                                <% }); %>
                            </select>

                            <select id="studentBlockFilter" onchange="filterStudentsTable()" class="form-input-custom" style="max-width: 200px; padding: 0.4rem 2rem 0.4rem 0.8rem; font-size: 0.9rem; margin: 0; height: 36px; border: 1px solid rgba(30, 58, 138, 0.15);">
                                <option value="ALL">Khối lớp: Tất cả</option>
                                <option value="Khối 10">Khối 10</option>
                                <option value="Khối 11">Khối 11</option>
                                <option value="Khối 12">Khối 12</option>
                            </select>

                            <select id="studentStatusFilter" onchange="filterStudentsTable()" class="form-input-custom" style="max-width: 200px; padding: 0.4rem 2rem 0.4rem 0.8rem; font-size: 0.9rem; margin: 0; height: 36px; border: 1px solid rgba(30, 58, 138, 0.15);">
                                <option value="ALL">Trạng thái: Tất cả</option>
                                <option value="Đang học">Đang học</option>
                                <option value="Đã nghỉ học">Đã nghỉ học</option>
                                <option value="Bảo lưu">Bảo lưu</option>
                            </select>

                            <button onclick="exportStudentsCSV()" class="btn-secondary-custom" style="padding: 0.4rem 1rem; font-size: 0.82rem; height: 36px; display: inline-flex; align-items: center; gap: 0.35rem; border-color: #cbd5e1; color: #475569; background: #fff; border-radius: 8px;">
                                <i class="fa-solid fa-download"></i> Xuất dữ liệu
                            </button>
                            
                            <button class="btn-custom" onclick="openModal('userModal')" style="margin-left: auto; padding: 0.4rem 1rem; font-size: 0.82rem; height: 36px; background: linear-gradient(135deg, #4f46e5, #7c3aed); border: none; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.35rem; border-radius: 8px;">
                                <i class="fa-solid fa-user-plus"></i> Thêm Học Sinh
                            </button>
                        </div>

                        <div class="table-wrapper">
                            <table class="table-custom" id="studentsTable">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">STT</th>
                                        <th>Họ Tên</th>
                                        <th>Email</th>
                                        <th>Số Điện Thoại</th>
                                        <th>Lớp học</th>
                                        <th>Khối lớp</th>
                                        <th>Trạng Thái</th>
                                        <th style="text-align: right;">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% students.forEach((s, idx)=> { %>
                                        <%
                                            const sp = s.Profile;
                                            const sDob = sp && sp.Dob ? new Date(sp.Dob).toLocaleDateString('vi-VN') : '';
                                            const sDobRaw = sp && sp.Dob ? new Date(sp.Dob).toISOString().split('T')[0] : '';
                                            const sGender = sp && sp.Gender !== null ? sp.Gender : '';
                                            const sGenderText = sGender === 0 ? 'Nam' : (sGender === 1 ? 'Nữ' : (sGender === 2 ? 'Khác' : ''));
                                            const sAddress = sp && sp.Address ? sp.Address : '';
                                            const parentName = sp && sp.Parent ? sp.Parent.FullName : '';
                                            const parentId = sp && sp.ParentId ? sp.ParentId : '';

                                            // Get class
                                            let className = 'Chưa liên kết';
                                            if (s.ClassEnrollments && s.ClassEnrollments.length > 0) {
                                                const active = s.ClassEnrollments.find(e => e.Status === 0 || e.Status === 1) || s.ClassEnrollments[0];
                                                if (active && active.Class) {
                                                    className = active.Class.Course ? active.Class.Course.Title : active.Class.ClassName;
                                                }
                                            }

                                            // Get block
                                            let blockName = s.Id % 3 === 0 ? 'Khối 10' : (s.Id % 3 === 1 ? 'Khối 11' : 'Khối 12');

                                            // Status text
                                            let statusText = 'Đang học';
                                            if (s.Status === 1) statusText = 'Đã nghỉ học';
                                            else if (s.Status === 2) statusText = 'Bảo lưu';
                                        %>
                                        <tr class="student-row-data" data-name="<%= s.FullName.toLowerCase() %>" data-email="<%= s.Email.toLowerCase() %>" data-phone="<%= s.Phone %>" data-class="<%= className %>" data-block="<%= blockName %>" data-status="<%= statusText %>">
                                            <td><%= idx + 1 %></td>
                                            <td style="font-weight: 600;">
                                                <div style="font-weight: 700; color: #1E293B;"><%= s.FullName %></div>
                                            </td>
                                            <td><%= s.Email %></td>
                                            <td><%= s.Phone %></td>
                                            <td>
                                                <span class="badge-custom <%= className.includes('IELTS') ? 'badge-primary' : (className.includes('Giao tiếp') ? 'badge-warning' : '') %>" style="<%= className === 'Chưa liên kết' ? 'background: #f1f5f9; color: #94a3b8; border: 1px solid #cbd5e1;' : '' %>">
                                                    <%= className %>
                                                </span>
                                            </td>
                                            <td style="font-weight: 500; color: #475569;"><%= blockName %></td>
                                            <td style="white-space: nowrap;">
                                                <% if (s.Status===0) { %>
                                                     <span class="badge-custom badge-success" style="white-space: nowrap; display: inline-flex; align-items: center; gap: 0.25rem;"><span class="material-symbols-outlined" style="font-size: 14px;">check_circle</span> Đang học</span>
                                                <% } else if (s.Status===2) { %>
                                                     <span class="badge-custom" style="background-color: #FEF3C7; color: #D97706; border: 1px solid #FDE68A; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.25rem;"><span class="material-symbols-outlined" style="font-size: 14px;">pending</span> Bảo lưu</span>
                                                <% } else { %>
                                                     <span class="badge-custom" style="background-color: #FEE2E2; color: #DC2626; border: 1px solid #FCA5A5; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.25rem;"><span class="material-symbols-outlined" style="font-size: 14px;">cancel</span> Đã nghỉ</span>
                                                <% } %>
                                            </td>
                                            <td style="text-align: right;">
                                                <div style="display: flex; gap: 0.8rem; justify-content: flex-end; align-items: center;">
                                                    <!-- Sửa thông tin (Pencil) -->
                                                    <button type="button" class="btn-minimal-action action-edit"
                                                        onclick="openEditStudentModal(<%= s.Id %>, '<%= (s.FullName||'').replace(/'/g, "\\'") %>', '<%= (s.Phone||'').replace(/'/g, "\\'") %>', '<%= sGender %>', '<%= sDobRaw %>', '<%= sAddress.replace(/'/g, "\\'") %>', '<%= parentId %>')"
                                                        title="Sửa thông tin"
                                                    >
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">edit</span>
                                                    </button>
                                                    
                                                    <!-- Tạm khóa / Mở khóa (Lock) -->
                                                    <form action="/Admin/ToggleUserStatus/<%= s.Id %>" method="post" style="display:inline; margin: 0;">
                                                        <input type="hidden" name="id" value="<%= s.Id %>" />
                                                        <% if (s.Status===0) { %>
                                                            <button type="submit" class="btn-minimal-action action-lock" title="Tạm khóa">
                                                                <span class="material-symbols-outlined" style="font-size: 20px;">lock_open</span>
                                                            </button>
                                                        <% } else { %>
                                                            <button type="submit" class="btn-minimal-action action-lock" title="Mở khóa">
                                                                <span class="material-symbols-outlined" style="font-size: 20px; color: #EF4444 !important;">lock</span>
                                                            </button>
                                                        <% } %>
                                                    </form>
                                                    
                                                    <!-- Xóa (Trash) -->
                                                    <form action="/Admin/DeleteUser/<%= s.Id %>" method="post" style="display:inline; margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn XÓA VĨNH VIỄN học sinh này khỏi hệ thống không?')">
                                                        <button type="submit" class="btn-minimal-action action-delete" title="Xóa học sinh">
                                                            <span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
                                                        </button>
                                                    </form>

                                                    <!-- Thao tác khác (More) -->
                                                    <button type="button" class="btn-minimal-action action-more" title="Thao tác khác">
                                                        <span class="material-symbols-outlined" style="font-size: 20px;">more_vert</span>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tab: Thanh toán học phí -->
                <div class="tab-content" id="tabPayments">
