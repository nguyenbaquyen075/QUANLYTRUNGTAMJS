                        <div class="chart-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                            <span class="chart-title"><i class="fa-solid fa-file-invoice" style="color: #2563EB;"></i> Danh sách hóa đơn học phí phát hành</span>
                            <button class="btn-custom" onclick="openModal('invoiceModal')" style="padding: 0.4rem 0.8rem; font-size: 0.82rem; height: 34px; background: linear-gradient(135deg, #4f46e5, #7c3aed); border: none; white-space: nowrap;">
                                <i class="fa-solid fa-file-invoice"></i> Xuất Hóa Đơn
                            </button>
                        </div>
                        <div class="table-wrapper">
                            <table class="table-custom">
                                <thead>
                                    <tr>
                                        <th>Mã
                                            HĐ
                                        </th>
                                        <th>Học
                                            Viên
                                        </th>
                                        <th>Lớp
                                            Học
                                        </th>
                                        <th>Số
                                            Tiền
                                        </th>
                                        <th>Hạn
                                            Đóng
                                        </th>
                                        <th>Trạng
                                            Thái
                                        </th>
                                        <th style="text-align: right;">
                                            Thao
                                            tác
                                            thu
                                            học
                                            phí
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% invoices.forEach(inv=> { %>
                                        <tr>
                                            <td style="font-weight: 600;">
                                                <%= inv.InvoiceCode %>
                                            </td>
                                            <%= inv.Student ? inv.Student.FullName : "" %></strong> </td>
                                                <td>
                                                    <%= inv.Class ? inv.Class.ClassName : "" %>
                                                </td>
                                                <td style="font-weight: 700; color: #1D4ED8;">
                                                    <%= Number(inv.Amount).toLocaleString("vi-VN") %>
                                                        đ
                                                </td>
                                                <td>
                                                    <%= new Date(inv.DueDate).toLocaleDateString("vi-VN") %>
                                                </td>
                                                <td>
                                                    <span
                                                        class="badge-custom <%= inv.Status === 1 ? 'badge-success' : 'badge-warning' %>">
                                                        <%= inv.Status===1 ? "Đã Đóng" : "Chờ Thanh Toán" %>
                                                    </span>
                                                </td>
                                                <td style="text-align: right;">
                                                    <% if (inv.Status===0) { %>
                                                        <form action="/Admin/MarkInvoicePaid/<%= inv.Id %>"
                                                            method="post" style="display: inline;">
                                                            <input type="hidden" name="id" value="<%= inv.Id %>" />
                                                            <button type="submit" class="btn-custom"
                                                                style="font-size: 0.75rem; padding: 0.3rem 0.6rem;">
                                                                <i class="fa-solid fa-check-double"></i>
                                                                Thu
                                                                tiền
                                                                mặt/chuyển
                                                                khoản
                                                            </button>
                                                        </form>
                                                        <% } else { %>
                                                            <span
                                                                style="font-size: 0.8rem; color: var(--text-muted);"><i
                                                                    class="fa-solid fa-circle-check"
                                                                    style="color: #10B981;"></i>
                                                                Đã
                                                                thu
                                                                đủ</span>
                                                            <% } %>
                                                </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Tab: Tiến độ học tập khóa học -->
