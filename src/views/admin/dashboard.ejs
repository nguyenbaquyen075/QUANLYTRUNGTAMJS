                    </div>
                    <input type="hidden" name="maxStudents" value="25" />
                    <button type="submit" class="btn-custom" style="width: 100%;"><i
                            class="fa-solid fa-calendar-check"></i>
                        Lưu & Sinh
                        Lịch Học Tự
