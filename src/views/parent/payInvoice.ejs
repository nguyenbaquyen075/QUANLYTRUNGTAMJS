<% title = "Thanh Toán Học Phí"; %>

<div class="container-fluid-custom" style="max-width: 800px; margin: 3rem auto; padding: 0 1rem;">
    <div style="margin-bottom: 1.5rem;">
        <a href="/Parent/Dashboard" class="btn-outline-custom" style="padding: 0.5rem 1rem; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;">
            <i class="fa-solid fa-arrow-left"></i> Quay lại Dashboard
        </a>
    </div>

    <div class="card-custom" style="padding: 2.5rem; box-shadow: var(--shadow-lg); border: 1.5px solid rgba(245, 158, 11, 0.15);">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 50px; height: 50px; border-radius: 50%; background: #FEF3C7; color: #D97706; display: inline-flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 0.75rem;">
                <i class="fa-solid fa-file-invoice-dollar"></i>
            </div>
            <h1 style="font-size: 1.5rem; font-weight: 800; color: var(--text-dark); margin: 0;">Thanh Toán Học Phí</h1>
            <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.25rem;">Hóa đơn: <strong><%= invoice.InvoiceCode %></strong></p>
        </div>

        <div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2.5rem; align-items: start;">
            <!-- Invoice Details & Bank Transfer Instructions -->
            <div>
                <h2 style="font-size: 1.05rem; font-weight: 700; color: var(--text-dark); border-bottom: 1.5px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;"><i class="fa-solid fa-circle-info"></i> Thông tin thanh toán</h2>
                
                <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem; font-size: 0.9rem;">
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Học sinh:</span>
                        <strong style="color: var(--text-dark);"><%= invoice.Student ? invoice.Student.FullName : 'Chưa rõ' %></strong>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Lớp học:</span>
                        <strong style="color: var(--text-dark);"><%= invoice.Class ? invoice.Class.ClassName : 'Chưa rõ' %></strong>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Hạn thanh toán:</span>
                        <strong style="color: #EF4444;"><%= new Date(invoice.DueDate).toLocaleDateString('vi-VN') %></strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; border-top: 1px dashed var(--border-color); padding-top: 0.75rem;">
                        <span style="color: var(--text-muted); font-size: 1rem;">Số tiền cần đóng:</span>
                        <strong style="color: var(--primary); font-size: 1.2rem;"><%= Number(invoice.Amount).toLocaleString('vi-VN') %> đ</strong>
                    </div>
                </div>

                <h2 style="font-size: 1.05rem; font-weight: 700; color: var(--text-dark); border-bottom: 1.5px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1rem;"><i class="fa-solid fa-building-columns"></i> Thông tin chuyển khoản</h2>
                <div style="background: #F8FAFC; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 1.25rem; font-size: 0.88rem; display: flex; flex-direction: column; gap: 0.6rem;">
                    <div>
                        <span style="color: var(--text-muted); display: block; font-size: 0.75rem; font-weight: 500;">Ngân hàng:</span>
                        <strong style="color: var(--text-dark);"><%= typeof BankName !== 'undefined' ? BankName : '' %></strong>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); display: block; font-size: 0.75rem; font-weight: 500;">Số tài khoản:</span>
                        <strong style="color: var(--text-dark); font-size: 1.05rem;"><%= typeof BankAccount !== 'undefined' ? BankAccount : '' %></strong>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); display: block; font-size: 0.75rem; font-weight: 500;">Chủ tài khoản:</span>
                        <strong style="color: var(--text-dark);"><%= typeof AccountHolder !== 'undefined' ? AccountHolder : '' %></strong>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); display: block; font-size: 0.75rem; font-weight: 500;">Nội dung chuyển khoản (Đúng cú pháp):</span>
                        <strong style="color: #D97706; background: #FEF3C7; padding: 0.25rem 0.5rem; border-radius: 4px; display: inline-block; margin-top: 0.15rem;">CKHP <%= invoice.InvoiceCode %></strong>
                    </div>
                </div>
            </div>

            <!-- VietQR Code Scan -->
            <div style="text-align: center;">
                <h2 style="font-size: 1.05rem; font-weight: 700; color: var(--text-dark); margin-bottom: 1rem;"><i class="fa-solid fa-qrcode"></i> Quét mã VietQR</h2>
                
                <% if (typeof QrCodeUrl !== 'undefined') { %>
                    <div style="background: white; border: 1px solid var(--border-color); padding: 1rem; border-radius: var(--radius-md); display: inline-block; box-shadow: var(--shadow-sm); max-width: 100%;">
                        <img src="<%= QrCodeUrl %>" alt="Mã VietQR đóng học phí" style="width: 220px; height: auto; display: block;" />
                    </div>
                <% } else { %>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">Mã QR không khả dụng.</p>
                <% } %>
                
                <p style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.4; margin-top: 1rem; padding: 0 0.5rem;"><i class="fa-solid fa-clock-rotate-left"></i> Hệ thống đối soát tự động 24/7. Hóa đơn sẽ được chuyển trạng thái <strong>Đã thanh toán</strong> ngay sau khi nhận được tiền.</p>
            </div>
        </div>
    </div>
</div>
