<% title = "Có lỗi xảy ra"; %>
<div class="container-fluid-custom" style="max-width: 600px; margin: 5rem auto; text-align: center; padding: 2rem;">
    <div style="font-size: 4rem; color: #EF4444; margin-bottom: 1.5rem;">
        <i class="fa-solid fa-triangle-exclamation"></i>
    </div>
    <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-dark); margin-bottom: 1rem;">Đã xảy ra lỗi!</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 2rem;">
        <%= typeof message !== 'undefined' ? message : 'Yêu cầu của bạn không thể xử lý vào lúc này. Vui lòng thử lại sau.' %>
    </p>
    <a href="/" class="btn-custom" style="padding: 0.75rem 2rem; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;">
        <i class="fa-solid fa-house"></i> Quay lại trang chủ
    </a>
</div>
