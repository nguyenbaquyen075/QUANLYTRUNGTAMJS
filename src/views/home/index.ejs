<!DOCTYPE html>
<html class="scroll-smooth" lang="vi">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block"
        rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-container": "#fd761a",
                        "on-tertiary-container": "#8fbeff",
                        "surface-container-lowest": "#ffffff",
                        "primary": "#00288e",
                        "secondary-fixed": "#ffdbca",
                        "outline": "#757684",
                        "surface-variant": "#e0e3e5",
                        "outline-variant": "#c4c5d5",
                        "on-error-container": "#93000a",
                        "inverse-on-surface": "#eff1f3",
                        "error-container": "#ffdad6",
                        "on-secondary-fixed": "#341100",
                        "tertiary": "#003564",
                        "on-secondary": "#ffffff",
                        "surface-tint": "#3755c3",
                        "on-tertiary-fixed-variant": "#004883",
                        "surface": "#f7f9fb",
                        "on-tertiary": "#ffffff",
                        "inverse-primary": "#b8c4ff",
                        "on-background": "#191c1e",
                        "tertiary-container": "#004c8b",
                        "surface-dim": "#d8dadc",
                        "inverse-surface": "#2d3133",
                        "on-surface": "#191c1e",
                        "on-primary-container": "#a8b8ff",
                        "on-error": "#ffffff",
                        "background": "#f7f9fb",
                        "on-secondary-container": "#5c2400",
                        "tertiary-fixed-dim": "#a4c9ff",
                        "tertiary-fixed": "#d4e3ff",
                        "surface-container-high": "#e6e8ea",
                        "primary-fixed-dim": "#b8c4ff",
                        "on-tertiary-fixed": "#001c39",
                        "error": "#ba1a1a",
                        "secondary-fixed-dim": "#ffb690",
                        "primary-fixed": "#dde1ff",
                        "on-primary-fixed-variant": "#173bab",
                        "surface-container-highest": "#e0e3e5",
                        "on-secondary-fixed-variant": "#783200",
                        "on-surface-variant": "#444653",
                        "surface-bright": "#f7f9fb",
                        "on-primary": "#ffffff",
                        "surface-container-low": "#f2f4f6",
                        "on-primary-fixed": "#001453",
                        "secondary": "#9d4300",
                        "primary-container": "#1e40af",
                        "surface-container": "#eceef0"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem",
                        "3xl": "2.5rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "sm": "8px",
                        "xl": "32px",
                        "xs": "4px",
                        "gutter-mobile": "12px",
                        "margin-mobile": "20px",
                        "lg": "24px",
                        "md": "16px",
                        "base": "4px"
                    },
                    "fontFamily": {
                        "sans": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
    <style>
        .glass-premium {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .glass-dark {
            background: rgba(0, 40, 142, 0.1);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .hero-silk-bg {
            background-image: url('https://lh3.googleusercontent.com/aida/AP1WRLvqfySXVXEJ0htQkY7XBdwDTxoN0XBrvkcOM6da23POUDb03v5xrGy6QJyDkst7wlrwHHSaQDOZekGPgGkYrWNl3a_e3bYQUzZZd4taowoiztSuSW4uac-22vrkZwaFUoNs9ClSwi8zSo9QFGAtIJ2I6F6BLXPfPkA_HWsmuFz6rVkArRSZ9MhsxKWFlzrIX4JjTw2XuuaoYs7dXR6xoGCepIhaRjUYwDOm9whKxBt64ahyaYu4y7Pjuo2I');
            background-size: cover;
            background-position: center;
        }

        .light-texture-bg {
            background-image: url('https://lh3.googleusercontent.com/aida/AP1WRLtS5Izgt_h7xr1EbKkVSlqpHWW-ZR6qVaJKZIv55up9Cb5n4_EMlj88OSQ6Pq2x4PfrWuX0qELKBkeOtnriqWw-xUpN7IzaZNx103S_AGSNmVG4dvtUeMJY8qYOaDTPqmxl1pm9EJGYTkKA5di-IluGhidXNY71uoItywAdJ4hNXYrl2tXeFhJoDmKjHElGdQw7xJ7k8a3EAd8lBkqg9PCLSvp94UfURITUGCjKSBoP0hqrpiW56tTBom00');
            background-size: cover;
            background-position: center;
        }

        .text-gradient {
            background: linear-gradient(135deg, #fff 0%, #a8b8ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-shadow {
            box-shadow: 0 20px 40px -15px rgba(0, 40, 142, 0.15);
        }

        .hover-lift {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .hover-lift:hover {
            transform: translateY(-8px);
        }

        .carousel-container {
            position: relative;
            overflow: hidden;
        }

        .carousel-track {
            display: flex;
            transition: transform 0.5s ease-in-out;
        }

        .carousel-slide {
            min-width: 100%;
        }
    </style>
</head>

<body class="antialiased font-sans selection:bg-primary-fixed selection:text-on-primary-fixed bg-surface">
    <%- include('../partials/home-navbar', { activePage: 'home', isLoggedIn: isLoggedIn, currentUserFullName: currentUserFullName, currentUserRole: currentUserRole }) %>
    <main>
        <!-- Hero Section -->
        <section class="hero-silk-bg min-h-screen relative flex items-center pt-24 overflow-hidden">
            <div class="absolute inset-0 bg-primary/20 backdrop-brightness-75 pointer-events-none"></div>
            <div class="max-w-7xl mx-auto px-margin-mobile lg:px-xl relative z-10 w-full">
                <div class="grid lg:grid-cols-12 gap-xl items-center">
                    <div class="lg:col-span-7 space-y-xl">
                        <div
                            class="inline-flex items-center gap-xs bg-white/10 border border-white/20 backdrop-blur-md px-md py-sm rounded-full">
                            <span class="material-symbols-outlined text-[18px] text-primary-fixed">auto_awesome</span>
                            <span class="text-[11px] font-black tracking-[0.25em] text-white uppercase">Công nghệ AI thế
                                hệ mới</span>
                        </div>
                        <h1 class="text-white text-[52px] md:text-[72px] leading-[1.1] font-black tracking-tight">
                            Nâng Tầm Tri Thức <br>
                            <span class="text-gradient">Đột Phá Bản Thân</span>
                        </h1>
                        <p class="text-white/80 text-lg md:text-xl max-w-2xl leading-relaxed font-normal">
                            Học trực tuyến hiệu quả cao với lộ trình cá nhân hóa. Đội ngũ giáo viên chuyên môn giỏi kết
                            hợp trợ lý AI thông minh đồng hành cùng học viên 24/7 để bứt phá điểm số.
                        </p>
                        <div class="flex flex-wrap gap-md pt-lg">
                            <button
                                class="bg-white text-primary px-xl py-lg rounded-full font-black text-sm shadow-[0_20px_50px_rgba(0,0,0,0.3)] hover:bg-primary-fixed hover:text-primary transition-all hover:scale-105 active:scale-95 flex items-center gap-sm group" onclick="location.href='/Auth/Register'">
                                Đăng Ký Học Thử Ngay
                                <span
                                    class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </button>
                            <button
                                onclick="window.location.href='/Home/Courses'"
                                class="bg-white/5 border border-white/20 text-white px-xl py-lg rounded-full font-black text-sm hover:bg-white/10 backdrop-blur-sm transition-all flex items-center gap-sm">
                                Xem Khóa Học
                            </button>
                        </div>
                        <!-- Stats -->
                        <div class="flex items-center gap-xl pt-20 border-t border-white/10">
                            <div class="space-y-xs">
                                <div class="text-3xl font-black text-white">5,000+</div>
                                <div class="text-white/50 text-[11px] font-bold uppercase tracking-widest">Học sinh
                                </div>
                            </div>
                            <div class="w-px h-12 bg-white/10"></div>
                            <div class="space-y-xs">
                                <div class="text-3xl font-black text-white">98%</div>
                                <div class="text-white/50 text-[11px] font-bold uppercase tracking-widest">Đột phá điểm
                                </div>
                            </div>
                            <div class="w-px h-12 bg-white/10"></div>
                            <div class="space-y-xs">
                                <div class="flex items-center gap-xs">
                                    <span class="text-3xl font-black text-white">4.9</span>
                                    <span class="material-symbols-outlined text-secondary text-[24px]"
                                        style="font-variation-settings: 'FILL' 1;">star</span>
                                </div>
                                <div class="text-white/50 text-[11px] font-bold uppercase tracking-widest">Đánh giá
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Dynamic Slider Widget -->
                    <div class="lg:col-span-5 relative lg:block hidden">
                        <div
                            class="glass-premium rounded-3xl overflow-hidden border border-white/10 shadow-2xl group min-h-[480px] flex flex-col">
                            <div class="carousel-container flex-1">
                                <div class="carousel-track" id="hero-carousel" style="transform: translateX(-200%);">
                                    <!-- Slide 1: Featured Courses -->
                                    <div class="carousel-slide p-xl">
                                        <div class="flex justify-between items-center mb-lg">
                                            <span
                                                class="px-sm py-1 bg-primary-fixed/20 text-primary-fixed rounded-lg text-[10px] font-black uppercase tracking-widest">Khóa
                                                Học Nổi Bật</span>
                                            <div class="flex gap-2">
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="prevSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_left</span></button>
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="nextSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_right</span></button>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-2 gap-md">
                                            <div class="space-y-sm">
                                                <img alt="Toán học"
                                                    class="w-full aspect-video object-cover rounded-xl border border-white/10"
                                                    src="https://lh3.googleusercontent.com/aida/AP1WRLvyT0OzP4-v-AbSjxn3UQjX5AKor7Y-XvNTsVFcCklUx0W72_TtUeWoKEGfaiqNyk1pO3_-rA0gjk9dEyLm7e_mlMmD08ouPWS17QWtg2EqPqcF8mrUafkdcP_bn4QdKITC7cm96juhZBUYQ-fqWQh_IlLXuynnbpwG0r70jvD24G401Rf8ibsdH4xnkmAGAz_oP99QgzyaIVA5MvqbhxpsID_8SeykfopkLz_stQ68xE836MUrFBOLWHPe">
                                                <p class="text-white font-bold text-sm">Toán Tư Duy Pro</p>
                                            </div>
                                            <div class="space-y-sm">
                                                <img alt="Vật lý"
                                                    class="w-full aspect-video object-cover rounded-xl border border-white/10"
                                                    src="https://lh3.googleusercontent.com/aida/AP1WRLt1a9QDM26OjuQpzhzgGend-U7pR-nHyrmrE53RIf-77t019C3zX6mE4yIioibFsNlsgvwqclzE0o8uKUVqr63rhRf1anXWhrXyBZ6RE_eIWsyLLTD_OHJ9DPSQTopkttEvW_dj7ptqhF0kjjMlMLUXuw0ng1jaQ78W0-fCRE-ujj0Zr2PImXPO8huIgUkE0JJtN97PzR_2IRjcyu_YMpbW8Cn6vQEOVCly5AzFWeWILhcf9J4mRMEFTyJT">
                                                <p class="text-white font-bold text-sm">Vật Lý 4.0</p>
                                            </div>
                                        </div>
                                        <div class="mt-xl p-lg bg-white/5 rounded-2xl border border-white/10">
                                            <p class="text-white/70 text-sm italic font-light leading-relaxed">
                                                "Chương trình học bám sát cấu trúc đề thi mới nhất, tích hợp công nghệ
                                                AI cá nhân hóa."
                                            </p>
                                        </div>
                                    </div>
                                    <!-- Slide 2: Top Teachers -->
                                    <div class="carousel-slide p-xl">
                                        <div class="flex justify-between items-center mb-lg">
                                            <span
                                                class="px-sm py-1 bg-secondary/20 text-secondary-fixed rounded-lg text-[10px] font-black uppercase tracking-widest">Đội
                                                Ngũ Giảng Viên</span>
                                            <div class="flex gap-2">
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="prevSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_left</span></button>
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="nextSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_right</span></button>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-lg mb-lg">
                                            <div
                                                class="w-20 h-20 rounded-full border-2 border-primary-fixed overflow-hidden">
                                                <img alt="Teacher" class="w-full h-full object-cover"
                                                    src="https://lh3.googleusercontent.com/aida/AP1WRLv6m4Vv03oH9ABy8yE8pW4K8o8U-1J5N9k-XN4U9I6Y7L8T9J5M">
                                            </div>
                                            <div>
                                                <h4 class="text-white font-black text-xl">Thầy Nguyễn Văn A</h4>
                                                <p class="text-primary-fixed text-xs font-bold uppercase">Chuyên gia
                                                    Toán học (15 năm kinh nghiệm)</p>
                                            </div>
                                        </div>
                                        <div class="space-y-md">
                                            <div class="flex items-center gap-md text-white/70 text-sm">
                                                <span
                                                    class="material-symbols-outlined text-primary-fixed">verified</span>
                                                Cựu giảng viên trường chuyên danh tiếng
                                            </div>
                                            <div class="flex items-center gap-md text-white/70 text-sm">
                                                <span class="material-symbols-outlined text-primary-fixed">school</span>
                                                Đào tạo hơn 1000+ học sinh đạt điểm 9+
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Slide 3: Center Info -->
                                    <div class="carousel-slide p-xl">
                                        <div class="flex justify-between items-center mb-lg">
                                            <span
                                                class="px-sm py-1 bg-green-500/20 text-green-400 rounded-lg text-[10px] font-black uppercase tracking-widest">Về
                                                Trung Tâm</span>
                                            <div class="flex gap-2">
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="prevSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_left</span></button>
                                                <button
                                                    class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all"
                                                    onclick="nextSlide()"><span
                                                        class="material-symbols-outlined text-white text-sm">chevron_right</span></button>
                                            </div>
                                        </div>
                                        <h3 class="text-white text-3xl font-black mb-md">Môi Trường Học Tập Đẳng Cấp
                                        </h3>
                                        <p class="text-white/60 leading-relaxed mb-lg">
                                            AcademiaPro tự hào là đơn vị tiên phong ứng dụng Hybrid Learning (Kết hợp
                                            trực tiếp &amp; trực tuyến) cùng hệ thống quản lý học tập thông minh.
                                        </p>
                                        <div class="grid grid-cols-3 gap-sm">
                                            <div class="bg-white/5 p-sm rounded-xl text-center border border-white/10">
                                                <span
                                                    class="material-symbols-outlined text-primary-fixed mb-1">wifi</span>
                                                <p class="text-[10px] text-white/50 font-bold uppercase">Phòng Lab</p>
                                            </div>
                                            <div class="bg-white/5 p-sm rounded-xl text-center border border-white/10">
                                                <span
                                                    class="material-symbols-outlined text-primary-fixed mb-1">auto_awesome</span>
                                                <p class="text-[10px] text-white/50 font-bold uppercase">AI Support</p>
                                            </div>
                                            <div class="bg-white/5 p-sm rounded-xl text-center border border-white/10">
                                                <span
                                                    class="material-symbols-outlined text-primary-fixed mb-1">coffee</span>
                                                <p class="text-[10px] text-white/50 font-bold uppercase">Lounge</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="p-xl bg-gradient-to-t from-black/20 to-transparent">
                                <button
                                    class="w-full bg-primary-fixed text-on-primary-fixed py-4 rounded-2xl font-black text-sm flex items-center justify-center gap-sm shadow-xl hover:bg-white transition-all">
                                    <span class="material-symbols-outlined text-[20px]">explore</span>
                                    Tìm hiểu chi tiết ngay
                                </button>
                            </div>
                        </div>
                        <!-- Floating Badge -->
                        <div
                            class="absolute -bottom-6 -left-12 glass-premium px-lg py-md rounded-2xl border border-white/10 shadow-2xl flex items-center gap-md z-20">
                            <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center shadow-lg">
                                <span class="material-symbols-outlined text-white text-[20px]">trending_up</span>
                            </div>
                            <div>
                                <div class="text-white font-black text-lg">+15%</div>
                                <div class="text-white/50 text-[10px] font-bold uppercase">Hiệu suất học tập</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Scroll Indicator -->
            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-sm">
                <span class="text-white/30 text-[10px] font-bold uppercase tracking-widest">Khám phá</span>
                <div class="w-[1px] h-12 bg-gradient-to-b from-white/30 to-transparent"></div>
            </div>
        </section>
        <!-- Featured Courses Section -->
        <section class="py-32 light-texture-bg relative overflow-hidden">
            <div class="max-w-7xl mx-auto px-margin-mobile lg:px-xl relative z-10">
                <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-lg">
                    <div class="space-y-md">
                        <div class="flex items-center gap-sm text-primary">
                            <span class="w-12 h-[2px] bg-primary"></span>
                            <span class="text-[11px] font-black uppercase tracking-[0.3em]">Hệ sinh thái tri thức</span>
                        </div>
                        <h2 class="text-5xl font-black text-on-surface leading-tight">Khám Phá Khóa Học</h2>
                    </div>
                    <p class="text-on-surface-variant max-w-sm text-lg leading-relaxed font-medium">Chọn khóa học phù
                        hợp để bắt đầu hành trình học tập thông minh cùng các giáo viên xuất sắc nhất.</p>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-xl">
                    <% if (courses && courses.length > 0) { %>
                    <% courses.slice(0, 4).forEach(function(course) { %>
                    <div class="bg-white rounded-3xl overflow-hidden shadow-2xl shadow-primary/5 hover-lift group border border-surface-container flex flex-col">
                        <div class="relative aspect-[4/3] overflow-hidden bg-primary/10">
                            <% const imgUrl = course.ImageUrl || course.ThumbnailUrl || ''; %>
                            <% if (imgUrl) { %>
                            <img alt="<%= course.Title || course.CourseName %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="<%= imgUrl %>"/>
                            <% } else { %>
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5">
                                <span class="material-symbols-outlined text-[80px] text-primary/40">school</span>
                            </div>
                            <% } %>
                            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/60 to-transparent"></div>
                            <span class="absolute top-md right-md bg-primary text-white text-[10px] font-black uppercase px-sm py-xs rounded-lg shadow-xl"><%= course.CourseCode || 'ACTIVE' %></span>
                        </div>
                        <div class="p-lg space-y-lg flex-1 flex flex-col">
                            <h4 class="font-black text-xl text-on-surface group-hover:text-primary transition-colors line-clamp-1"><%= course.CourseName %></h4>
                            <div class="flex items-center justify-between text-on-surface-variant text-[13px] font-bold">
                                <div class="flex items-center gap-sm"><span class="material-symbols-outlined text-[18px]">school</span> <%= course.Grade || 'Mọi cấp lớp' %></div>
                                <div class="flex items-center gap-xs"><span class="material-symbols-outlined text-[18px] text-yellow-500" style="font-variation-settings: 'FILL' 1;">star</span> 4.9</div>
                            </div>
                            <div class="flex justify-between items-center pt-lg border-t border-outline-variant/30 mt-auto">
                                <div>
                                    <span class="text-on-surface-variant text-[10px] uppercase font-bold">Học phí</span>
                                    <% if (course.Price && course.Price > 0) { %>
                                    <div class="text-primary font-black text-2xl"><%= Number(course.Price).toLocaleString('vi-VN') %> đ</div>
                                    <% } else { %>
                                    <div class="text-primary font-black text-2xl">Miễn phí</div>
                                    <% } %>
                                </div>
                                <a href="/Auth/Checkout?courseId=<%= course.Id || course.CourseId %>" class="w-12 h-12 rounded-2xl bg-surface-container flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all shadow-sm">
                                    <span class="material-symbols-outlined">arrow_forward</span>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %>
                    <!-- Fallback static cards when no DB data -->
