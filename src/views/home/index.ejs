<!DOCTYPE html>

<html class="scroll-smooth" lang="vi">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;family=Source+Serif+4:wght@600;700&amp;family=Inter:wght@400;700;800&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#1e3a8a", // Deeper Edu Blue (Blue 900)
                        "on-primary": "#ffffff",
                        "primary-container": "#dbeafe",
                        "on-primary-container": "#172554",
                        "secondary": "#2563eb", // More saturated Blue 600
                        "surface": "#fdfbf7",
                        "on-surface": "#0b1120",
                        "surface-variant": "#f6f4eb",
                        "on-surface-variant": "#334155",
                        "outline": "#94a3b8",
                        "background": "#fdfbf7",
                        "on-background": "#0b1120",
                        "surface-container-low": "#faf8f0",
                        "surface-container": "#f6f4eb",
                        "surface-container-high": "#f0eee2",
                        "surface-container-highest": "#eae8d8",
                        "surface-container-lowest": "#ffffff",
                        "outline-variant": "#cbd5e1",
                        "vibrant-blue": "#1d4ed8", // Darker Blue 700
                        "vibrant-sky": "#0369a1" // Darker Sky 800
                    },
                    "borderRadius": {
                        "DEFAULT": "0.5rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "max-width": "1280px",
                        "gutter": "24px",
                        "margin-mobile": "16px",
                        "margin-desktop": "64px",
                        "base": "8px"
                    },
                    "fontFamily": {
                        "sans": ["Inter", "Manrope", "sans-serif"],
                        "serif": ["Source Serif 4", "serif"]
                    }
                }
            }
        }
    </script>
    <style>
        .glass-premium {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 8px 32px 0 rgba(30, 58, 138, 0.08);
        }

        .blended-gradient {
            background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
            /* Original deep blue gradient */
        }

        .hero-blended-bg {
            background-image: radial-gradient(circle at 70% 30%, rgba(30, 58, 138, 0.2) 0%, transparent 70%),
                linear-gradient(135deg, rgba(30, 58, 138, 0.1) 0%, rgba(23, 37, 84, 0.1) 100%);
            background-size: cover;
            background-position: center;
        }

        .hero-premium-bg {
            position: relative;
            background: transparent;
            overflow: hidden;
        }

        .hero-premium-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.58) 0%, rgba(255, 255, 255, 0.25) 100%), 
                              url('/images/ryunosuke-kikuno-uIRtLhPN_nQ-unsplash.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            filter: brightness(0.8); /* Darkened the background image to reduce glare and boost text contrast */
            z-index: 0;
        }

        @media (min-width: 1024px) {
            .hero-premium-bg::before {
                background-image: linear-gradient(90deg, rgba(255, 255, 255, 0.58) 0%, rgba(255, 255, 255, 0.3) 45%, rgba(255, 255, 255, 0.03) 100%), 
                                  url('/images/ryunosuke-kikuno-uIRtLhPN_nQ-unsplash.jpg');
            }
        }

        .hero-premium-bg h1 {
            color: #000000 !important; /* Deepest black for title */
            font-weight: 900 !important;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 4px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg h1 span {
            color: #1e3a8a !important; /* Solid deep blue */
            font-weight: 900 !important;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 4px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg p {
            color: #000000 !important; /* Solid black for paragraph texts */
            font-weight: 700 !important; /* Thicker bold weight (3 levels up from 450) */
            font-style: normal !important;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 3px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg .text-on-surface-variant {
            color: #000000 !important; /* Solid black for teacher details and slider descriptions */
            font-weight: 700 !important; /* Bolder weight (3 levels up from 500) */
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 3px rgba(255, 255, 255, 0.6) !important;
        }
        .hero-premium-bg .text-3xl {
            color: #000000 !important; /* Deep black for numbers */
            font-weight: 900 !important;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 3px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg .text-on-surface-variant\/60 {
            color: #000000 !important; /* Solid black for stats labels */
            font-weight: 800 !important; /* Extra-bold weight (3 levels up from 500) */
            font-style: normal !important;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 3px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg .carousel-track {
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.95), 0 0 3px rgba(255, 255, 255, 0.6);
        }
        .hero-premium-bg .bg-white\/20, .hero-premium-bg .bg-white\/10, .hero-premium-bg .bg-white\/15, .hero-premium-bg .bg-white\/35, .hero-premium-bg .bg-white\/40, .hero-premium-bg .bg-white\/45 {
            background-color: rgba(255, 247, 230, 0.16) !important; /* Soft warm ivory #FFF7E6, made even more transparent (trong chút nữa) at 16% opacity */
            border-color: rgba(255, 255, 255, 0.15) !important; /* Thin white outline */
            backdrop-filter: blur(14px) !important; /* Soften bookshelves behind cards */
            -webkit-backdrop-filter: blur(14px) !important;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4) !important; /* Dark text shadow for white text */
        }
        /* Style text and icons inside white glass cards to white/light slate for high readability */
        .hero-premium-bg .bg-white\/20 *, .hero-premium-bg .bg-white\/10 *, .hero-premium-bg .bg-white\/15 *, .hero-premium-bg .bg-white\/35 *, .hero-premium-bg .bg-white\/40 *, .hero-premium-bg .bg-white\/45 * {
            color: #ffffff !important; /* White color for headings and text */
            font-weight: 700 !important;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4) !important;
        }
        .hero-premium-bg .bg-white\/20 p, .hero-premium-bg .bg-white\/10 p, .hero-premium-bg .bg-white\/15 p, .hero-premium-bg .bg-white\/35 p, .hero-premium-bg .bg-white\/40 p, .hero-premium-bg .bg-white\/45 p,
        .hero-premium-bg .bg-white\/20 .text-on-surface-variant, .hero-premium-bg .bg-white\/10 .text-on-surface-variant, .hero-premium-bg .bg-white\/15 .text-on-surface-variant, 
        .hero-premium-bg .bg-white\/35 .text-on-surface-variant, .hero-premium-bg .bg-white\/40 .text-on-surface-variant, .hero-premium-bg .bg-white\/45 .text-on-surface-variant {
            color: #f3f4f6 !important; /* Light gray-100 for descriptive texts */
            font-weight: 600 !important; /* Bolder weight for readability */
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4) !important;
        }
        .hero-premium-bg .bg-white\/40 .text-primary, .hero-premium-bg .bg-white\/45 .text-vibrant-sky, .hero-premium-bg .bg-white\/45 .text-primary {
            color: #fde68a !important; /* Warm golden light for highlights inside cards */
            font-weight: 800 !important;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4) !important;
        }
        .hero-premium-bg .bg-white\/35 button, .hero-premium-bg .bg-white\/40 button, .hero-premium-bg .bg-white\/45 button {
            border-color: rgba(255, 255, 255, 0.25) !important;
        }
        .hero-premium-bg .grid-cols-3 div {
            background-color: rgba(255, 255, 255, 0.08) !important;
            border-color: rgba(255, 255, 255, 0.15) !important;
        }
        .hero-premium-bg .grid-cols-3 p {
            color: #fde68a !important; /* Warm golden light for slider pills */
            font-weight: 800 !important;
            font-style: normal !important;
            text-shadow: none !important;
        }

        .platinum-white-gradient {
            background: linear-gradient(180deg, #f1f5f9 0%, #ffffff 100%);
        }

        .text-gradient {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-shadow {
            box-shadow: 0 20px 40px -15px rgba(30, 58, 138, 0.15);
        }

        .hover-lift {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .hover-lift:hover {
            transform: translateY(-8px);
        }

        .carousel-track {
            display: flex;
            transition: transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
        }

        @keyframes shake {

            0%,
            100% {
                transform: rotate(0);
            }

            25% {
                transform: rotate(-10deg);
            }

            75% {
                transform: rotate(10deg);
            }
        }

        .contact-shake:hover .material-symbols-outlined {
            animation: shake 0.3s infinite;
        }
    </style>
</head>

<body
    class="antialiased font-sans selection:bg-primary-container selection:text-on-primary-container bg-surface text-on-surface">
    <%- include('../partials/home-navbar', { activePage: 'home' , isLoggedIn: isLoggedIn, currentUserFullName:
        currentUserFullName, currentUserRole: currentUserRole }) %>

        <main>
            <!-- Hero Section -->
            <section class="min-h-screen relative flex items-center pt-24 overflow-hidden hero-premium-bg">
                <div class="max-w-7xl mx-auto px-6 lg:px-margin-desktop relative z-10 w-full">
                    <div class="grid lg:grid-cols-12 gap-12 items-center">
                        <div class="lg:col-span-7 space-y-6">
                            <div
                                class="inline-flex items-center gap-2 bg-primary/10 border border-primary/20 px-4 py-2 rounded-full">
                                <span class="material-symbols-outlined text-[18px] text-primary">auto_awesome</span>
                                <span class="text-[10px] font-black tracking-[0.25em] text-primary uppercase">Công nghệ
                                    AI
                                    thế hệ mới</span>
                            </div>
                            <h1
                                class="text-on-surface text-5xl md:text-7xl leading-[1.05] font-black tracking-tight font-serif">
                                Nâng Tầm Tri Thức <br />
                                <span class="text-primary">Đột Phá Bản Thân</span>
                            </h1>
                            <p class="text-on-surface-variant text-lg md:text-xl max-w-2xl leading-relaxed font-normal">
                                Học trực tuyến hiệu quả cao với lộ trình cá nhân hóa. Đội ngũ giáo viên chuyên môn giỏi
                                kết
                                hợp trợ lý AI thông minh đồng hành cùng học viên 24/7 để bứt phá điểm số.
                            </p>
                            <div class="flex flex-wrap gap-4 pt-4">
                                <button
                                    class="blended-gradient text-white px-8 py-4 rounded-full font-black text-sm shadow-xl hover:brightness-110 transition-all hover:scale-105 active:scale-95 flex items-center gap-2 group"
                                    onclick="location.href='/Auth/Register'">
                                    Đăng Ký Học Thử Ngay
                                    <span
                                        class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                                </button>
                                <button
                                    class="bg-white/30 backdrop-blur-md border border-white/60 text-on-surface px-8 py-4 rounded-full font-black text-sm hover:bg-white/50 transition-all flex items-center gap-2 shadow-md"
                                    onclick="window.location.href='/Home/Courses'">
                                    Xem Khóa Học
                                </button>
                            </div>
                            <!-- Stats -->
                            <div class="flex items-center gap-12 pt-16 border-t border-outline-variant/30">
                                <div class="space-y-1">
                                    <div class="text-3xl font-black text-on-surface">5,000+</div>
                                    <div
                                        class="text-on-surface-variant/60 text-[10px] font-bold uppercase tracking-widest">
                                        Học sinh</div>
                                </div>
                                <div class="w-px h-10 bg-outline-variant/30"></div>
                                <div class="space-y-1">
                                    <div class="text-3xl font-black text-on-surface">98%</div>
                                    <div
                                        class="text-on-surface-variant/60 text-[10px] font-bold uppercase tracking-widest">
                                        Đột phá điểm</div>
                                </div>
                                <div class="w-px h-10 bg-outline-variant/30"></div>
                                <div class="space-y-1">
                                    <div class="flex items-center gap-1">
                                        <span class="text-3xl font-black text-on-surface">4.9</span>
                                        <span class="material-symbols-outlined text-vibrant-sky text-[24px]"
                                            style="font-variation-settings: 'FILL' 1;">star</span>
                                    </div>
                                    <div
                                        class="text-on-surface-variant/60 text-[10px] font-bold uppercase tracking-widest">
                                        Đánh giá</div>
                                </div>
                            </div>
                        </div>
                        <!-- Dynamic Slider Widget -->
                        <div class="lg:col-span-5 relative lg:block hidden">
                            <div
                                class="bg-white/35 backdrop-blur-xl rounded-3xl overflow-hidden shadow-2xl border border-white/40 group min-h-[480px] flex flex-col">
                                <div class="relative overflow-hidden flex-1">
                                    <div class="carousel-track h-full" id="hero-carousel">
                                        <!-- Slide 1: Featured Courses -->
                                        <div class="min-w-full p-8 flex flex-col" data-slide-url="/Home/Courses" data-slide-label="Xem tất cả khóa học">
                                            <div class="flex justify-between items-center mb-8">
                                                <span
                                                    class="px-3 py-1 bg-primary/10 text-primary rounded-lg text-[10px] font-black uppercase tracking-widest">Khóa
                                                    Học Nổi Bật</span>
                                                <div class="flex gap-2">
                                                    <button
                                                        class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-all"
                                                        onclick="prevSlide()"><span
                                                            class="material-symbols-outlined text-on-surface-variant text-sm">chevron_left</span></button>
                                                    <button
                                                        class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-all"
                                                        onclick="nextSlide()"><span
                                                            class="material-symbols-outlined text-on-surface-variant text-sm">chevron_right</span></button>
                                                </div>
                                            </div>
                                            <div class="grid grid-cols-2 gap-4">
                                                <div class="space-y-2">
                                                    <img alt="Toán học"
                                                        class="w-full aspect-video object-cover rounded-xl border border-outline-variant/30"
                                                        src="https://lh3.googleusercontent.com/aida/AP1WRLvyT0OzP4-v-AbSjxn3UQjX5AKor7Y-XvNTsVFcCklUx0W72_TtUeWoKEGfaiqNyk1pO3_-rA0gjk9dEyLm7e_mlMmD08ouPWS17QWtg2EqPqcF8mrUafkdcP_bn4QdKITC7cm96juhZBUYQ-fqWQh_IlLXuynnbpwG0r70jvD24G401Rf8ibsdH4xnkmAGAz_oP99QgzyaIVA5MvqbhxpsID_8SeykfopkLz_stQ68xE836MUrFBOLWHPe" />
                                                    <p class="text-on-surface font-bold text-xs">Toán Tư Duy Pro</p>
                                                </div>
                                                <div class="space-y-2">
                                                    <img alt="Vật lý"
                                                        class="w-full aspect-video object-cover rounded-xl border border-outline-variant/30"
                                                        src="https://lh3.googleusercontent.com/aida/AP1WRLt1a9QDM26OjuQpzhzgGend-U7pR-nHyrmrE53RIf-77t019C3zX6mE4yIioibFsNlsgvwqclzE0o8uKUVqr63rhRf1anXWhrXyBZ6RE_eIWsyLLTD_OHJ9DPSQTopkttEvW_dj7ptqhF0kjjMlMLUXuw0ng1jaQ78W0-fCRE-ujj0Zr2PImXPO8huIgUkE0JJtN97PzR_2IRjcyu_YMpbW8Cn6vQEOVCly5AzFWeWILhcf9J4mRMEFTyJT" />
                                                    <p class="text-on-surface font-bold text-xs">Vật Lý 4.0</p>
                                                </div>
                                            </div>
                                            <div class="mt-auto p-6 bg-primary/5 rounded-2xl border border-primary/10">
                                                <p
                                                    class="text-on-surface-variant text-sm italic font-light leading-relaxed">
                                                    "Chương trình học bám sát cấu trúc đề thi mới nhất, tích hợp công
                                                    nghệ
                                                    AI cá nhân hóa."
                                                </p>
                                            </div>
                                        </div>
                                        <!-- Slide 2: Top Teachers (Dynamic) -->
                                        <% if (typeof teachers !=='undefined' && teachers && teachers.length> 0) { %>
                                            <% teachers.forEach(t=> { %>
                                                <% const profile=t.Profile || {}; %>
                                                    <% const avatarUrl=t.AvatarUrl
                                                        || 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=256&auto=format&fit=crop'
                                                        ; %>
                                                        <div class="min-w-full p-8 cursor-pointer hover:bg-surface-container/50 transition-colors" data-slide-url="/Home/Teachers" data-slide-label="Xem tất cả giảng viên"
                                                            onclick="openTeacherDetailModal({
                                                     fullName: '<%= (t.FullName||'').replace(/'/g, " \\'") %>',
                                                            avatarUrl: '<%= avatarUrl %>',
                                                                subject: '<%= (profile.Subject || 'Toán học'
                                                                    ).replace(/'/g, "\\'" ) %>',
                                                                    title: '<%= (profile.TeacherTitle
                                                                        || 'Giáo viên tiêu biểu' ).replace(/'/g, "\\'" )
                                                                        %>',
                                                                        experience: '<%= profile.TeacherExperience
                                                                            !==null ? profile.TeacherExperience : 5 %>',
                                                                            students: '<%= profile.TeacherStudents
                                                                                !==null ? profile.TeacherStudents : 100
                                                                                %>',
                                                                                rating: '<%= profile.TeacherRating
                                                                                    !==null ?
                                                                                    parseFloat(profile.TeacherRating).toFixed(1)
                                                                                    : '4.8' %>',
                                                                                    bio: `<%= (profile.TeacherBio
                                                                                        || 'Giảng viên giàu kinh nghiệm ôn luyện và bồi dưỡng kiến thức toàn diện cho các em học viên.'
                                                                                        ).replace(/`/g, '\\`'
                                                                                        ).replace(/\$/g, '\\$' ) %>`
                                                                                        })">
                                                                                        <div
                                                                                            class="flex justify-between items-center mb-8">
                                                                                            <span
                                                                                                class="px-3 py-1 bg-vibrant-sky/10 text-vibrant-sky rounded-lg text-[10px] font-black uppercase tracking-widest">Đội
                                                                                                Ngũ Giảng Viên</span>
                                                                                            <div class="flex gap-2">
                                                                                                <button
                                                                                                    class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-all"
                                                                                                    onclick="event.stopPropagation(); prevSlide()"><span
                                                                                                        class="material-symbols-outlined text-on-surface-variant text-sm">chevron_left</span></button>
                                                                                                <button
                                                                                                    class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-all"
                                                                                                    onclick="event.stopPropagation(); nextSlide()"><span
                                                                                                        class="material-symbols-outlined text-on-surface-variant text-sm">chevron_right</span></button>
                                                                                            </div>
                                                                                        </div>
                                                                                        <div
                                                                                            class="flex items-center gap-6 mb-6">
                                                                                            <div
                                                                                                class="w-20 h-20 rounded-full border-2 border-vibrant-sky overflow-hidden bg-white shadow-sm flex-shrink-0">
                                                                                                <img alt="<%= t.FullName %>"
                                                                                                    class="w-full h-full object-cover"
                                                                                                    src="<%= avatarUrl %>" />
                                                                                            </div>
                                                                                            <div>
                                                                                                <h4
                                                                                                    class="text-on-surface font-black text-xl">
                                                                                                    <%= t.FullName %>
                                                                                                </h4>
                                                                                                <p
                                                                                                    class="text-vibrant-sky text-xs font-bold uppercase">
                                                                                                    <%= profile.TeacherTitle
                                                                                                        || 'Giáo viên tiêu biểu tại trung tâm'
                                                                                                        %> (<%=
                                                                                                            profile.Subject
                                                                                                            || 'Toán học'
                                                                                                            %>)
                                                                                                </p>
                                                                                            </div>
                                                                                        </div>
                                                                                        <div class="space-y-4">
                                                                                            <div
                                                                                                class="flex items-center gap-4 text-on-surface-variant text-sm font-medium">
                                                                                                <span
                                                                                                    class="material-symbols-outlined text-vibrant-sky">verified</span>
                                                                                                Chuyên môn: <%=
                                                                                                    profile.Subject
                                                                                                    || 'Chưa cập nhật'
                                                                                                    %> (<%=
                                                                                                        profile.TeacherExperience
                                                                                                        !==null ?
                                                                                                        profile.TeacherExperience
                                                                                                        : 5 %> năm kinh
                                                                                                        nghiệm)
                                                                                            </div>
                                                                                            <div
                                                                                                class="flex items-center gap-4 text-on-surface-variant text-sm font-medium">
                                                                                                <span
                                                                                                    class="material-symbols-outlined text-vibrant-sky">school</span>
                                                                                                Lượt đánh giá học viên
                                                                                                đạt <%=
                                                                                                    profile.TeacherRating
                                                                                                    !==null ?
                                                                                                    parseFloat(profile.TeacherRating).toFixed(1)
                                                                                                    : '4.8' %>/5.0 sao
                                                                                            </div>
                                                                                        </div>
                                                        </div>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <!-- Slide 2: Top Teachers (Static fallback) -->
                                                                <div class="min-w-full p-8" data-slide-url="/Home/Teachers" data-slide-label="Xem tất cả giảng viên">
                                                                    <div class="flex justify-between items-center mb-8">
                                                                        <span
                                                                            class="px-3 py-1 bg-vibrant-sky/10 text-vibrant-sky rounded-lg text-[10px] font-black uppercase tracking-widest">Đội
                                                                            Ngũ Giảng Viên</span>
                                                                        <div class="flex gap-2">
                                                                            <button
                                                                                class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-all"
