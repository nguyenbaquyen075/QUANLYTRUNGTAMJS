    <script>
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 50) {
                nav.classList.add('bg-[#00288e]/90', 'backdrop-blur-xl', 'py-4', 'shadow-2xl');
                nav.classList.remove('py-lg');
            } else {
                nav.classList.remove('bg-[#00288e]/90', 'backdrop-blur-xl', 'py-4', 'shadow-2xl');
                nav.classList.add('py-lg');
            }
        });

        // Simple Carousel Logic
        let currentSlide = 0;
        const track = document.getElementById('hero-carousel');
        const slides = track.children.length;

        function updateCarousel() {
            track.style.transform = `translateX(-${currentSlide * 100}%)`;
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides;
            updateCarousel();
        }

        function prevSlide() {
            currentSlide = (currentSlide - 1 + slides) % slides;
            updateCarousel();
        }

        // Auto-play
        setInterval(nextSlide, 5000);
    </script>


