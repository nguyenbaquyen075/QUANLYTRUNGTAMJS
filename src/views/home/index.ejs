                                <span class="material-symbols-outlined text-[32px] text-white">shop</span>
                                <div>
                                    <div
                                        class="text-[9px] uppercase font-black tracking-widest text-white/40">
                                        Get it on</div>
                                    <div class="font-black text-base text-white">Google Play</div>
                                </div>
                            </a>
                            <a class="flex items-center gap-4 bg-white/10 p-4 rounded-2xl hover:bg-white/20 transition-all border border-white/20"
                                href="#">
                                <span class="material-symbols-outlined text-[32px] text-white">phone_iphone</span>
                                <div>
                                    <div
                                        class="text-[9px] uppercase font-black tracking-widest text-white/40">
                                        Available on</div>
                                    <div class="font-black text-base text-white">App Store</div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
                <div
                    class="pt-4 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-3">
                    <p class="text-white/30 text-[10px] font-bold uppercase tracking-widest">© 2024
                        ACADEMIAPRO. ALL RIGHTS RESERVED.</p>
                    <div class="flex gap-12">
                        <a class="text-white/30 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors"
                            href="/Home/Privacy">Privacy Policy</a>
                        <a class="text-white/30 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors"
                            href="/Home/Privacy">Terms of Service</a>
                    </div>
                </div>
            </div>
        </footer>
        <script>


            // Carousel Logic
            let currentSlide = 0;
            const track = document.getElementById('hero-carousel');
            const slides = track ? track.children.length : 0;

            function updateCarousel() {
                if (track) {
                    track.style.transform = `translateX(-${currentSlide * 100}%)`;
                }
                // Sync CTA button label & URL based on current slide
                const ctaLabel = document.getElementById('hero-cta-label');
                if (ctaLabel && track) {
                    const slideEl = track.children[currentSlide];
                    const label = slideEl ? (slideEl.getAttribute('data-slide-label') || 'Tìm hiểu chi tiết ngay') : 'Tìm hiểu chi tiết ngay';
                    ctaLabel.textContent = label;
                }
            }

            function heroCtaClick() {
                if (!track) return;
                const slideEl = track.children[currentSlide];
                const url = slideEl ? (slideEl.getAttribute('data-slide-url') || '/Home/Courses') : '/Home/Courses';
                window.location.href = url;
            }

            function nextSlide() {
                if (slides > 0) {
                    currentSlide = (currentSlide + 1) % slides;
                    updateCarousel();
                }
            }

            function prevSlide() {
                if (slides > 0) {
                    currentSlide = (currentSlide - 1 + slides) % slides;
                    updateCarousel();
                }
            }

            // Auto-play
            setInterval(nextSlide, 6000);
        </script>

        <!-- Teacher Detail Modal -->
        <div id="teacherDetailModal"
            class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] hidden items-center justify-center p-4"
            onclick="handleOutsideClick(event)">
            <div class="bg-white rounded-3xl max-w-6xl w-full overflow-hidden shadow-2xl transform transition-all duration-300 scale-95 opacity-0 flex flex-col md:flex-row relative"
                id="teacherModalContent" onclick="event.stopPropagation()">
                <!-- Close Button -->
                <button onclick="closeTeacherDetailModal()"
                    class="absolute top-6 right-6 text-slate-400 hover:text-slate-600 transition-colors w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center z-10">
                    <span class="material-symbols-outlined text-[24px] font-bold">close</span>
                </button>

                <!-- Left Side: Profile Intro -->
                <div
                    class="md:w-[30%] bg-surface-container-low p-12 border-b md:border-b-0 md:border-r border-slate-100 flex flex-col items-center justify-center text-center">
                    <div
                        class="w-48 h-48 rounded-full border-4 border-primary/10 overflow-hidden bg-white shadow-md mb-6">
                        <img id="modalTeacherAvatar" class="w-full h-full object-cover" src="" alt="Teacher Avatar" />
                    </div>
                    <span id="modalTeacherSubject"
                        class="bg-primary text-white text-xs font-bold px-4 py-1 rounded-full shadow-sm mb-4"></span>
                    <h3 id="modalTeacherName" class="text-3xl font-extrabold text-primary mb-2 whitespace-nowrap"></h3>
                    <p id="modalTeacherTitle" class="text-sm text-on-surface-variant font-medium mb-10 px-2"></p>

                    <div class="grid grid-cols-3 gap-2 w-full pt-6 border-t border-slate-200">
                        <div class="text-center">
                            <span id="modalTeacherExp" class="block text-2xl font-extrabold text-primary"></span>
                            <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Năm KN</span>
                        </div>
                        <div class="text-center">
                            <span id="modalTeacherStudents" class="block text-2xl font-extrabold text-primary"></span>
                            <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Học sinh</span>
                        </div>
                        <div class="text-center">
                            <span id="modalTeacherRating"
                                class="block text-2xl font-extrabold text-primary flex items-center justify-center gap-0.5"></span>
                            <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Đánh giá</span>
                        </div>
                    </div>
                </div>

                <!-- Right Side: Details / Bio -->
                <div class="md:w-[70%] p-12 flex flex-col justify-between">
                    <div class="flex-grow">
                        <h4 class="text-base font-black text-primary uppercase tracking-wider mb-6"><i
                                class="fa-solid fa-graduation-cap"></i> Tiểu sử & Kinh nghiệm giảng dạy</h4>
                        <div class="overflow-y-auto max-h-[500px] pr-4 text-justify">
                            <p id="modalTeacherBio"
                                class="text-base text-on-surface-variant leading-relaxed font-medium"
                                style="white-space: pre-line;"></p>
                        </div>
                    </div>
                    <div class="mt-10 pt-6 border-t border-slate-100 flex justify-end">
                        <button onclick="closeTeacherDetailModal()"
                            class="px-8 py-3.5 bg-primary text-white text-base font-bold rounded-xl shadow-lg hover:bg-primary-dark transition-all">
                            Đóng cửa sổ
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            function openTeacherDetailModal(data) {
                document.getElementById('modalTeacherAvatar').src = data.avatarUrl;
                document.getElementById('modalTeacherSubject').textContent = data.subject;
                document.getElementById('modalTeacherName').textContent = data.fullName;
                document.getElementById('modalTeacherTitle').textContent = data.title;
                document.getElementById('modalTeacherExp').textContent = data.experience + '+';
                document.getElementById('modalTeacherStudents').textContent = data.students + '+';
                document.getElementById('modalTeacherRating').innerHTML = data.rating + ' <span class="material-symbols-outlined text-[14px] text-secondary" style="font-variation-settings: \'FILL\' 1; vertical-align: middle;">star</span>';
                document.getElementById('modalTeacherBio').textContent = data.bio;

                const modal = document.getElementById('teacherDetailModal');
                const content = document.getElementById('teacherModalContent');

                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.style.overflow = 'hidden'; // prevent background scrolling
                setTimeout(() => {
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                }, 10);
            }

            function closeTeacherDetailModal() {
                const modal = document.getElementById('teacherDetailModal');
                const content = document.getElementById('teacherModalContent');

                content.classList.remove('scale-100', 'opacity-100');
                content.classList.add('scale-95', 'opacity-0');
                document.body.style.overflow = ''; // restore scrolling
                setTimeout(() => {
                    modal.classList.remove('flex');
                    modal.classList.add('hidden');
                }, 300);
            }

            function handleOutsideClick(event) {
                closeTeacherDetailModal();
            }

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    closeTeacherDetailModal();
                }
            });
        </script>
</body>

</html>
