<% title = "Khóa Học - Chương trình đào tạo trực tuyến"; %>
<!DOCTYPE html>
<html class="scroll-smooth" lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary": "#9d4300",
                        "on-tertiary-fixed": "#001c39",
                        "inverse-surface": "#2d3133",
                        "error-container": "#ffdad6",
                        "on-tertiary": "#ffffff",
                        "on-secondary-fixed-variant": "#783200",
                        "on-secondary": "#ffffff",
                        "inverse-primary": "#b8c4ff",
                        "surface-variant": "#e0e3e5",
                        "surface-container-highest": "#e0e3e5",
                        "on-primary-fixed": "#001453",
                        "outline": "#757684",
                        "surface-container-low": "#f2f4f6",
                        "primary-container": "#1e40af",
                        "background": "#f7f9fb",
                        "surface-container": "#eceef0",
                        "secondary-container": "#fd761a",
                        "on-surface-variant": "#444653",
                        "on-surface": "#191c1e",
                        "tertiary-fixed": "#d4e3ff",
                        "secondary-fixed": "#ffdbca",
                        "on-primary-fixed-variant": "#173bab",
                        "primary": "#00288e",
                        "primary-fixed": "#dde1ff",
                        "on-tertiary-container": "#8fbeff",
                        "surface-tint": "#3755c3",
                        "secondary-fixed-dim": "#ffb690",
                        "surface-bright": "#f7f9fb",
                        "on-error-container": "#93000a",
                        "on-error": "#ffffff",
                        "tertiary-container": "#004c8b",
                        "surface-dim": "#d8dadc",
                        "surface-container-high": "#e6e8ea",
                        "on-secondary-fixed": "#341100",
                        "error": "#ba1a1a",
                        "tertiary-fixed-dim": "#a4c9ff",
                        "on-secondary-container": "#5c2400",
                        "surface": "#f7f9fb",
                        "outline-variant": "#c4c5d5",
                        "on-primary": "#ffffff",
                        "on-primary-container": "#a8b8ff",
                        "on-background": "#191c1e",
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed-dim": "#b8c4ff",
                        "on-tertiary-fixed-variant": "#004883",
                        "inverse-on-surface": "#eff1f3",
                        "tertiary": "#003564"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "md": "16px",
                        "margin-mobile": "20px",
                        "base": "4px",
                        "xs": "4px",
                        "xl": "32px",
                        "sm": "8px",
                        "lg": "24px",
                        "gutter-mobile": "12px"
                    },
                    "fontFamily": {
                        "sans": ["Inter", "sans-serif"]
                    }
                }
            }
        }
    </script>
<style>
        .hover-shake:hover {
            animation: shake 0.5s ease-in-out infinite;
        }
        @keyframes shake {
            0% { transform: rotate(0deg); }
            25% { transform: rotate(5deg); }
            50% { transform: rotate(0deg); }
            75% { transform: rotate(-5deg); }
            100% { transform: rotate(0deg); }
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="antialiased font-sans bg-[#f7f9fb] text-gray-900">
<%- include('../partials/home-navbar', { activePage: 'courses', isLoggedIn: isLoggedIn, currentUserFullName: currentUserFullName, currentUserRole: currentUserRole }) %>
<main class="pt-[64px]">
<!-- Hero Section -->
<%- include('../partials/home-hero', { heroIcon: 'library_books', heroTitle: 'Tất Cả Khóa Học', heroDesc: 'Khám phá chương trình đào tạo đa dạng - được thiết kế bởi đội ngũ giáo viên giỏi nhất.', heroBreadcrumb: 'Khóa Học', heroStats: [] }) %>
<!-- Filters & Search Section -->
<section class="py-12 relative border-b border-surface-container" style="background-image: url('/images/courses-hero-bg.png'); background-size: cover; background-position: center;">
<div class="max-w-7xl mx-auto px-margin-mobile lg:px-xl">
<div class="flex flex-col lg:flex-row justify-between items-center gap-lg">
<!-- Search Bar -->
<div class="w-full lg:max-w-md relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="w-full pl-12 pr-6 py-4 bg-white border border-surface-container rounded-full text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none shadow-sm" id="searchInput" placeholder="Tìm kiếm tên khóa học, môn học..." type="text" oninput="filterCourses()"/>
</div>
<!-- Filter Buttons -->
<div class="flex items-center gap-3 overflow-x-auto pb-2 lg:pb-0 no-scrollbar w-full lg:w-auto" id="filterBtns">
<button class="px-8 py-3 bg-primary text-white rounded-full text-sm font-bold shadow-lg shadow-primary/20 whitespace-nowrap filter-btn active" onclick="setFilter('all', this)">Tất Cả</button>
<button class="px-8 py-3 bg-white border border-surface-container text-on-surface font-bold rounded-full text-sm hover:bg-surface-container transition-colors whitespace-nowrap filter-btn" onclick="setFilter('toán', this)">Toán Học</button>
<button class="px-8 py-3 bg-white border border-surface-container text-on-surface font-bold rounded-full text-sm hover:bg-surface-container transition-colors whitespace-nowrap filter-btn" onclick="setFilter('vật lý', this)">Vật Lý</button>
<button class="px-8 py-3 bg-white border border-surface-container text-on-surface font-bold rounded-full text-sm hover:bg-surface-container transition-colors whitespace-nowrap filter-btn" onclick="setFilter('hóa', this)">Hóa Học</button>
<button class="px-8 py-3 bg-white border border-surface-container text-on-surface font-bold rounded-full text-sm hover:bg-surface-container transition-colors whitespace-nowrap filter-btn" onclick="setFilter('tiếng anh', this)">Tiếng Anh</button>
</div>
</div>
<!-- Course Grid -->
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-xl mt-16" id="courseGrid">
<% if (courses && courses.length > 0) { %>
    <% courses.forEach(function(course) { %>
    <div class="bg-white rounded-3xl overflow-hidden border border-surface-container flex flex-col group hover:shadow-xl transition-all duration-300 course-card" data-name="<%= (course.CourseName || '').toLowerCase() %>">
        <div class="relative aspect-video overflow-hidden bg-primary/10">
            <% const imgUrl = course.ImageUrl || course.ThumbnailUrl || ''; %>
            <% if (imgUrl) { %>
            <img alt="<%= course.Title || course.CourseName %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="<%= imgUrl %>"/>
            <% } else { %>
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5">
                <span class="material-symbols-outlined text-[64px] text-primary/40">school</span>
            </div>
            <% } %>
            <span class="absolute top-4 left-4 bg-primary text-white text-[10px] font-black uppercase px-4 py-1.5 rounded-lg shadow-lg"><%= course.CourseCode || 'KHÓA HỌC' %></span>
        </div>
        <div class="p-xl space-y-md flex-1 flex flex-col">
            <div class="flex items-center justify-between text-on-surface-variant text-[13px] font-medium">
                <div class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px]">school</span> <%= course.Grade || 'Mọi cấp lớp' %></div>
                <div class="flex items-center gap-1"><span class="material-symbols-outlined text-[18px] text-yellow-500" style="font-variation-settings: 'FILL' 1;">star</span> 4.9</div>
            </div>
            <h3 class="text-xl font-black text-on-surface line-clamp-2 min-h-[56px] group-hover:text-primary transition-colors"><%= course.Title || course.CourseName %></h3>
            <p class="text-on-surface-variant text-sm font-medium leading-relaxed line-clamp-3">
                <%= course.Description || 'Chương trình học chất lượng cao được thiết kế bởi đội ngũ giáo viên chuyên nghiệp.' %>
            </p>
            <div class="mt-auto pt-lg border-t border-surface-container flex items-center justify-between">
                <div>
                    <% const displayPrice = course.BasePrice || course.Price || 0; %>
                    <% if (displayPrice > 0) { %>
                    <div class="text-primary font-black text-2xl"><%= Number(displayPrice).toLocaleString('vi-VN') %> đ</div>
                    <% } else { %>
                    <div class="text-primary font-black text-2xl">Miễn phí</div>
                    <% } %>
                </div>
                <a href="/Auth/Checkout?courseId=<%= course.Id || course.CourseId %>" class="bg-primary text-white px-6 py-3 rounded-xl text-sm font-bold flex items-center gap-2 hover:bg-primary/90 transition-all group/btn">
                    Đăng Ký Ngay <span class="material-symbols-outlined text-[18px] group-hover/btn:translate-x-1 transition-transform">arrow_forward</span>
                </a>
            </div>
        </div>
    </div>
    <% }); %>
<% } else { %>
<div class="col-span-3 text-center py-24">
    <span class="material-symbols-outlined text-[72px] text-on-surface-variant/30">school</span>
    <p class="text-on-surface-variant font-bold mt-4 text-lg">Chưa có khóa học nào được mở.</p>
    <p class="text-on-surface-variant text-sm mt-2">Vui lòng quay lại sau!</p>
</div>
<% } %>
</div>
<!-- No results message (shown via JS) -->
<div class="col-span-3 text-center py-24 hidden" id="noResultsMsg">
    <span class="material-symbols-outlined text-[72px] text-on-surface-variant/30">search_off</span>
    <p class="text-on-surface-variant font-bold mt-4 text-lg">Không tìm thấy khóa học phù hợp.</p>
    <p class="text-on-surface-variant text-sm mt-2">Thử từ khóa khác hoặc chọn danh mục khác.</p>
</div>
</div>
</section>
</main>
<!-- Footer -->
<footer class="bg-[#000e31] text-white pt-24 pb-12 relative overflow-hidden">
<div class="max-w-7xl mx-auto px-margin-mobile lg:px-xl relative z-10">
<div class="grid lg:grid-cols-12 gap-16 mb-16">
<div class="lg:col-span-4 space-y-6">
<div class="flex items-center gap-2">
<img alt="Logo" class="h-16 w-auto brightness-0 invert" src="/images/logo.png"/>
<span class="text-white font-black text-xl">AcademiaPro</span>
</div>
<p class="text-white/50 text-sm leading-relaxed max-w-sm">
Nền tảng giáo dục trực tuyến cao cấp, ứng dụng trí tuệ nhân tạo để kiến tạo lộ trình học tập tối ưu cho thế hệ tương lai.
</p>
<div class="flex gap-4">
<a class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary transition-all" href="#"><span class="material-symbols-outlined text-[20px]">public</span></a>
<a class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary transition-all" href="#"><span class="material-symbols-outlined text-[20px]">mail</span></a>
<a class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary transition-all" href="#"><span class="material-symbols-outlined text-[20px]">play_circle</span></a>
</div>
</div>
<div class="lg:col-span-2 space-y-6">
<h4 class="text-sm font-black text-primary-fixed uppercase tracking-widest">Đào tạo</h4>
<ul class="space-y-4 text-white/50 text-sm font-bold">
<li><a class="hover:text-white transition-colors" href="/Home/Courses">Luyện Thi Đại Học</a></li>
<li><a class="hover:text-white transition-colors" href="/Home/Courses">Tiếng Anh IELTS</a></li>
<li><a class="hover:text-white transition-colors" href="/Home/Courses">Toán - Lý - Hóa</a></li>
<li><a class="hover:text-white transition-colors" href="/Home/Courses">Kỹ Năng Mềm AI</a></li>
</ul>
</div>
<div class="lg:col-span-2 space-y-6">
<h4 class="text-sm font-black text-primary-fixed uppercase tracking-widest">Hỗ Trợ</h4>
<ul class="space-y-4 text-white/50 text-sm font-bold">
<li><a class="hover:text-white transition-colors" href="/Home/Privacy">Chính Sách Bảo Mật</a></li>
<li><a class="hover:text-white transition-colors" href="/Home/Privacy">Điều Khoản Sử Dụng</a></li>
<li><a class="hover:text-white transition-colors" href="/Auth/Register">Hướng Dẫn Đăng Ký</a></li>
</ul>
</div>
<div class="lg:col-span-4 space-y-6">
<h4 class="text-sm font-black text-primary-fixed uppercase tracking-widest">Ứng Dụng Di Động</h4>
<div class="flex flex-col gap-4">
<a class="flex items-center gap-4 bg-white/5 p-4 rounded-xl hover:bg-white/10 transition-all border border-white/10" href="#">
<span class="material-symbols-outlined text-[32px] text-primary-fixed">shop</span>
<div>
<div class="text-[9px] uppercase font-black tracking-widest text-white/30">Get it on</div>
<div class="font-black text-base text-white">Google Play</div>
</div>
</a>
<a class="flex items-center gap-4 bg-white/5 p-4 rounded-xl hover:bg-white/10 transition-all border border-white/10" href="#">
<span class="material-symbols-outlined text-[32px] text-primary-fixed">phone_iphone</span>
<div>
<div class="text-[9px] uppercase font-black tracking-widest text-white/30">Available on</div>
<div class="font-black text-base text-white">App Store</div>
</div>
</a>
</div>
</div>
</div>
<div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
<p class="text-white/30 text-[11px] font-bold uppercase tracking-widest">© 2024 ACADEMIAPRO. ALL RIGHTS RESERVED.</p>
<div class="flex gap-8">
<a class="text-white/30 hover:text-white text-[11px] font-bold uppercase tracking-widest transition-colors" href="/Home/Privacy">Privacy Policy</a>
<a class="text-white/30 hover:text-white text-[11px] font-bold uppercase tracking-widest transition-colors" href="/Home/Privacy">Terms of Service</a>
</div>
</div>
</div>
</footer>
<!-- Floating Contact Buttons -->
<div class="fixed bottom-8 right-8 z-[100] flex flex-col gap-4">
<a class="w-16 h-16 bg-[#24ab1f] text-white rounded-full flex items-center justify-center shadow-2xl hover-shake group transition-transform hover:scale-110" href="#" title="Zalo">
<svg class="w-10 h-10 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21.5 12c0 4.418-4.253 8-9.5 8-1.04 0-2.038-.14-2.965-.396L5.5 22l.833-3.333C4.11 17.18 3 14.72 3 12c0-4.418 4.253-8 9.5-8s9.5 3.582 9.5 8zm-4.545-3.182h-4.91v1.136h2.727l-2.727 3.182v1.136h4.91v-1.136h-2.727l2.727-3.182v-1.136zM8.5 8.818h-1.5v5.454h3.5v-1.136H8.5V8.818z"></path></svg>
</a>
<a class="w-16 h-16 bg-secondary text-white rounded-full flex items-center justify-center shadow-2xl hover-shake group transition-transform hover:scale-110" href="tel:0123456789" title="Gọi ngay">
<span class="material-symbols-outlined text-[32px]">call</span>
</a>
</div>
<script>
let currentFilter = 'all';

function setFilter(category, btn) {
    currentFilter = category;
    document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-primary', 'text-white', 'shadow-lg', 'active');
        b.classList.add('bg-white', 'border', 'border-surface-container', 'text-on-surface');
    });
    btn.classList.add('bg-primary', 'text-white', 'shadow-lg', 'active');
    btn.classList.remove('bg-white', 'border', 'border-surface-container', 'text-on-surface');
    filterCourses();
}

function filterCourses() {
    const query = (document.getElementById('searchInput').value || '').toLowerCase();
    const cards = document.querySelectorAll('.course-card');
    let visibleCount = 0;
    cards.forEach(card => {
        const name = card.getAttribute('data-name') || '';
        const matchesSearch = !query || name.includes(query);
        const matchesFilter = currentFilter === 'all' || name.includes(currentFilter);
        if (matchesSearch && matchesFilter) {
            card.style.display = '';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });
    const noResultsMsg = document.getElementById('noResultsMsg');
    if (noResultsMsg) {
        noResultsMsg.classList.toggle('hidden', visibleCount > 0);
    }
}
</script>
</body></html>