                                                        <span class="badge-custom badge-success" style="font-size: 0.75rem; padding: 0.35rem 0.75rem;">Đã hoàn thành</span>
                                                        <strong style="display: block; font-size: 0.9rem; font-weight: 800; color: #10B981; margin-top: 0.25rem;">Điểm: <%= sub && sub.Grade !== null ? Number(sub.Grade).toFixed(1) : '10' %>/10</strong>
                                                    </div>
