            <% } %>
        </div>

        <!-- TAB 6: TIẾN ĐỘ HỌC TẬP -->
        <div id="tab-progress" class="tab-pane">
            <div style="margin-bottom: 2rem;">
                <h2 style="font-size: 1.5rem; font-weight: 800; color: #0F172A; margin: 0;">Tiến Độ & Kết Quả Học Tập</h2>
                <p style="color: #64748B; margin: 0.25rem 0 0 0; font-size: 0.9rem;">Thống kê tổng hợp về điểm GPA, tỷ lệ chuyên cần chuyên nghiệp được trích xuất tự động.</p>
            </div>

            <!-- Stats Overview Grid -->
