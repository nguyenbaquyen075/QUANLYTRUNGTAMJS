                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div>
                        <span style="font-size: 0.75rem; color: #64748B; display: block;">Điểm trung bình (GPA)</span>
                        <strong style="font-size: 1.5rem; color: #0F172A; font-weight: 800;"><%= gpaVal %> / 10</strong>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background: #ECFDF5; color: #10B981;">
                        <i class="fa-solid fa-calendar-check"></i>
                    </div>
