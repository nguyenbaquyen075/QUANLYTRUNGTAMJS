                                                <span style="color: #94A3B8; font-style: italic;">Chờ chấm</span>
                                            <% } %>
                                        </td>
                                        <td style="padding: 0.75rem; color: #475569; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= s.TeacherComment || '' %>">
                                            <%= s.TeacherComment || 'Chưa có nhận xét' %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

    </div> <!-- đóng .student-content-body -->
    </div> <!-- đóng .student-content-container -->
</div> <!-- đóng .student-layout -->

<script>
    function switchDashboardTab(tabId) {
        // Toggle Active menu class
        document.querySelectorAll('.sidebar-item').forEach(btn => {
            if (btn.getAttribute('data-tab') === tabId) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Toggle Active pane
        document.querySelectorAll('.tab-pane').forEach(pane => {
            if (pane.id === `tab-${tabId}`) {
                pane.classList.add('active');
            } else {
                pane.classList.remove('active');
            }
        });
    }

    // Auto navigate to deep linked tabs if hash exists
    window.addEventListener('DOMContentLoaded', () => {
        const hash = window.location.hash.substring(1);
        if (hash && document.getElementById(`tab-${hash}`)) {
            switchDashboardTab(hash);
        }
    });
</script>
