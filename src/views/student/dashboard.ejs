                    <i class="fa-solid fa-clipboard-question" style="font-size: 3rem; color: #94A3B8; margin-bottom: 1rem;"></i>
                    <h4 style="font-weight: 700; color: #0F172A; margin: 0;">Bạn chưa tham gia lớp học nào</h4>
                    <p style="color: #64748B; font-size: 0.85rem; margin-top: 0.5rem;">Hãy đăng ký khóa học để theo dõi bài kiểm tra.</p>
                </div>
            <% } else { %>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <% enrollments.forEach((e, idx) => { %>
                        <% const classQuizzes = quizAssignments.filter(q => q.Lesson && q.Lesson.ClassId === e.ClassId); %>
                        
                        <details class="course-accordion" <%= idx === 0 ? 'open' : '' %>>
                            <summary>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(0, 40, 142, 0.08); color: #00288e; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <i class="fa-solid fa-circle-question"></i>
                                    </div>
                                    <div style="text-align: left;">
