                                    <p style="text-align: center; color: #64748B; font-size: 0.85rem; margin: 1.5rem 0;">Chưa có bài kiểm tra trắc nghiệm nào được giao cho lớp học này.</p>
                                <% } else { %>
                                    <% classQuizzes.forEach(q => { %>
