                                        <div class="homework-item" style="margin-bottom: 0.5rem;">
                                            <div>
                                                <h4 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #1E293B;"><%= q.Title %></h4>
                                                <span class="ai-bubble-badge" style="margin-top: 0.25rem;"><i class="fa-solid fa-robot"></i> Đề chấm tự động bởi AI</span>
