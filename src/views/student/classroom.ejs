<% title = "Phòng Học Trực Tuyến"; %>

<%
    const activeLesson = (typeof lessons !== 'undefined' && lessons) ? lessons.find(l => {
        const today = new Date();
        const lessonDate = new Date(l.LessonDate);
        const isSameDay = today.toDateString() === lessonDate.toDateString();
        return l.Status === 1 || (l.Status === 0 && isSameDay); // IN_PROGRESS = 1, SCHEDULED = 0
    }) : null;

    const formatTime = (t) => {
        if (!t) return '';
        if (typeof t === 'string') return t.substring(0, 5);
        if (typeof t === 'object') {
            const h = (t.hours !== undefined ? t.hours : (t.hour !== undefined ? t.hour : 0)).toString().padStart(2, '0');
            const m = (t.minutes !== undefined ? t.minutes : (t.minute !== undefined ? t.minute : 0)).toString().padStart(2, '0');
            return `${h}:${m}`;
        }
        return String(t);
    };
%>

