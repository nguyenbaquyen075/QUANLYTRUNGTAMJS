<% title = "Làm Bài Tập"; hideHeader = true; hideChatbot = true; %>

<%
    // AssignmentType: 0 = QUIZ (trắc nghiệm), 1 = ESSAY (tự luận), 2 = TRUE_FALSE (Đúng/Sai), 3 = EXAM (Hỗn hợp)
    const assignmentType = typeof assignment !== 'undefined' && assignment ? assignment.AssignmentType : 1;
    const isQuiz = assignmentType === 0;
    const isEssay = assignmentType === 1;
    const isTF = assignmentType === 2;
    const isExam = assignmentType === 3;

    const assignmentTitle = typeof assignment !== 'undefined' && assignment ? assignment.Title : '';
    const assignmentDue = typeof assignment !== 'undefined' && assignment ? new Date(assignment.DueDate).toLocaleString('vi-VN') : '';
    const assignmentId = typeof assignment !== 'undefined' && assignment ? assignment.Id : '';
    const assignmentInstruction = typeof assignment !== 'undefined' && assignment ? assignment.Instruction : '';
    const attachmentUrl = typeof assignment !== 'undefined' && assignment && assignment.AttachmentUrl ? assignment.AttachmentUrl : null;

    let parsedQuizData = [];
    let parsedTFData = [];
    let parsedExamData = { sectionOrder: [], quiz: [], tf: [], essay: [] };
    let quizCount = 0;

    try {
        const raw = typeof assignment !== 'undefined' && assignment && assignment.QuizData ? assignment.QuizData : '[]';
        if (isQuiz) {
            parsedQuizData = typeof raw === 'string' ? JSON.parse(raw) : (Array.isArray(raw) ? raw : []);
            quizCount = parsedQuizData.length;
        } else if (isTF) {
            parsedTFData = typeof raw === 'string' ? JSON.parse(raw) : (Array.isArray(raw) ? raw : []);
        } else if (isExam) {
            parsedExamData = typeof raw === 'string' ? JSON.parse(raw) : raw;
        }
    } catch(e) { 
        console.error("JSON parse error:", e);
    }
%>

