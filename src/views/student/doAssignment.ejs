<script>
    const assignmentId = "<%= assignmentId %>";
    const assignmentType = <%= assignmentType %>;
    const isQuiz = <%= isQuiz ? 'true' : 'false' %>;
    const isTF = <%= isTF ? 'true' : 'false' %>;
    const isExam = <%= isExam ? 'true' : 'false' %>;

    let rawQuizData = [];
    let rawTFData = [];
    let rawExamData = { quiz: [], tf: [], essay: [] };

    try {
        if (isQuiz) {
            rawQuizData = <%- JSON.stringify(parsedQuizData) %>;
        } else if (isTF) {
            rawTFData = <%- JSON.stringify(parsedTFData) %>;
        } else if (isExam) {
            rawExamData = <%- JSON.stringify(parsedExamData) %>;
        }
    } catch(e) {
        console.error("Script parse error:", e);
    }

    let currentQ = 0;
    const answers = new Array(rawQuizData.length).fill(-1); 
    const tfAnswers = new Array(rawTFData.length).fill(null).map(() => ({ a: null, b: null, c: null, d: null }));
    const examAnswers = {
        quiz: new Array((rawExamData.quiz || []).length).fill(-1),
        tf: new Array((rawExamData.tf || []).length).fill(null).map(() => ({ a: null, b: null, c: null, d: null })),
        essay: new Array((rawExamData.essay || []).length).fill('')
    };

    function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = el.scrollHeight + 'px';
    }

    function triggerAutoResizeAll() {
        setTimeout(() => {
            document.querySelectorAll('textarea.auto-resize').forEach(el => {
                autoResize(el);
            });
        }, 100);
    }

    let tabSwitchCount = 0;
    document.addEventListener("visibilitychange", function() {
        if (document.visibilityState === 'hidden' && (isQuiz || isExam || isTF)) {
            tabSwitchCount++;
            if (tabSwitchCount > 3) {
                alert("Bạn đã thoát tab quá 3 lần. Hệ thống tự động nộp bài!");
                submitFormDirect();
            } else {
                alert("Cảnh báo! Bạn đã rời khỏi giao diện làm bài. Lần " + tabSwitchCount + "/3");
            }
        }
    });

    // ===== UNIFIED ONE-AT-A-TIME RENDERER =====
    // Build a flat list of all questions across all types
    let allQuestions = []; // { type: 'quiz'|'tf'|'examTN'|'examDS'|'examTL', data, originalIdx, sectionLabel? }

    if (isQuiz) {
        rawQuizData.forEach((q, i) => allQuestions.push({ type: 'quiz', data: q, originalIdx: i }));
    } else if (isTF) {
        rawTFData.forEach((q, i) => allQuestions.push({ type: 'tf', data: q, originalIdx: i }));
    } else if (isExam) {
        const order = rawExamData.sectionOrder || [];
        let tnIdx = 0, dsIdx = 0, tlIdx = 0;
        order.forEach((sec, sIdx) => {
            const label = ['I','II','III','IV'][sIdx] || (sIdx+1);
            if (sec === 'tn') {
                (rawExamData.quiz || []).forEach((q, i) => allQuestions.push({ type: 'examTN', data: q, originalIdx: tnIdx++, sectionLabel: 'Phần ' + label + ': TRẮC NGHIỆM' }));
            } else if (sec === 'ds') {
                (rawExamData.tf || []).forEach((q, i) => allQuestions.push({ type: 'examDS', data: q, originalIdx: dsIdx++, sectionLabel: 'Phần ' + label + ': ĐÚNG/SAI' }));
            } else if (sec === 'tl') {
                (rawExamData.essay || []).forEach((q, i) => allQuestions.push({ type: 'examTL', data: q, originalIdx: tlIdx++, sectionLabel: 'Phần ' + label + ': TỰ LUẬN' }));
            }
        });
        // Fallback if no sectionOrder
        if (order.length === 0) {
            (rawExamData.quiz || []).forEach((q, i) => allQuestions.push({ type: 'examTN', data: q, originalIdx: i }));
            (rawExamData.tf || []).forEach((q, i) => allQuestions.push({ type: 'examDS', data: q, originalIdx: i }));
            (rawExamData.essay || []).forEach((q, i) => allQuestions.push({ type: 'examTL', data: q, originalIdx: i }));
        }
    }

    const totalQuestions = allQuestions.length;
    // answers tracking per flat index
    const flatAnswers = new Array(totalQuestions).fill(null);

    window.addEventListener('DOMContentLoaded', () => {
        restoreDraft();
        if (isQuiz || isTF || isExam) {
            renderQuestion(0);
            updateNavBar();
            startTimer(2700);
        }
        triggerAutoResizeAll();
    });

    function renderQuestion(idx) {
        if (idx < 0 || idx >= totalQuestions) return;
        const container = document.getElementById('quizContainer');
        if (!container) return;
        const qObj = allQuestions[idx];
        const { type, data, originalIdx, sectionLabel } = qObj;
        currentQ = idx;

        let sectionBadge = '';
        if (sectionLabel) {
            const color = type === 'examTN' ? 'text-blue-800 bg-blue-50' : (type === 'examDS' ? 'text-emerald-800 bg-emerald-50' : 'text-amber-800 bg-amber-50');
            sectionBadge = `<span class="text-xs font-bold px-3 py-1 ${color} rounded-full uppercase mr-2">${sectionLabel}</span>`;
        }

        let html = `<section class="bg-white/80 backdrop-blur-md rounded-xl p-lg soft-shadow border border-outline-variant question-card">
            <div class="flex items-center gap-2 mb-md">
                ${sectionBadge}
                <span class="text-xs font-bold px-3 py-1 bg-surface-container text-on-surface-variant rounded-full uppercase">CÂU ${idx + 1}/${totalQuestions}</span>
            </div>`;

        if (type === 'quiz' || type === 'examTN') {
            const opts = ['A','B','C','D'];
            const curAns = type === 'quiz' ? answers[originalIdx] : examAnswers.quiz[originalIdx];
            const changeFn = type === 'quiz' ? `onAnswerChange(${originalIdx}, this.value)` : `onExamTNChange(${originalIdx}, this.value)`;
            html += `<div class="text-base font-semibold text-on-surface mb-xl whitespace-pre-wrap">${data.question || data.question_text || ''}</div>`;
            html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-md">`;
            opts.forEach((letter, optIdx) => {
                const sel = curAns === optIdx;
                html += `<label class="group flex items-center p-md border ${sel ? 'border-primary bg-primary/5' : 'border-outline-variant'} rounded-xl cursor-pointer transition-all hover:border-primary/50">
                    <input class="hidden" type="radio" name="q_flat_${idx}" value="${optIdx}" onchange="flatAnswerChange(${idx}, ${optIdx})" ${sel ? 'checked' : ''} />
                    <span class="w-10 h-10 flex items-center justify-center rounded-lg ${sel ? 'bg-primary text-white' : 'bg-surface-container group-hover:bg-primary/10'} font-bold transition-all mr-4 shrink-0">${letter}</span>
                    <span class="text-sm font-medium text-on-surface">${data.options ? (data.options[optIdx] || '') : ''}</span>
                </label>`;
            });
            html += `</div>`;
        } else if (type === 'tf' || type === 'examDS') {
            const tfAns = type === 'tf' ? tfAnswers[originalIdx] : examAnswers.tf[originalIdx];
            html += `<div class="text-base font-semibold text-on-surface mb-xl whitespace-pre-wrap">${data.stem || ''}</div>`;
            html += `<div class="space-y-3">`;
            const letters = ['a','b','c','d'];
            (data.items || []).forEach((item, ii) => {
                if (!item) return;
                const curVal = tfAns ? tfAns[letters[ii]] : null;
                const iDung = curVal === 'dung';
                const iSai = curVal === 'sai';
                html += `<div class="flex items-center justify-between p-3 bg-white/80 rounded-xl border border-outline-variant flex-wrap gap-2">
                    <div class="flex items-center gap-3">
                        <span class="w-7 h-7 flex items-center justify-center bg-surface-container text-primary font-bold rounded-full text-xs shrink-0">${letters[ii]}</span>
                        <span class="text-sm font-medium text-on-surface">${item.text || ''}</span>
                    </div>
                    <div class="flex gap-2">
                        <button type="button"
                            class="px-4 py-1.5 rounded-lg text-xs font-bold border transition-all ${iDung ? 'bg-emerald-600 text-white border-emerald-600' : 'border-outline-variant text-on-surface-variant hover:bg-surface-container'}"
                            onclick="flatTFAnswer(${idx}, ${ii}, 'dung')">&#10003; Đúng</button>
                        <button type="button"
                            class="px-4 py-1.5 rounded-lg text-xs font-bold border transition-all ${iSai ? 'bg-rose-600 text-white border-rose-600' : 'border-outline-variant text-on-surface-variant hover:bg-surface-container'}"
                            onclick="flatTFAnswer(${idx}, ${ii}, 'sai')">&#10007; Sai</button>
                    </div>
                </div>`;
            });
            html += `</div>`;
        } else if (type === 'examTL') {
            const essayVal = examAnswers.essay[originalIdx] || '';
            html += `<div class="text-base font-semibold text-on-surface mb-md whitespace-pre-wrap">${data.question_text || ''}</div>`;
            if (data.points) html += `<div class="text-sm text-on-surface-variant mb-lg">(${data.points} điểm)</div>`;
            html += `<div class="border border-outline-variant rounded-xl overflow-hidden focus-within:border-primary transition-all bg-white">
                <textarea class="w-full min-h-[200px] p-4 text-sm resize-none overflow-y-hidden bg-white text-on-surface auto-resize"
                    placeholder="Nhập câu trả lời tự luận..." oninput="flatEssayAnswer(${originalIdx}, this.value); autoResize(this);">${essayVal}</textarea>
            </div>
            <div class="mt-md">
                <label class="flex items-center gap-2 px-4 py-2.5 bg-surface-container text-on-surface font-bold rounded-lg hover:bg-surface-container-high transition-all cursor-pointer text-sm w-fit">
                    <span class="material-symbols-outlined">upload_file</span>
                    <span>Đính kèm file (nếu có)</span>
                    <input type="file" id="fileUploadInput" class="hidden" accept="image/*,.pdf" onchange="uploadFile()" />
                </label>
                <input type="hidden" name="fileUrl" id="essayFile" />
                <p id="uploadStatus" class="text-sm mt-2 text-on-surface-variant">Hãy chọn và tải file lên (nếu có).</p>
            </div>`;
        }

        html += `</section>`;
        container.innerHTML = html;
        container.querySelectorAll('textarea.auto-resize').forEach(el => autoResize(el));

        document.getElementById('btnPrev').disabled = (idx === 0);
        document.getElementById('btnNext').disabled = (idx === totalQuestions - 1);
        const mLabel = document.getElementById('mobileQLabel');
        if (mLabel) mLabel.textContent = `Câu ${idx + 1}/${totalQuestions}`;

        // Update bottom action button
        const btnSubmitOrNext = document.getElementById('btnSubmitOrNext');
        if (btnSubmitOrNext) {
            if (idx === totalQuestions - 1) {
                btnSubmitOrNext.innerHTML = `<span class="material-symbols-outlined text-lg">send</span><span>Nộp Bài</span>`;
                btnSubmitOrNext.className = "flex items-center gap-2 px-4 py-2 bg-primary text-white font-bold rounded-lg shadow-sm hover:bg-primary-container transition-all cursor-pointer";
            } else {
                btnSubmitOrNext.innerHTML = `<span>Tiếp theo</span><span class="material-symbols-outlined text-lg">arrow_forward</span>`;
                btnSubmitOrNext.className = "flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white font-bold rounded-lg shadow-sm hover:bg-emerald-700 transition-all cursor-pointer";
            }
        }

        updateNavBar();
    }

    function handleBottomButtonClick() {
        if (!isQuiz && !isTF && !isExam) {
            submitFormDirect();
        } else if (currentQ === totalQuestions - 1) {
            submitFormDirect();
        } else {
            goNext();
        }
    }

    function submitFormDirect() {
        if (isQuiz || isTF || isExam) {
            // Count unanswered
            let unanswered = 0;
            for (let i = 0; i < totalQuestions; i++) {
                const qObj = allQuestions[i];
                if (qObj.type === 'tf' || qObj.type === 'examDS') {
                    const tfAns = qObj.type === 'tf' ? tfAnswers[qObj.originalIdx] : examAnswers.tf[qObj.originalIdx];
                    let answeredCount = 0;
                    ['a','b','c','d'].forEach(letter => {
                        if (tfAns && tfAns[letter] !== null && tfAns[letter] !== undefined) answeredCount++;
                    });
                    if (answeredCount < 4) unanswered++;
                } else {
                    const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1 && flatAnswers[qi] !== '';
                    if (!getAnswered(i)) unanswered++;
                }
            }
            if (unanswered > 0) {
                if (!confirm('Bạn còn ' + unanswered + ' câu chưa hoàn thành. Bạn có chắc muốn nộp bài?')) return;
            }
            
            // pack content
            let contentToSave = '';
            if (isQuiz) {
                contentToSave = JSON.stringify(answers);
            } else if (isTF) {
                contentToSave = JSON.stringify(tfAnswers);
            } else if (isExam) {
                contentToSave = JSON.stringify(examAnswers);
            }
            document.getElementById('assignmentContentInput').value = contentToSave;
        } else {
            const essayEl = document.getElementById('essayText');
            if (essayEl) {
                document.getElementById('assignmentContentInput').value = essayEl.value;
            }
        }
        localStorage.removeItem('submission_draft_' + assignmentId);
        document.getElementById('assignmentForm').submit();
    }

    function flatAnswerChange(flatIdx, optIdx) {
        const qObj = allQuestions[flatIdx];
        flatAnswers[flatIdx] = optIdx;
        if (qObj.type === 'quiz') answers[qObj.originalIdx] = optIdx;
        else if (qObj.type === 'examTN') examAnswers.quiz[qObj.originalIdx] = optIdx;
        saveDraft();
        updateNavBar();
        renderQuestion(flatIdx);
    }

    function flatTFAnswer(flatIdx, itemIdx, val) {
        const qObj = allQuestions[flatIdx];
        const letters = ['a','b','c','d'];
        if (qObj.type === 'tf') {
            if (!tfAnswers[qObj.originalIdx]) tfAnswers[qObj.originalIdx] = {};
            tfAnswers[qObj.originalIdx][letters[itemIdx]] = val;
        } else {
            if (!examAnswers.tf[qObj.originalIdx]) examAnswers.tf[qObj.originalIdx] = {};
            examAnswers.tf[qObj.originalIdx][letters[itemIdx]] = val;
        }
        flatAnswers[flatIdx] = true; // mark answered
        saveDraft();
        updateNavBar();
        renderQuestion(flatIdx); // re-render to update button styles
    }

    function flatEssayAnswer(originalIdx, val) {
        examAnswers.essay[originalIdx] = val;
        const flatIdx = currentQ;
        flatAnswers[flatIdx] = val;
        saveDraft();
    }

    function onAnswerChange(qIdx, optIdx) { flatAnswerChange(currentQ, parseInt(optIdx)); }
    function onExamTNChange(qIdx, optIdx) { flatAnswerChange(currentQ, parseInt(optIdx)); }

    function goPrev() { if (currentQ > 0) renderQuestion(currentQ - 1); }
    function goNext() { if (currentQ < totalQuestions - 1) renderQuestion(currentQ + 1); }
    function goToQuestion(idx) { renderQuestion(idx); }

    function updateNavBar() {
        const total = totalQuestions;
        const navBar = document.getElementById('questionNavBar');
        if (!navBar || total === 0) return;

        let html = '';
        const MAX_SHOW = 5;
        const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1;

        const mkBtn = (qi) => {
            let cls = qi === currentQ
                ? 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full bg-primary text-white text-xs font-bold cursor-pointer'
                : (getAnswered(qi)
                    ? 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full bg-primary-fixed text-primary border border-primary text-xs font-bold cursor-pointer'
                    : 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant text-xs font-medium cursor-pointer hover:border-primary hover:text-primary');
            return `<button type="button" class="${cls}" onclick="goToQuestion(${qi})">${qi+1}</button>`;
        };

        if (total <= MAX_SHOW + 2) {
            for (let qi = 0; qi < total; qi++) html += mkBtn(qi);
        } else {
            for (let qi = 0; qi < MAX_SHOW; qi++) html += mkBtn(qi);
            html += '<span class="text-on-surface-variant px-1">...</span>';
            html += mkBtn(total - 1);
        }
        navBar.innerHTML = html;

        // Update modal dots
        document.querySelectorAll('.q-modal-dot').forEach(btn => {
            const qi = parseInt(btn.dataset.qidx);
            btn.className = 'q-modal-dot w-full aspect-square flex items-center justify-center rounded-xl text-sm font-bold transition-all border ';
            if (qi === currentQ) btn.className += 'bg-primary text-white border-primary';
            else if (getAnswered(qi)) btn.className += 'bg-primary-fixed text-primary border-primary';
            else btn.className += 'border-outline-variant text-on-surface-variant hover:border-primary';
        });
    }

    function toggleQuestionList() {
        const modal = document.getElementById('questionListModal');
        if (!modal) return;
        modal.classList.toggle('hidden');
        // Rebuild the modal grid with current state
        const grid = document.getElementById('modalQuestionGrid');
        if (grid && !modal.classList.contains('hidden')) {
            const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1;
            grid.innerHTML = allQuestions.map((qObj, qi) => {
                let cls = 'q-modal-dot w-full aspect-square flex items-center justify-center rounded-xl text-sm font-bold transition-all border ';
                if (qi === currentQ) cls += 'bg-primary text-white border-primary';
                else if (getAnswered(qi)) cls += 'bg-primary-fixed text-primary border-primary';
                else cls += 'border-outline-variant text-on-surface-variant hover:border-primary';
                return `<button type="button" class="${cls}" data-qidx="${qi}" onclick="goToQuestion(${qi}); toggleQuestionList();">${qi+1}</button>`;
            }).join('');
        }
        updateNavBar();
    }

    function startTimer(duration) {
        let timer = duration;
        const timerEl = document.getElementById('timerDisplay');
        if (!timerEl) return;
        const interval = setInterval(() => {
            const h = Math.floor(timer / 3600), m = Math.floor((timer % 3600) / 60), s = timer % 60;
            timerEl.textContent = (h > 0 ? (h.toString().padStart(2,'0') + ':') : '') + m.toString().padStart(2,'0') + ':' + s.toString().padStart(2,'0');
            if (timer < 120) timerEl.style.color = '#ba1a1a';
            if (--timer < 0) { clearInterval(interval); alert("Hết thời gian!"); submitFormDirect(); }
        }, 1000);
    }

    function saveDraft() {
        let contentToSave = isQuiz ? JSON.stringify(answers) : (isTF ? JSON.stringify(tfAnswers) : (isExam ? JSON.stringify(examAnswers) : (document.getElementById('essayText') ? document.getElementById('essayText').value : '')));
        localStorage.setItem('submission_draft_' + assignmentId, JSON.stringify({ content: contentToSave, fileUrl: document.getElementById('essayFile') ? document.getElementById('essayFile').value : '' }));
    }

    function restoreDraft() {
        const draftStr = localStorage.getItem('submission_draft_' + assignmentId);
        if (!draftStr) return;
        try {
            const draft = JSON.parse(draftStr);
            if (draft.fileUrl) {
                const el = document.getElementById('essayFile'); if(el) el.value = draft.fileUrl;
                const st = document.getElementById('uploadStatus'); if(st) st.innerHTML = 'Đã phục hồi file: <a href="' + draft.fileUrl + '" target="_blank" class="text-blue-600 underline">Xem</a>';
            }
            if (isQuiz) JSON.parse(draft.content).forEach((ans, idx) => { if (ans !== -1) answers[idx] = ans; });
            else if (isTF) JSON.parse(draft.content).forEach((val, idx) => { if (val) { tfAnswers[idx] = val; ['a','b','c','d'].forEach((l, i) => { if (val[l]) selectTFAnswer(idx, i, val[l]); }); } });
            else if (isExam) {
                const parsed = JSON.parse(draft.content);
                if (parsed.quiz) parsed.quiz.forEach((ans, idx) => { if (ans !== -1) selectExamQuizAnswer(idx, ans); });
                if (parsed.tf) parsed.tf.forEach((val, idx) => { if (val) ['a','b','c','d'].forEach((l, i) => { if (val[l]) selectExamTFAnswer(idx, i, val[l]); }); });
                if (parsed.essay) document.querySelectorAll('textarea.auto-resize').forEach((t, i) => { if (parsed.essay[i]) { t.value = parsed.essay[i]; examAnswers.essay[i] = parsed.essay[i]; } });
            } else { const el = document.getElementById('essayText'); if (el) el.value = draft.content; }
        } catch(e) { console.error(e); }
    }

    function uploadFile() {
        const fileInput = document.getElementById('fileUploadInput'), statusEl = document.getElementById('uploadStatus');
        if (!fileInput.files.length) return;
        const formData = new FormData(); formData.append("file", fileInput.files[0]);
        statusEl.textContent = "Đang tải...";
        fetch("/Student/UploadFile", { method: "POST", body: formData }).then(r => r.json()).then(data => {
            if (data.success) {
                document.getElementById('essayFile').value = data.fileUrl;
                statusEl.innerHTML = "Thành công: <a href='" + data.fileUrl + "' target='_blank' class='text-blue-600 underline'>" + fileInput.files[0].name + "</a>";
                saveDraft();
            } else statusEl.textContent = "Lỗi: " + data.message;
        });
    }
</script>
