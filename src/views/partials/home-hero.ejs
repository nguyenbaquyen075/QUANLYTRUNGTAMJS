<%
/*
  Partial: home-hero.ejs
  Variables expected from parent scope:
    - heroIcon: material symbol name (e.g. 'school', 'diversity_3')
    - heroTitle: string
    - heroDesc: string
    - heroBreadcrumb: string (label for current page)
    - heroStats (optional): array of { value, label }
*/
var _heroIcon = (typeof heroIcon !== 'undefined' && heroIcon) ? heroIcon : 'home';
var _heroTitle = (typeof heroTitle !== 'undefined') ? heroTitle : '';
var _heroDesc = (typeof heroDesc !== 'undefined') ? heroDesc : '';
var _heroBreadcrumb = (typeof heroBreadcrumb !== 'undefined') ? heroBreadcrumb : '';
var _heroStats = (typeof heroStats !== 'undefined' && Array.isArray(heroStats)) ? heroStats : [];
%>
<section class="relative w-full min-h-[340px] flex items-center overflow-hidden" style="background-image: url('/images/blue-silk-hero.png'); background-size: cover; background-position: center;">
  <!-- Gradient overlay seamless với header -->
  <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(5,15,50,0.72) 0%, rgba(5,15,50,0.55) 60%, rgba(5,15,50,0.75) 100%);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8 py-16 text-white w-full">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-5 text-white/60 text-sm font-medium">
      <a href="/" class="text-white/60 hover:text-white/90 transition-colors">Trang chủ</a>
      <span class="text-white/40">/</span>
      <span class="font-semibold text-white/85"><%= _heroBreadcrumb %></span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl font-black mb-4 leading-tight text-white">
      <%= _heroTitle %>
    </h1>

    <!-- Description -->
    <p class="text-base md:text-lg text-white/90 max-w-2xl font-medium leading-relaxed text-white/90">
      <%= _heroDesc %>
    </p>

    <!-- Optional Stats -->
    <% if (_heroStats.length > 0) { %>
    <div class="mt-8 flex flex-wrap gap-8">
      <% _heroStats.forEach(function(stat, i) { %>
        <% if (i > 0) { %><div class="w-px h-10 bg-white/20 self-center hidden sm:block"></div><% } %>
        <div class="flex flex-col">
          <span class="text-3xl font-black text-white"><%= stat.value %></span>
          <span class="text-xs font-semibold text-white/55 uppercase tracking-widest mt-0.5"><%= stat.label %></span>
        </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>
