<%
/*
  Partial: home-hero.ejs
  Variables expected from parent scope:
    - heroIcon: material symbol name (e.g. 'school', 'diversity_3')
    - heroTitle: string
    - heroDesc: string
    - heroBreadcrumb: string (label for current page)
    - heroStats (optional): array of { value, label }
*/
var _heroIcon = (typeof heroIcon !== 'undefined' && heroIcon) ? heroIcon : 'home';
var _heroTitle = (typeof heroTitle !== 'undefined') ? heroTitle : '';
var _heroDesc = (typeof heroDesc !== 'undefined') ? heroDesc : '';
var _heroBreadcrumb = (typeof heroBreadcrumb !== 'undefined') ? heroBreadcrumb : '';
var _heroStats = (typeof heroStats !== 'undefined' && Array.isArray(heroStats)) ? heroStats : [];
%>
<section class="relative w-full min-h-[300px] flex items-center overflow-hidden bg-gradient-to-br from-blue-50 via-white to-sky-50 border-b border-outline-variant/20 pt-[64px]">
  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-8 py-16 w-full">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 mb-4 text-on-surface-variant text-sm font-semibold">
      <a href="/" class="text-on-surface-variant hover:text-primary transition-colors">Trang chủ</a>
      <span class="text-on-surface-variant/40">/</span>
      <span class="font-bold text-on-surface"><%= _heroBreadcrumb %></span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl font-black mb-4 leading-tight text-on-surface font-serif">
      <%= _heroTitle %>
    </h1>

    <!-- Description -->
    <p class="text-base md:text-lg text-on-surface-variant max-w-2xl font-medium leading-relaxed">
      <%= _heroDesc %>
    </p>

    <!-- Optional Stats -->
    <% if (_heroStats.length > 0) { %>
    <div class="mt-8 flex flex-wrap gap-8">
      <% _heroStats.forEach(function(stat, i) { %>
        <% if (i > 0) { %><div class="w-px h-10 bg-outline-variant/30 self-center hidden sm:block"></div><% } %>
        <div class="flex flex-col">
          <span class="text-3xl font-black text-on-surface"><%= stat.value %></span>
          <span class="text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest mt-0.5"><%= stat.label %></span>
        </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>
