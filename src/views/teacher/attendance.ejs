<div style="padding: 1.5rem 2rem;">
    <h2 style="margin: 0 0 0.25rem 0; font-size: 1.3rem; font-weight: 800; color: #1E293B;">
        <i class="fa-solid fa-clipboard-user" style="color: #7C3AED;"></i> Điểm Danh Buổi Học
    </h2>
    <p style="margin-top: 0.25rem;">Lớp: <strong><%= typeof lesson !== 'undefined' && lesson && lesson.Class ? lesson.Class.ClassName : '' %></strong> | Buổi học: <strong><%= typeof lesson !== 'undefined' && lesson ? lesson.Title : '' %></strong></p>

    <div style="background: linear-gradient(135deg, #EDE9FE, #F5F3FF); border: 1px solid #C4B5FD; border-radius: 10px; padding: 0.85rem 1.2rem; margin-bottom: 1.2rem; display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.83rem; color: #4B5563;">
        <span><i class="fa-solid fa-circle-check" style="color: #10B981;"></i> <strong>Có mặt / Trễ</strong>: Tự động được xem video</span>
        <span><i class="fa-solid fa-video" style="color: #7C3AED;"></i> <strong>Cho xem video</strong>: Học sinh có mặt/đi trễ được tự động tích. Bạn có thể tích thêm cho học sinh vắng mặt có lý do.</span>
    </div>

    <!-- Toast notification -->
    <div id="videoGrantToast" style="display:none; position: fixed; top: 1.5rem; right: 1.5rem; z-index: 9999; background: #1E293B; color: white; padding: 0.85rem 1.4rem; border-radius: 12px; font-size: 0.87rem; font-weight: 600; box-shadow: 0 8px 32px rgba(0,0,0,0.22); align-items: center; gap: 0.6rem; max-width: 360px; transition: opacity 0.3s;">
        <i class="fa-solid fa-circle-check" style="color: #10B981; font-size: 1.1rem;"></i>
        <span id="videoGrantToastMsg"></span>
    </div>

    <form action="/Teacher/SaveAttendance" method="post" style="margin-top: 0.5rem;">
        <input type="hidden" name="lessonId" value="<%= typeof lesson !== 'undefined' && lesson ? lesson.Id : '' %>" />

        <div class="table-wrapper">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th style="width: 22%;">Học Sinh</th>
                        <th style="width: 36%; text-align: center;">Trạng Thái Chuyên Cần</th>
                        <th style="width: 20%;">Ghi chú / Nhận xét</th>
                        <th style="width: 22%; text-align: center;">
                            <i class="fa-solid fa-video" style="color: #7C3AED;"></i> Cho xem video
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof students !== 'undefined' && students.length > 0) { %>
                        <% students.forEach((student, index) => { %>
                            <%
                                const att = typeof attendanceMap !== 'undefined' && attendanceMap && attendanceMap[student.Id] ? attendanceMap[student.Id] : null;
                                const statusVal = att ? att.Status : 0;
                                const remarkVal = att ? att.Remark : '';
                                const videoAccessVal = att ? att.VideoAccess : (statusVal === 0 || statusVal === 1);
                                const isAbsent = statusVal === 2 || statusVal === 3;
                            %>
                            <tr id="student-row-<%= student.Id %>">
                                <td style="font-weight: 600; display: flex; align-items: center; gap: 0.75rem;">
                                    <img src="<%= student.AvatarUrl || 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100' %>" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;" />
                                    <div>
                                        <div style="font-weight: 700; color: #1E293B; font-size: 0.88rem;"><%= student.FullName %></div>
                                        <% if (isAbsent && !videoAccessVal) { %>
                                            <span class="video-badge" style="font-size: 0.7rem; background: #FEF3C7; color: #92400E; padding: 0.1rem 0.45rem; border-radius: 99px; font-weight: 600; border: 1px solid #FDE68A; display: inline-block; margin-top: 0.1rem;">
                                                <i class="fa-solid fa-lock" style="font-size: 0.65rem;"></i> Chưa xem video
                                            </span>
                                        <% } else if (videoAccessVal) { %>
                                            <span class="video-badge" style="font-size: 0.7rem; background: #D1FAE5; color: #065F46; padding: 0.1rem 0.45rem; border-radius: 99px; font-weight: 600; border: 1px solid #A7F3D0; display: inline-block; margin-top: 0.1rem;">
                                                <i class="fa-solid fa-circle-check" style="font-size: 0.65rem;"></i> Được xem video
                                            </span>
                                        <% } %>
                                    </div>
                                    <input type="hidden" name="studentIds" value="<%= student.Id %>" />
                                </td>
                                <td style="text-align: center;">
                                    <div style="display: inline-flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                                        <label style="cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font-weight: 500; font-size: 0.85rem;">
                                            <input type="radio" name="statuses[<%= index %>]" value="PRESENT" <%= statusVal === 0 ? "checked" : "" %> style="accent-color: var(--primary-color);" onchange="onStatusChange(<%= student.Id %>, 'PRESENT')" />
                                            Có mặt
                                        </label>
                                        <label style="cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font-weight: 500; font-size: 0.85rem;">
                                            <input type="radio" name="statuses[<%= index %>]" value="LATE" <%= statusVal === 1 ? "checked" : "" %> style="accent-color: #F59E0B;" onchange="onStatusChange(<%= student.Id %>, 'LATE')" />
                                            Trễ
                                        </label>
                                        <label style="cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font-weight: 500; font-size: 0.85rem;">
                                            <input type="radio" name="statuses[<%= index %>]" value="ABSENT_REQUESTED" <%= statusVal === 2 ? "checked" : "" %> style="accent-color: #3B82F6;" onchange="onStatusChange(<%= student.Id %>, 'ABSENT_REQUESTED')" />
                                            Vắng phép
                                        </label>
                                        <label style="cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font-weight: 500; font-size: 0.85rem;">
                                            <input type="radio" name="statuses[<%= index %>]" value="ABSENT_UNEXCUSED" <%= statusVal === 3 ? "checked" : "" %> style="accent-color: #EF4444;" onchange="onStatusChange(<%= student.Id %>, 'ABSENT_UNEXCUSED')" />
                                            Vắng không phép
                                        </label>
                                    </div>
                                </td>
                                <td>
                                    <input type="text" name="remarks" class="form-input-custom" style="padding: 0.4rem 0.75rem; font-size: 0.85rem;" placeholder="Nhập nhận xét nhanh..." value="<%= remarkVal %>" />
                                </td>
                                <td style="text-align: center;">
                                    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem;">
                                        <label style="display: inline-flex; flex-direction: column; align-items: center; gap: 0.3rem; cursor: pointer;">
                                            <input type="checkbox"
                                                name="videoAccesses"
                                                value="<%= student.Id %>"
                                                id="videoAccess-<%= student.Id %>"
                                                <%= videoAccessVal ? 'checked' : '' %>
                                                style="width: 18px; height: 18px; accent-color: #7C3AED; cursor: pointer;"
                                            />
                                            <span style="font-size: 0.7rem; color: #7C3AED; font-weight: 600;" id="videoAccessLabel-<%= student.Id %>">
                                                <%= videoAccessVal ? 'Được xem' : 'Khóa' %>
                                            </span>
                                        </label>
                                        <!-- Quick AJAX grant/revoke button -->
                                        <button type="button"
                                            id="quickGrantBtn-<%= student.Id %>"
                                            data-student-id="<%= student.Id %>"
                                            data-lesson-id="<%= typeof lesson !== 'undefined' && lesson ? lesson.Id : '' %>"
                                            data-access="<%= videoAccessVal ? '1' : '0' %>"
                                            onclick="quickGrantVideo(this)"
                                            style="font-size: 0.7rem; padding: 0.3rem 0.65rem; border-radius: 8px; border: none; cursor: pointer; font-weight: 700; display: inline-flex; align-items: center; gap: 0.3rem; transition: all 0.2s; <%= videoAccessVal ? 'background: #FEE2E2; color: #991B1B;' : 'background: linear-gradient(135deg, #7C3AED, #4F46E5); color: white;' %>"
                                        >
                                            <% if (videoAccessVal) { %>
                                                <i class="fa-solid fa-lock-open"></i> Thu hồi
                                            <% } else { %>
                                                <i class="fa-solid fa-unlock"></i> Duyệt ngay
                                            <% } %>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 2rem; color: var(--text-muted);">Không có học sinh trong lớp học này.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div style="margin-top: 2rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
            <div style="font-size: 0.82rem; color: #64748B; line-height: 1.7;">
                <i class="fa-solid fa-circle-info"></i> Học sinh "Có mặt" và "Trễ" sẽ tự động được xem video. Bạn có thể tích thêm cho học sinh vắng mặt.<br>
                <i class="fa-solid fa-bolt" style="color: #7C3AED;"></i> Nhấn <strong style="color: #7C3AED;">Duyệt ngay</strong> để cấp/thu hồi quyền xem video tức thì mà không cần lưu lại toàn bộ.
            </div>
            <button type="submit" class="btn-custom" style="padding: 0.8rem 2rem; white-space: nowrap;"><i class="fa-solid fa-floppy-disk"></i> Lưu &amp; Khóa Buổi Học</button>
        </div>
    </form>
</div>

<script>
    function onStatusChange(studentId, newStatus) {
        const checkbox = document.getElementById('videoAccess-' + studentId);
        const label = document.getElementById('videoAccessLabel-' + studentId);
        if (newStatus === 'PRESENT' || newStatus === 'LATE') {
            checkbox.checked = true;
        } else if (newStatus === 'ABSENT_UNEXCUSED') {
            checkbox.checked = false;
        }
        label.textContent = checkbox.checked ? 'Được xem' : 'Khóa';
        updateQuickGrantBtn(studentId, checkbox.checked);
    }

    document.querySelectorAll('[id^="videoAccess-"]').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var id = this.id.replace('videoAccess-', '');
            var label = document.getElementById('videoAccessLabel-' + id);
            label.textContent = this.checked ? 'Được xem' : 'Khóa';
            updateQuickGrantBtn(id, this.checked);
        });
    });

    function updateQuickGrantBtn(studentId, hasAccess) {
        const btn = document.getElementById('quickGrantBtn-' + studentId);
        if (!btn) return;
        btn.dataset.access = hasAccess ? '1' : '0';
        if (hasAccess) {
            btn.style.background = '#FEE2E2';
            btn.style.color = '#991B1B';
            btn.innerHTML = '<i class="fa-solid fa-lock-open"></i> Thu hồi';
        } else {
            btn.style.background = 'linear-gradient(135deg, #7C3AED, #4F46E5)';
            btn.style.color = 'white';
            btn.innerHTML = '<i class="fa-solid fa-unlock"></i> Duyệt ngay';
        }
    }

    async function quickGrantVideo(btn) {
        const studentId = btn.dataset.studentId;
        const lessonId = btn.dataset.lessonId;
        const currentAccess = btn.dataset.access === '1';
        const newAccess = !currentAccess;

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

        try {
            const resp = await fetch('/Teacher/GrantVideoAccess', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ lessonId, studentId, grant: newAccess })
            });
            const data = await resp.json();

            if (data.success) {
                const checkbox = document.getElementById('videoAccess-' + studentId);
                if (checkbox) {
                    checkbox.checked = newAccess;
                    document.getElementById('videoAccessLabel-' + studentId).textContent = newAccess ? 'Được xem' : 'Khóa';
                }
                updateStudentBadge(studentId, newAccess);
                btn.dataset.access = newAccess ? '1' : '0';
                updateQuickGrantBtn(studentId, newAccess);
                showVideoGrantToast(data.message, newAccess);
            } else {
                alert(data.message || 'Có lỗi xảy ra.');
                btn.disabled = false;
                updateQuickGrantBtn(studentId, currentAccess);
            }
        } catch (e) {
            alert('Lỗi kết nối. Vui lòng thử lại.');
            btn.disabled = false;
            updateQuickGrantBtn(studentId, currentAccess);
        }
    }

    function updateStudentBadge(studentId, hasAccess) {
        const row = document.getElementById('student-row-' + studentId);
        if (!row) return;
        const nameDiv = row.querySelector('td:first-child > div');
        if (!nameDiv) return;
        let badge = nameDiv.querySelector('.video-badge');
        if (!badge) {
            badge = document.createElement('span');
            badge.className = 'video-badge';
            badge.style.cssText = 'font-size: 0.7rem; padding: 0.1rem 0.45rem; border-radius: 99px; font-weight: 600; display: inline-block; margin-top: 0.1rem;';
            nameDiv.appendChild(badge);
        }
        if (hasAccess) {
            badge.style.background = '#D1FAE5';
            badge.style.color = '#065F46';
            badge.style.border = '1px solid #A7F3D0';
            badge.innerHTML = '<i class="fa-solid fa-circle-check" style="font-size: 0.65rem;"></i> Được xem video';
        } else {
            badge.style.background = '#FEF3C7';
            badge.style.color = '#92400E';
            badge.style.border = '1px solid #FDE68A';
            badge.innerHTML = '<i class="fa-solid fa-lock" style="font-size: 0.65rem;"></i> Chưa xem video';
        }
    }

    let toastTimeout;
    function showVideoGrantToast(msg, success) {
        const toast = document.getElementById('videoGrantToast');
        const msgEl = document.getElementById('videoGrantToastMsg');
        if (!toast || !msgEl) return;
        msgEl.textContent = msg;
        const icon = toast.querySelector('i');
        if (icon) icon.style.color = success ? '#10B981' : '#EF4444';
        toast.style.display = 'flex';
        toast.style.opacity = '1';
        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(function() {
            toast.style.opacity = '0';
            setTimeout(function() { toast.style.display = 'none'; toast.style.opacity = '1'; }, 300);
        }, 3000);
    }
</script>
