<% title = "Bài Tập Học Viên Nộp"; %>

<%
    let avgScore = 0;
    let topStudentsCount = 0;
    let lowStudentsCount = 0;
    let gradedSubmissions = typeof submissions !== 'undefined' && submissions ? submissions.filter(s => s.Grade !== null) : [];
    if (gradedSubmissions.length > 0) {
        let sum = gradedSubmissions.reduce((acc, s) => acc + parseFloat(s.Grade), 0);
        avgScore = sum / gradedSubmissions.length;
    }
    
    if (typeof submissions !== 'undefined' && submissions) {
        submissions.forEach(s => {
            if (s.Grade !== null) {
                const g = parseFloat(s.Grade);
                if (g >= 8.0) topStudentsCount++;
                if (g < 5.0) lowStudentsCount++;
            }
        });
    }

    // List names of top students to show in the widget
    let topStudentNames = [];
    if (typeof submissions !== 'undefined' && submissions) {
        submissions.forEach(s => {
            if (s.Grade !== null && parseFloat(s.Grade) >= 8.0 && s.Student) {
                topStudentNames.push(s.Student.FullName);
            }
        });
    }
    let topStudentsText = topStudentNames.length > 0 ? "Bao gồm: " + topStudentNames.slice(0, 3).join(', ') + (topStudentNames.length > 3 ? '...' : '') : "Chưa có học sinh đạt điểm giỏi.";

    // Process previous homework evaluations
    let prevEvaluations = [];
    if (typeof otherAssignments !== 'undefined' && otherAssignments && otherAssignments.length > 0) {
        otherAssignments.forEach(pa => {
            let paGraded = pa.Submissions ? pa.Submissions.filter(s => s.Grade !== null) : [];
            let paAvg = 0;
            if (paGraded.length > 0) {
                let sum = paGraded.reduce((acc, s) => acc + parseFloat(s.Grade), 0);
                paAvg = sum / paGraded.length;
            }
            prevEvaluations.push({
                title: pa.Title,
                avg: paAvg,
                count: paGraded.length
            });
        });
    }
%>

