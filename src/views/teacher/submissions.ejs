<% title = "Bài Tập Học Viên Nộp"; %>

<div class="app-container">
    <div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
        <div>
            <h1><i class="fa-solid fa-folder-open" style="color: var(--primary-color);"></i> Danh Sách Bài Làm Đã Nộp</h1>
            <p style="margin-top: 0.25rem;">Bài tập: <strong><%= typeof assignment !== 'undefined' && assignment ? assignment.Title : '' %></strong> | Lớp: <strong><%= typeof assignment !== 'undefined' && assignment && assignment.Lesson && assignment.Lesson.Class ? assignment.Lesson.Class.ClassName : '' %></strong></p>
        </div>
        <a href="/Teacher/Dashboard" class="btn-secondary-custom"><i class="fa-solid fa-arrow-left"></i> Trở Về</a>
    </div>

    <!-- Assignment Info & Attachment Details -->
    <div style="background-color: var(--white); border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius-lg); margin-top: 1.5rem; box-shadow: var(--shadow-sm);">
        <h3 style="font-weight: 700; font-size: 1.05rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-file-invoice" style="color: var(--primary-color);"></i> Chi tiết Đề bài đã giao:</h3>
        <p style="font-size: 0.95rem; color: var(--text-dark); white-space: pre-wrap; margin-bottom: 1rem;"><%= typeof assignment !== 'undefined' && assignment ? assignment.Instruction : '' %></p>
        
        <% if (typeof assignment !== 'undefined' && assignment && assignment.AttachmentUrl) { %>
            <div style="border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 1rem;">
                <h4 style="font-size: 0.9rem; font-weight: 700; margin-bottom: 0.75rem;"><i class="fa-solid fa-paperclip" style="color: var(--primary-color);"></i> Đề bài đính kèm:</h4>
                <% 
                    const fileUrl = assignment.AttachmentUrl;
                    const ext = fileUrl.split('.').pop().toLowerCase();
                    const isImg = ['png', 'jpg', 'jpeg', 'gif', 'webp'].includes(ext);
                %>
                <% if (isImg) { %>
                    <div style="margin-bottom: 0.75rem;">
                        <a href="<%= fileUrl %>" target="_blank" title="Xem ảnh gốc">
                            <img src="<%= fileUrl %>" alt="Ảnh đề bài" style="max-width: 100%; max-height: 250px; border-radius: 6px; border: 1px solid var(--border-color);" />
                        </a>
                    </div>
                <% } %>
                <a href="<%= fileUrl %>" class="btn-secondary-custom" style="font-size: 0.85rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem;" download>
                    <i class="fa-solid fa-download"></i> Tải đề bài đã đính kèm (.<%= ext %>)
                </a>
            </div>
        <% } %>
    </div>

    <div style="margin-top: 2rem;">
        <% if (typeof submissions === 'undefined' || submissions.length === 0) { %>
            <div style="background-color: var(--white); border: 1px solid var(--border-color); padding: 3rem 2rem; text-align: center; color: var(--text-muted); border-radius: var(--radius-lg);">
                <i class="fa-regular fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: var(--text-muted); display: block;"></i>
                Chưa có học sinh nào nộp bài tập này.
            </div>
        <% } else { %>
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <% submissions.forEach(sub => { %>
                    <div style="background-color: var(--white); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm); display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
                        <div>
                            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                                <img src="<%= sub.Student && sub.Student.AvatarUrl ? sub.Student.AvatarUrl : 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100' %>" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                <div>
                                    <h3 style="font-size: 1.05rem; font-weight: 700; color: var(--text-dark);"><%= sub.Student ? sub.Student.FullName : 'Học sinh' %></h3>
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">Nộp lúc: <%= new Date(sub.SubmittedAt).toLocaleString('vi-VN') %></span>
                                </div>
                            </div>
                            <div style="background-color: var(--bg-light); padding: 1rem; border-radius: var(--radius-md); font-size: 0.95rem; color: var(--text-dark); border: 1px solid var(--border-color); margin-bottom: 1rem;">
                                <strong>Nội dung:</strong> <p style="margin-top: 0.25rem;"><%= sub.Content %></p>
                            </div>
                            <% if (sub.FileUrl) { %>
                                <a href="<%= sub.FileUrl %>" class="btn-secondary-custom" style="font-size: 0.85rem; text-decoration: none;" download><i class="fa-solid fa-paperclip"></i> Tải File Bài Làm</a>
                            <% } %>
                        </div>

                        <!-- Grading Form -->
                        <div style="border-left: 1px solid var(--border-color); padding-left: 2rem;">
                            <h4 style="font-weight: 700; font-size: 1rem; margin-bottom: 1rem; color: var(--text-dark);">Chấm Điểm & Phản Hồi</h4>
                            <form action="/Teacher/GradeSubmission" method="post">
                                <input type="hidden" name="submissionId" value="<%= sub.Id %>" />
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Điểm số (Thang điểm 10)</label>
                                    <input type="number" step="0.5" min="0" max="10" name="grade" class="form-input-custom" value="<%= sub.Grade !== null ? Number(sub.Grade).toFixed(1) : '10.0' %>" required />
                                </div>
                                <div class="form-group-custom" style="margin-bottom: 1.5rem;">
                                    <label class="form-label-custom">Nhận xét của Giáo viên</label>
                                    <textarea name="comment" class="form-input-custom" placeholder="Viết phản hồi cho học sinh..." style="height: 80px; resize: vertical;" required><%= sub.TeacherComment || '' %></textarea>
                                </div>
                                <button type="submit" class="btn-custom" style="width: 100%;"><i class="fa-solid fa-square-check"></i> Lưu Điểm Số</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
