                    <span id="modalTeacherExp" class="block text-2xl font-extrabold text-primary"></span>
                    <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Năm KN</span>
                </div>
                <div class="text-center">
                    <span id="modalTeacherStudents" class="block text-2xl font-extrabold text-primary"></span>
                    <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Học sinh</span>
                </div>
                <div class="text-center">
                    <span id="modalTeacherRating" class="block text-2xl font-extrabold text-primary flex items-center justify-center gap-0.5"></span>
                    <span class="text-[10px] text-outline uppercase font-bold tracking-wide">Đánh giá</span>
                </div>
            </div>
        </div>

        <!-- Right Side: Details / Bio -->
        <div class="md:w-[70%] p-12 flex flex-col justify-between">
            <div class="flex-grow">
                <h4 class="text-base font-black text-primary uppercase tracking-wider mb-6"><i class="fa-solid fa-graduation-cap"></i>  Tiểu sử & Kinh nghiệm giảng dạy</h4>
                <div class="overflow-y-auto max-h-[500px] pr-4 text-justify">
                    <p id="modalTeacherBio" class="text-base text-on-surface-variant leading-relaxed font-medium" style="white-space: pre-line;"></p>
                </div>
            </div>
            <div class="mt-8 pt-5 border-t border-slate-100 flex justify-end">
                <button onclick="closeTeacherDetailModal()" class="px-6 py-3 bg-primary text-white text-sm font-bold rounded-xl shadow-lg hover:bg-primary-dark transition-all">
                    Đóng cửa sổ
                </button>
            </div>
        </div>
