<style>
        .glass-premium {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .blended-gradient {
            background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
            /* Deepened gradient */
        }

        .hero-blended-bg {
            background-image: radial-gradient(circle at 70% 30%, rgba(30, 58, 138, 0.2) 0%, transparent 70%),
                linear-gradient(135deg, rgba(30, 58, 138, 0.1) 0%, rgba(23, 37, 84, 0.1) 100%);
            background-size: cover;
            background-position: center;
        }

        .platinum-white-gradient {
            background: linear-gradient(180deg, #f1f5f9 0%, #ffffff 100%);
        }

        .text-gradient {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-shadow {
            box-shadow: 0 20px 40px -15px rgba(30, 58, 138, 0.15);
        }

        .hover-lift {
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .hover-lift:hover {
            transform: translateY(-8px);
        }

        .carousel-track {
            display: flex;
            transition: transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
        }

        @keyframes shake {

            0%,
            100% {
                transform: rotate(0);
            }

            25% {
                transform: rotate(-10deg);
            }

            75% {
                transform: rotate(10deg);
            }
        }

        .contact-shake:hover .material-symbols-outlined {
            animation: shake 0.3s infinite;
        }
    </style>
</head>
<body class="antialiased font-sans bg-surface text-on-surface">
<%- include('../partials/home-navbar', { activePage: 'teachers', isLoggedIn: isLoggedIn, currentUserFullName: currentUserFullName, currentUserRole: currentUserRole }) %>
<main class="pt-0">
<!-- Hero Section -->
<%- include('../partials/home-hero', { heroIcon: 'diversity_3', heroTitle: 'Đội Ngũ Giáo Viên Tiêu Biểu', heroDesc: 'Học hỏi từ những thầy cô có chuyên môn cao, nhiều năm kinh nghiệm ôn thi và bồi dưỡng, cam kết mang lại lộ trình học tập tối ưu cho từng học sinh.', heroBreadcrumb: 'Giáo Viên', heroStats: [{value: '200+', label: 'Giảng viên'}, {value: '15k+', label: 'Học sinh đậu'}] }) %>

<!-- Teachers Grid Section -->
<section class="py-24 bg-surface">
<div class="max-w-7xl mx-auto px-margin-mobile lg:px-8">
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

<% if (typeof teachers !== 'undefined' && teachers && teachers.length > 0) { %>
    <% teachers.forEach(t => { %>
        <% const profile = t.Profile || {}; %>
        <% const avatarUrl = t.AvatarUrl || 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=256&auto=format&fit=crop'; %>
        <div class="teacher-card bg-white border border-outline-variant/30 rounded-xl overflow-visible flex flex-col items-center p-8 text-center relative hover:shadow-xl transition-all duration-300 cursor-pointer hover:border-primary/50 hover:-translate-y-1"
             onclick="openTeacherDetailModal({
                 fullName: '<%= (t.FullName||'').replace(/'/g, "\\'") %>',
                 avatarUrl: '<%= avatarUrl %>',
                 subject: '<%= (profile.Subject || 'Toán học').replace(/'/g, "\\'") %>',
                 title: '<%= (profile.TeacherTitle || 'Giáo viên tiêu biểu').replace(/'/g, "\\'") %>',
                 experience: '<%= profile.TeacherExperience !== null ? profile.TeacherExperience : 5 %>',
                 students: '<%= profile.TeacherStudents !== null ? profile.TeacherStudents : 100 %>',
                 rating: '<%= profile.TeacherRating !== null ? parseFloat(profile.TeacherRating).toFixed(1) : '4.8' %>',
                 bio: `<%= (profile.TeacherBio || 'Giảng viên giàu kinh nghiệm ôn luyện và bồi dưỡng kiến thức toàn diện cho các em học viên.').replace(/`/g, '\\`').replace(/\$/g, '\\$') %>`
             })">
            <div class="relative mb-6">
                <div class="w-32 h-32 rounded-full border-4 border-primary/10 overflow-hidden bg-surface-container shadow-inner">
                    <img class="w-full h-full object-cover" src="<%= avatarUrl %>" alt="<%= t.FullName %>"/>
                </div>
                <span class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-4 py-1 rounded-full shadow-lg whitespace-nowrap"><%= profile.Subject || 'Toán học' %></span>
            </div>
            <h3 class="text-lg font-bold text-primary mb-1 mt-2"><%= t.FullName %></h3>
            <p class="text-sm font-bold text-secondary-container mb-4"><%= profile.TeacherTitle || 'Giáo viên tiêu biểu tại trung tâm' %></p>
            <p class="text-sm text-on-surface-variant mb-6 leading-relaxed line-clamp-3">
                <%= profile.TeacherBio || 'Giảng viên giàu kinh nghiệm ôn luyện và bồi dưỡng kiến thức toàn diện cho các em học viên.' %>
            </p>
            <div class="mt-auto w-full pt-6 border-t border-outline-variant/30 flex justify-between gap-4">
                <div class="flex flex-col items-center">
                    <span class="text-xl font-bold text-primary"><%= profile.TeacherExperience !== null ? profile.TeacherExperience : 5 %>+</span>
                    <span class="text-xs text-outline uppercase font-semibold tracking-wide">Năm KN</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-xl font-bold text-primary"><%= profile.TeacherStudents !== null ? profile.TeacherStudents : 100 %>+</span>
                    <span class="text-xs text-outline uppercase font-semibold tracking-wide">Học sinh</span>
                </div>
                <div class="flex flex-col items-center">
                    <span class="text-xl font-bold text-primary flex items-center gap-0.5"><%= profile.TeacherRating !== null ? parseFloat(profile.TeacherRating).toFixed(1) : '4.8' %> <span class="material-symbols-outlined text-[16px] text-secondary" style="font-variation-settings: 'FILL' 1;">star</span></span>
                    <span class="text-xs text-outline uppercase font-semibold tracking-wide">Đánh giá</span>
                </div>
            </div>
        </div>
    <% }) %>
<% } else { %>
    <div class="col-span-full text-center py-12 text-slate-500">
        Hiện chưa có danh sách giáo viên nào được kích hoạt.
    </div>
<% } %>

</div>

