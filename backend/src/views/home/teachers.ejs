<!-- Teacher Detail Modal -->
<div id="teacherDetailModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] hidden items-center justify-center p-4" onclick="handleOutsideClick(event)">
    <div class="bg-white rounded-3xl max-w-6xl w-full overflow-hidden shadow-2xl transform transition-all duration-300 scale-95 opacity-0 flex flex-col md:flex-row relative" id="teacherModalContent" onclick="event.stopPropagation()">
        <!-- Close Button -->
        <button onclick="closeTeacherDetailModal()" class="absolute top-6 right-6 text-slate-400 hover:text-slate-600 transition-colors w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center z-10">
            <span class="material-symbols-outlined text-[24px] font-bold">close</span>
        </button>

        <!-- Left Side: Profile Intro -->
        <div class="md:w-[30%] bg-slate-50 p-12 border-b md:border-b-0 md:border-r border-slate-100 flex flex-col items-center justify-center text-center">
            <div class="w-48 h-48 rounded-full border-4 border-primary/10 overflow-hidden bg-white shadow-md mb-6">
                <img id="modalTeacherAvatar" class="w-full h-full object-cover" src="" alt="Teacher Avatar"/>
            </div>
            <span id="modalTeacherSubject" class="bg-primary text-white text-xs font-bold px-4 py-1 rounded-full shadow-sm mb-4"></span>
            <h3 id="modalTeacherName" class="text-3xl font-extrabold text-primary mb-2 whitespace-nowrap"></h3>
            <p id="modalTeacherTitle" class="text-sm text-on-surface-variant font-medium mb-10 px-2"></p>
            
            <div class="grid grid-cols-3 gap-2 w-full pt-6 border-t border-slate-200">
