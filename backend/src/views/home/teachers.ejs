</div>

<script>
    function openTeacherDetailModal(data) {
        document.getElementById('modalTeacherAvatar').src = data.avatarUrl;
        document.getElementById('modalTeacherSubject').textContent = data.subject;
        document.getElementById('modalTeacherName').textContent = data.fullName;
        document.getElementById('modalTeacherTitle').textContent = data.title;
        document.getElementById('modalTeacherExp').textContent = data.experience + '+';
        document.getElementById('modalTeacherStudents').textContent = data.students + '+';
        document.getElementById('modalTeacherRating').innerHTML = data.rating + ' <span class="material-symbols-outlined text-[14px] text-secondary" style="font-variation-settings: \'FILL\' 1; vertical-align: middle;">star</span>';
        document.getElementById('modalTeacherBio').textContent = data.bio;

        const modal = document.getElementById('teacherDetailModal');
        const content = document.getElementById('teacherModalContent');
        
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden'; // prevent background scrolling
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeTeacherDetailModal() {
        const modal = document.getElementById('teacherDetailModal');
        const content = document.getElementById('teacherModalContent');
        
        content.classList.remove('scale-100', 'opacity-100');
        content.classList.add('scale-95', 'opacity-0');
        document.body.style.overflow = ''; // restore scrolling
        setTimeout(() => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }, 300);
    }

    function handleOutsideClick(event) {
        closeTeacherDetailModal();
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeTeacherDetailModal();
        }
    });
</script>
</body>
</html>
