  }

  body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

  /* Category Tabs */
  .cat-tabs { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1.75rem; }
  .cat-btn {
    padding: 0.45rem 1.2rem;
    border-radius: 9999px;
    border: 1.5px solid #cbd5e1;
    background: #fff;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #334155;
  }
  .cat-btn.active, .cat-btn:hover {
    background: #1e3a8a;
    color: #fff;
    border-color: #1e3a8a;
  }

  /* Doc Cards */
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .doc-card {
    background: #fff;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    transition: all 0.22s ease;
    color: #0f172a;
  }
  .doc-card:hover {
    border-color: #1e3a8a;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(30, 58, 138,0.1);
  }
  .doc-badge {
    min-width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .doc-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }
  .doc-meta { font-size: 0.78rem; color: #64748b; display: flex; gap: 1rem; }
  .doc-arrow {
    margin-left: auto;
    color: #94a3b8;
    font-size: 1.1rem;
    transition: color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }
  .doc-card:hover .doc-arrow { color: #1e3a8a; transform: translateY(2px); }

  /* FAQ */
  .faq-wrap { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem; }
  .faq-item {
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: border-color 0.2s;
  }
  .faq-item.active { border-color: #1e3a8a; }
  .faq-q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    font-weight: 700;
    font-size: 0.95rem;
    color: #0f172a;
    gap: 1rem;
    user-select: none;
  }
  .faq-q .faq-icon {
    color: #94a3b8;
    transition: transform 0.25s ease, color 0.2s;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .faq-item.active .faq-icon { transform: rotate(180deg); color: #1e3a8a; }
  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.25s;
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.65;
    padding: 0 1.25rem;
  }
  .faq-item.active .faq-a { max-height: 200px; padding: 0 1.25rem 1.25rem; }
