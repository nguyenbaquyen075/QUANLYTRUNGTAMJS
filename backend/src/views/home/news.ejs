<style>
  .glass-premium {
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .blended-gradient {
      background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
  }

  body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

  /* News Grid */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.75rem;
  }
  .news-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border: 1px solid #e2e8f0;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .news-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 32px rgba(30, 58, 138,0.12);
  }
  .news-thumb {
    height: 210px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .news-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #1e3a8a;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .news-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .news-date {
    font-size: 0.78rem;
    color: #94a3b8;
    font-weight: 500;
    margin-bottom: 0.6rem;
  }
  .news-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: #0f172a;
    line-height: 1.45;
    margin-bottom: 0.65rem;
  }
  .news-desc {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .news-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #1e3a8a;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    transition: gap 0.2s;
  }
  .news-link:hover { gap: 0.65rem; color: #1d4ed8; }

  /* Tips Section */
  .tips-section {
    background: linear-gradient(135deg, #eff6ff 0%, #f8fafc 100%);
    border-radius: 16px;
    border: 1px solid #dbeafe;
    padding: 2.5rem 2rem;
    margin-top: 3rem;
  }
  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }
  .tip-card {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 1.25rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .tip-num {
    min-width: 34px;
    height: 34px;
    background: #1e3a8a;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.875rem;
  }
  .tip-card h4 { font-size: 0.95rem; font-weight: 700; color: #0f172a; margin-bottom: 0.3rem; }
  .tip-card p  { font-size: 0.82rem; color: #64748b; line-height: 1.55; }
