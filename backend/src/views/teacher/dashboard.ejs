            arrow.style.transform = "rotate(180deg)";
        } else {
            panel.style.display = "none";
            arrow.style.transform = "rotate(0deg)";
        }
    }

    function toggleExamClass(classId) {
        const panel = document.getElementById(`exam-class-${classId}`);
        const arrow = document.getElementById(`arrow-exam-${classId}`);
        if (panel.style.display === "none") {
            panel.style.display = "block";
            arrow.style.transform = "rotate(180deg)";
        } else {
            panel.style.display = "none";
            arrow.style.transform = "rotate(0deg)";
        }
    }

    function toggleLessonClass(idx) {
        const panel = document.getElementById(`class-sec-${idx}`);
        const arrow = document.getElementById(`chevron-class-sec-${idx}`);
        if (panel.style.display === "none") {
            panel.style.display = "flex";
            arrow.style.transform = "rotate(0deg)";
        } else {
            panel.style.display = "none";
            arrow.style.transform = "rotate(-90deg)";
        }
    }
</script>
