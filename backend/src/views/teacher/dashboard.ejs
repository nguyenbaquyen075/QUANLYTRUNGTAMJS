    function submitVideoFile() {
        if (!_selectedVideoFile) return;

        const lessonId = document.getElementById('uploadVideoLessonId').value;
        if (!lessonId) { alert('Thiếu thông tin buổi học.'); return; }

        const formData = new FormData();
        formData.append('videoFile', _selectedVideoFile);
        formData.append('lessonId', lessonId);

        const progressContainer = document.getElementById('videoUploadProgressContainer');
        const progressBar = document.getElementById('videoUploadBar');
        const progressPercent = document.getElementById('videoUploadPercent');
        const statusText = document.getElementById('videoUploadStatusText');
        const uploadBtn = document.getElementById('uploadVideoFileBtn');

        progressContainer.style.display = 'block';
        uploadBtn.disabled = true;
        uploadBtn.textContent = 'Đang tải lên...';

        const xhr = new XMLHttpRequest();

        xhr.upload.addEventListener('progress', function(e) {
            if (e.lengthComputable) {
                const pct = Math.round((e.loaded / e.total) * 100);
                progressBar.style.width = pct + '%';
                progressPercent.textContent = pct + '%';
                statusText.textContent = pct < 100 ? 'Đang tải lên...' : 'Đang xử lý...';
            }
        });

        xhr.addEventListener('load', function() {
            try {
                const res = JSON.parse(xhr.responseText);
                if (res.success) {
                    statusText.textContent = '✓ Upload thành công!';
                    progressBar.style.background = '#10B981';
                    progressPercent.textContent = '100%';
                    progressBar.style.width = '100%';
                    setTimeout(function() { location.reload(); }, 1200);
                } else {
                    statusText.textContent = '✗ ' + (res.message || 'Upload thất bại');
                    progressBar.style.background = '#EF4444';
                    uploadBtn.disabled = false;
                    uploadBtn.innerHTML = '<i class="fa-solid fa-cloud-arrow-up"></i> Thử lại';
                }
            } catch (err) {
                statusText.textContent = '✗ Lỗi không xác định.';
                uploadBtn.disabled = false;
            }
        });

        xhr.addEventListener('error', function() {
            statusText.textContent = '✗ Lỗi kết nối. Vui lòng thử lại.';
            progressBar.style.background = '#EF4444';
            uploadBtn.disabled = false;
        });

        xhr.open('POST', '/Teacher/UploadLessonVideo');
        xhr.send(formData);
    }

