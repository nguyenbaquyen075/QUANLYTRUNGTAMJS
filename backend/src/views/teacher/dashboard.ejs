<% 
    title = "Giáo Viên Dashboard"; 
    hideHeader = true; 
    const formatTime = (t) => {
        if (!t) return '';
        if (typeof t === 'string') return t.substring(0, 5);
        if (typeof t === 'object') {
            const h = (t.hours !== undefined ? t.hours : (t.hour !== undefined ? t.hour : 0)).toString().padStart(2, '0');
            const m = (t.minutes !== undefined ? t.minutes : (t.minute !== undefined ? t.minute : 0)).toString().padStart(2, '0');
            return `${h}:${m}`;
        }
        return String(t);
    };
%>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

<style>
    .dashboard-layout {
        display: flex;
        height: 100vh;
        background: #ffffff;
        overflow: hidden;
    }
    
    .sidebar {
        width: 280px;
        background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #e0f2fe 100%); border-right: 1px solid rgba(30, 58, 138, 0.08);
        display: flex;
        flex-direction: column;
        padding: 0 1rem 0.75rem 1rem;
        flex-shrink: 0;
        z-index: 10;
        position: relative;
    }
    
    .main-content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
    }

    .teacher-content-body {
        flex: 1;
        padding: 2.5rem;
        overflow-y: auto;
        background: #ffffff;
    }

    /* Sidebar Link Buttons */
    .teacher-tab-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        text-align: left;
        padding: 0.85rem 1.1rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.92rem;
        border: none;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        background: none;
        color: #475569;
    }

    .teacher-tab-btn:hover {
        background: rgba(30, 58, 138, 0.04);
        color: #1e3a8a;
        padding-left: 1.30rem;
    }

    .teacher-tab-btn.active {
        background: rgba(30, 58, 138, 0.06);
        color: #1e3a8a;
        font-weight: 700;
        border-left: 4px solid #1e3a8a;
        border-radius: 4px 12px 12px 4px;
    }

    .teacher-tab-btn i {
        font-size: 1.15rem;
        width: 20px;
        text-align: center;
        transition: transform 0.2s ease;
    }

    .teacher-tab-btn:hover i {
        transform: scale(1.1);
    }

    .tab-content {
        display: none;
    }

    .tab-content.active {
        display: block;
    }

    .teacher-logout-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.85rem 1.1rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.92rem;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        background: none;
        color: #ff8b8b;
        text-decoration: none;
        margin-top: auto;
    }
    .teacher-logout-btn:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #ff8b8b;
    }

    @media (max-width: 992px) {
        .dashboard-layout {
            flex-direction: column;
            height: auto;
            overflow: visible;
        }
        .sidebar {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid rgba(30, 58, 138, 0.08);
            padding: 1.25rem 0.75rem;
        }
        .sidebar div[style*="flex-direction: column"] {
            flex-direction: row !important;
            overflow-x: auto;
            white-space: nowrap;
            padding-bottom: 0.5rem;
            gap: 0.5rem;
            -webkit-overflow-scrolling: touch;
        }
        .teacher-tab-btn {
            width: auto;
            display: inline-flex;
            white-space: nowrap;
            padding: 0.6rem 1rem;
        }
        .main-content {
            height: auto !important;
            overflow: visible !important;
        }
        .teacher-content-header {
            padding: 0 1.25rem !important;
            height: 60px !important;
        }
        .teacher-content-body {
            padding: 1.25rem !important;
            overflow-y: visible !important;
        }
    }

    /* ── Card / container shared across all tabs ── */
    .chart-container-custom {
        background: #ffffff;
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        padding: 1.75rem 2rem;
        box-shadow: 0 1px 6px rgba(15,23,42,0.06);
        margin-bottom: 1.5rem;
    }
    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .chart-title {
        font-size: 1rem;
        font-weight: 800;
        color: #0F172A;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* ── Form utilities ── */
    .form-group-custom { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-label-custom { font-size: 0.8rem; font-weight: 700; color: #475569; text-transform: none; }
    .form-input-custom {
        border: 1px solid #CBD5E1;
        border-radius: 8px;
        padding: 0.55rem 0.85rem;
        font-size: 0.9rem;
        color: #0F172A;
        outline: none;
        transition: border-color 0.2s;
        background: #faf8f0;
        width: 100%;
        box-sizing: border-box;
    }
    .form-input-custom:focus { border-color: #2563EB; background: #fff; }
    .btn-custom {
        background: linear-gradient(135deg, #1e3a8a, #2563EB);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.6rem 1.4rem;
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s;
    }
    .btn-custom:hover { opacity: 0.88; }
</style>

<div class="dashboard-layout">
    <!-- Sidebar Navigation -->
    <div class="sidebar">
        <div class="sidebar-header" style="height: 70px; display: flex; align-items: center; padding: 0 0.5rem; border-bottom: 1px solid rgba(30, 58, 138, 0.08); margin-bottom: 1.25rem; box-sizing: border-box;">
            <div class="sidebar-user-info" style="display: flex; align-items: center; gap: 0.75rem;">
                <div style="width: 42px; height: 42px; border-radius: 50%; background: linear-gradient(135deg, #1e3a8a, #3B82F6); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 1rem; border: 2px solid white; box-shadow: 0 4px 10px rgba(30, 58, 138, 0.15); flex-shrink: 0;">
                    <%= typeof currentUserFullName !== 'undefined' && currentUserFullName ? currentUserFullName.charAt(0).toUpperCase() : 'G' %>
                </div>
                <div>
                    <h5 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #0b1120; line-height: 1.2;"><%= typeof currentUserFullName !== 'undefined' ? currentUserFullName : '' %></h5>
                    <span style="font-size: 0.7rem; color: #64748B; display: flex; align-items: center; gap: 0.25rem; margin-top: 0.25rem;">
                        <span style="display:inline-block; width: 6px; height: 6px; background:#10B981; border-radius:50%;"></span> Giáo Viên
                    </span>
                </div>
            </div>
        </div>
        
        <div style="display: flex; flex-direction: column; gap: 0.45rem; flex-grow: 1;">
            <button class="teacher-tab-btn active" onclick="switchTab('tabLessons')">
                Lịch dạy & Điểm danh
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabAssignments')">
                Bài tập về nhà (<%= typeof assignments !== 'undefined' ? assignments.filter(a => a.AssignmentType !== 3).length : 0 %>)
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabExams')">
                Bài kiểm tra (<%= typeof assignments !== 'undefined' ? assignments.filter(a => a.AssignmentType === 3).length : 0 %>)
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabCourseProgress')">
                Tiến độ các khóa học
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabMyCourses')">
                Khóa học của tôi
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabStudentKpi')">
                Đánh giá KPI học viên
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabTeacherKpi')">
                Đánh giá KPI giảng viên
            </button>
            <button class="teacher-tab-btn" onclick="switchTab('tabTeacherProfile')">
                Thông tin giới thiệu
            </button>
        </div>

        <!-- Logout Button at bottom of sidebar -->
        <div style="margin-top: auto; padding: 1.25rem 0.5rem 0.5rem 0.5rem; border-top: 1px solid rgba(30, 58, 138, 0.08);">
            <a href="/Auth/Logout" class="teacher-logout-btn" onclick="return confirm('Bạn có chắc muốn đăng xuất không?')">
                Đăng xuất
            </a>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="main-content">
        <!-- Internal white header -->
        <div class="teacher-content-header" style="height: 70px; background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #e0f2fe 100%); border-bottom: 1px solid rgba(30, 58, 138, 0.08); display: flex; justify-content: space-between; align-items: center; padding: 0 2.5rem; flex-shrink: 0; z-index: 5; box-shadow: 0 1px 3px rgba(15,23,42,0.02);">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <h3 style="font-size: 1.15rem; font-weight: 800; color: #0F172A; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fa-solid fa-chalkboard-user text-[#1e3a8a]"></i> Bảng Tin Giáo Viên
                </h3>
            </div>
            
            <div style="display: flex; align-items: center; gap: 1rem;">
                <a href="/Notification" style="position: relative; padding: 0; display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; background: #F1F5F9; color: #475569; border: 1.5px solid #E2E8F0; text-decoration: none;" title="Thông báo">
                    <i class="fa-solid fa-bell" style="font-size: 1.15rem; margin: 0;"></i>
                    <span id="notifBadge" style="position: absolute; top: -3px; right: -3px; background: #EF4444; color: white; font-size: 0.65rem; font-weight: 800; border-radius: 50%; width: 18px; height: 18px; display: none; align-items: center; justify-content: center; border: 2px solid white; line-height: 1;">0</span>
                </a>
            </div>
        </div>

        <!-- Body wrapper -->
        <div class="teacher-content-body">
        <div class="tab-content active" id="tabLessons">
            <div style="background-color: var(--white); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; flex-wrap: wrap; gap: 1rem;">
                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <h2 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin: 0;"><i class="fa-solid fa-calendar-week" style="color: #2563EB;"></i> Danh sách các buổi học được giao</h2>
                        <span class="badge-custom badge-info"><%= typeof lessons !== 'undefined' ? lessons.length : 0 %> buổi</span>
                    </div>
                    <button class="btn-custom" style="font-size: 0.85rem; padding: 0.5rem 1rem;" onclick="openModal('lessonModal')">
                        <i class="fa-solid fa-plus"></i> Thêm buổi học mới
                    </button>
                </div>

                <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <% if (typeof lessons === 'undefined' || lessons.length === 0) { %>
                        <p style="font-size: 0.95rem; color: var(--text-muted);">Không có buổi học nào.</p>
                    <% } else { %>
                        <% 
                            // Nhóm các buổi học theo lớp
                            const groupedLessons = {};
                            lessons.forEach(l => {
                                const className = l.Class ? l.Class.ClassName : 'Lớp khác';
                                if (!groupedLessons[className]) {
                                    groupedLessons[className] = [];
                                }
                                groupedLessons[className].push(l);
                            });
                        %>
                        <% Object.keys(groupedLessons).forEach((className, idx) => { %>
                            <div style="border: 1px solid var(--border-color); border-radius: var(--radius-md); overflow: hidden; margin-bottom: 0.75rem;">
                                <div onclick="toggleLessonClass(<%= idx %>)" style="background-color: #F1F5F9; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none;">
                                    <span style="font-size: 0.9rem; font-weight: 700; color: #1E293B;"><i class="fa-solid fa-graduation-cap" style="color: #3B82F6; margin-right: 0.5rem;"></i> Lớp: <%= className %></span>
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <span class="badge-custom badge-info" style="font-size: 0.75rem;"><%= groupedLessons[className].length %> buổi</span>
                                        <i class="fa-solid fa-chevron-down" id="chevron-class-sec-<%= idx %>" style="font-size: 0.8rem; color: #64748B; transition: transform 0.2s; transform: rotate(-90deg);"></i>
                                    </div>
                                </div>
                                <div id="class-sec-<%= idx %>" style="padding: 1rem; display: none; flex-direction: column; gap: 0.75rem; background-color: var(--white);">
                                    <% groupedLessons[className].forEach(l => { %>
                                        <div style="background-color: var(--bg-light); border: 1px solid var(--border-color); padding: 1rem 1.25rem; border-radius: var(--radius-sm); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                                            <div>
                                                <h4 style="font-size: 0.95rem; font-weight: 600; margin: 0 0 0.25rem 0; color: var(--text-dark);"><%= l.Title %></h4>
                                                <div style="font-size: 0.85rem; color: var(--text-muted); display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
                                                    <span><i class="fa-regular fa-clock"></i> <%= new Date(l.LessonDate).toLocaleDateString('vi-VN') %> | <%= formatTime(l.StartTime) %> - <%= formatTime(l.EndTime) %></span>
                                                    <% if (l.MeetingUrl) { %>
                                                        <a href="<%= l.MeetingUrl %>" target="_blank" style="color: #2563EB; text-decoration: none; font-weight: 600;"><i class="fa-solid fa-video"></i> Vào phòng học</a>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end;">
                                                <span class="badge-custom <%= l.Status === 2 ? 'badge-success' : l.Status === 3 ? 'badge-danger' : 'badge-warning' %>">
                                                    <%= l.Status === 2 ? 'Đã hoàn thành' : l.Status === 3 ? 'Đã hủy' : 'Sắp dạy' %>
                                                </span>
                                                <% if (l.VideoUrl) { %>
                                                    <span style="display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; padding: 0.3rem 0.65rem; background: #D1FAE5; color: #065F46; border-radius: 20px; font-weight: 600; border: 1px solid #6EE7B7;">
                                                        <i class="fa-solid fa-circle-check"></i> Đã có video
                                                    </span>
                                                <% } %>

                                                <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                                                    <% if (l.Status === 2) { %>
                                                        <button class="btn-upload-video btn-custom" 
                                                            data-lesson-id="<%= l.Id %>"
                                                            data-lesson-title="<%- (l.Title || '').replace(/"/g, '&quot;') %>"
                                                            data-video-url="<%- (l.VideoUrl || '').replace(/"/g, '&quot;') %>"
                                                            style="font-size: 0.8rem; padding: 0.4rem 0.85rem; background: linear-gradient(135deg, #7C3AED, #4F46E5); border-color: #7C3AED;">
                                                            <i class="fa-solid fa-video"></i> <%= l.VideoUrl ? 'Sửa Video' : 'Upload Video' %>
                                                        </button>
                                                    <% } %>
                                                    <button class="btn-secondary-custom" style="font-size: 0.8rem; padding: 0.4rem 0.75rem;" onclick="openEditLessonModal(<%= l.Id %>, <%- JSON.stringify(l.Title) %>, '<%= l.MeetingUrl || '' %>', '<%= l.MeetingId || '' %>', '<%= l.MeetingPassword || '' %>', '<%= l.Status %>', '<%= l.VideoUrl || '' %>', '<%= l.DocumentUrl || '' %>', <%- JSON.stringify(l.DocumentName || '') %>)">
                                                        <i class="fa-solid fa-pen-to-square"></i> Cập nhật
                                                    </button>
                                                    <% if (l.Status === 2) { %>
                                                        <a href="/Teacher/Attendance/<%= l.Id %>" class="btn-custom" style="font-size: 0.8rem; padding: 0.4rem 0.75rem; text-decoration: none; background: linear-gradient(135deg, #D97706, #B45309); border-color: #D97706;"><i class="fa-solid fa-video"></i> Duyệt Video</a>
                                                    <% } else { %>
                                                        <a href="/Teacher/Attendance/<%= l.Id %>" class="btn-custom" style="font-size: 0.8rem; padding: 0.4rem 0.75rem; text-decoration: none;"><i class="fa-solid fa-clipboard-user"></i> Điểm danh</a>
                                                    <% } %>
                                                    <a href="/Teacher/CreateAssignment/<%= l.Id %>" class="btn-secondary-custom" style="font-size: 0.8rem; padding: 0.4rem 0.75rem; text-decoration: none;"><i class="fa-solid fa-plus"></i> Giao bài tập</a>
                                                </div>
                                            </div>

                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Tab: Bài tập về nhà -->
        <div class="tab-content" id="tabAssignments">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
                <h2 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin: 0;"><i class="fa-solid fa-file-invoice" style="color: #2563EB;"></i> Thống kê bài tập đã giao theo Lớp học</h2>
                <span style="font-size: 0.85rem; color: var(--text-muted);">Click vào lớp học để xem danh sách bài tập</span>
            </div>

            <% if (typeof assignments === 'undefined' || assignments.length === 0) { %>
                <div style="background-color: var(--white); border: 1px dashed var(--border-color); padding: 3rem 2rem; text-align: center; color: var(--text-muted); border-radius: var(--radius-lg);">
                    Chưa có bài tập nào được giao.
                </div>
            <% } else { %>
                <% 
                    const groupedAssignments = {};
                    assignments.forEach(assign => {
                        if (assign.Lesson && assign.Lesson.Class) {
                            const classId = assign.Lesson.Class.Id;
                            if (!groupedAssignments[classId]) {
                                groupedAssignments[classId] = {
                                    Class: assign.Lesson.Class,
                                    List: []
                                };
                            }
                            groupedAssignments[classId].List.push(assign);
                        }
                    });
                    const groups = Object.values(groupedAssignments);
                %>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <% groups.forEach(group => { %>
                        <% const cls = group.Class; %>
                        <% const classAssignments = group.List; %>
                        <div style="background-color: var(--white); border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
                            <div onclick="toggleAssignmentClass(<%= cls.Id %>)" style="background-color: #F8FAFC; padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: center; cursor: pointer; border-bottom: 1px solid var(--border-color); transition: background-color 0.2s;">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 1.05rem; font-weight: 700; color: var(--text-dark);"><i class="fa-solid fa-folder-open" style="color: #2563EB; margin-right: 0.25rem;"></i> <%= cls.ClassName %></span>
                                    <span class="badge-custom badge-info" style="font-size: 0.75rem; padding: 0.2rem 0.5rem; font-weight: 600;"><%= classAssignments.length %> bài tập đã giao</span>
                                </div>
                                <i class="fa-solid fa-chevron-down" id="arrow-class-<%= cls.Id %>" style="transition: transform 0.2s; color: var(--text-muted);"></i>
                            </div>
                            
                            <div id="assign-class-<%= cls.Id %>" style="display: none; padding: 1.5rem; background-color: var(--white);">
                                <div class="table-wrapper" style="margin: 0;">
                                    <table class="table-custom">
                                        <thead>
                                            <tr>
                                                <th>Tên bài tập</th>
                                                <th>Buổi học</th>
                                                <th>Hạn nộp bài</th>
                                                <th>Hình thức</th>
                                                <th>Đã nộp</th>
                                                <th style="text-align: right;">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% classAssignments.forEach(assign => { %>
                                                <% const submitted = (typeof submissionCounts !== 'undefined' && submissionCounts) ? (submissionCounts[assign.Id] || 0) : 0; %>
                                                <tr>
                                                    <td><strong><%= assign.Title %></strong></td>
                                                    <td><%= assign.Lesson ? assign.Lesson.Title : '' %></td>
                                                    <td><%= new Date(assign.DueDate).toLocaleString('vi-VN') %></td>
                                                     <td>
                                                        <span class="badge-custom <%= assign.AssignmentType === 0 ? 'badge-info' : assign.AssignmentType === 2 ? 'badge-success' : assign.AssignmentType === 3 ? 'badge-warning' : 'badge-default' %>">
                                                            <%= assign.AssignmentType === 0 ? 'Trắc nghiệm' : assign.AssignmentType === 2 ? 'Đúng/Sai' : assign.AssignmentType === 3 ? 'Kiểm tra' : 'Tự luận' %>
                                                        </span>
                                                     </td>
                                                    <td><strong style="color: #2563EB;"><%= submitted %></strong> học viên nộp</td>
                                                    <td style="text-align: right;">
                                                        <a href="/Teacher/Submissions/<%= assign.Id %>" class="btn-custom" style="font-size: 0.8rem; padding: 0.4rem 0.75rem; text-decoration: none;">
                                                            <i class="fa-solid fa-graduation-cap"></i> Xem & Chấm điểm
                                                        </a>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Tab: Bài kiểm tra -->
        <div class="tab-content" id="tabExams">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
                <h2 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark); margin: 0;"><i class="fa-solid fa-file-circle-check" style="color: #7C3AED;"></i> Bài Kiểm Tra Lớp Học</h2>
                <span style="font-size: 0.85rem; color: var(--text-muted);">Kiểm tra 15 phút, 1 tiết, học kỳ...</span>
            </div>

            <% if (typeof classes !== 'undefined' && classes.length > 0) { %>
                <!-- Quick create buttons per class -->
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
                    <% classes.forEach(c => { %>
                    <a href="/Teacher/CreateExam/<%= c.Id %>" style="display: flex; align-items: center; gap: 0.75rem; background: linear-gradient(135deg, #EDE9FE, #DDD6FE); border: 1px solid #A78BFA; border-radius: var(--radius-lg); padding: 1rem 1.25rem; text-decoration: none; transition: all 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
                        <div style="width: 40px; height: 40px; background: #7C3AED; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="fa-solid fa-plus" style="color: #fff; font-size: 1.1rem;"></i>
                        </div>
                        <div>
                            <div style="font-weight: 700; color: #5B21B6; font-size: 0.9rem;"><%= c.ClassName %></div>
                            <div style="font-size: 0.78rem; color: #7C3AED;">Tạo bài kiểm tra mới</div>
                        </div>
                    </a>
                    <% }) %>
                </div>
            <% } %>

            <% 
                const examAssignments = typeof assignments !== 'undefined' ? assignments.filter(a => a.AssignmentType === 3) : [];
            %>

            <% if (examAssignments.length === 0) { %>
                <div style="background: var(--white); border: 1px dashed var(--border-color); padding: 3rem 2rem; text-align: center; color: var(--text-muted); border-radius: var(--radius-lg);">
                    <i class="fa-solid fa-file-circle-check" style="font-size: 2rem; margin-bottom: 0.75rem; display: block; color: #A78BFA;"></i>
                    Chưa có bài kiểm tra nào. Nhấn <strong>"Tạo bài kiểm tra mới"</strong> ở trên để bắt đầu.
                </div>
            <% } else { %>
                <% 
                    const groupedExams = {};
                    examAssignments.forEach(assign => {
                        if (assign.Lesson && assign.Lesson.Class) {
                            const classId = assign.Lesson.Class.Id;
                            if (!groupedExams[classId]) {
                                groupedExams[classId] = { Class: assign.Lesson.Class, List: [] };
                            }
                            groupedExams[classId].List.push(assign);
                        }
                    });
                    const examGroups = Object.values(groupedExams);
                %>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <% examGroups.forEach(group => { %>
                        <% const ecls = group.Class; %>
                        <div style="background: var(--white); border: 1px solid #A78BFA; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">
                            <div onclick="toggleExamClass(<%= ecls.Id %>)" style="background: #F5F3FF; padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; align-items: center; cursor: pointer; border-bottom: 1px solid #DDD6FE;">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 1rem; font-weight: 700; color: #5B21B6;"><i class="fa-solid fa-folder-open" style="color: #7C3AED; margin-right: 0.25rem;"></i> <%= ecls.ClassName %></span>
                                    <span class="badge-custom badge-info" style="background: #EDE9FE; color: #5B21B6; border-color: #A78BFA; font-size: 0.75rem;"><%= group.List.length %> bài kiểm tra</span>
                                </div>
                                <i class="fa-solid fa-chevron-down" id="arrow-exam-<%= ecls.Id %>" style="transition: transform 0.2s; color: #7C3AED;"></i>
                            </div>
                            <div id="exam-class-<%= ecls.Id %>" style="display: none; padding: 1.5rem; background: var(--white);">
                                <div class="table-wrapper" style="margin: 0;">
                                    <table class="table-custom">
                                        <thead><tr><th>Tiêu đề</th><th>Hình thức</th><th>Thời gian thi</th><th>Đã nộp</th><th style="text-align:right;">Thao tác</th></tr></thead>
                                        <tbody>
                                            <% group.List.forEach(assign => { %>
                                                <% const submitted = (typeof submissionCounts !== 'undefined' && submissionCounts) ? (submissionCounts[assign.Id] || 0) : 0; %>
                                                <tr>
                                                    <td><strong><%= assign.Title %></strong></td>
                                                    <td><span class="badge-custom" style="background:#EDE9FE;color:#5B21B6;">📋 Kiểm tra</span></td>
                                                    <td><%= new Date(assign.DueDate).toLocaleString('vi-VN') %></td>
                                                    <td><strong style="color: #7C3AED;"><%= submitted %></strong> nộp</td>
                                                    <td style="text-align:right;">
                                                        <a href="/Teacher/Submissions/<%= assign.Id %>" class="btn-custom" style="font-size:0.8rem;padding:0.4rem 0.75rem;text-decoration:none;background:#7C3AED;">
                                                            <i class="fa-solid fa-graduation-cap"></i> Xem & Chấm
                                                        </a>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Tab: Tiến độ học tập các khóa học -->
        <div class="tab-content" id="tabCourseProgress">
            <div class="chart-container-custom">
                <div class="chart-header" style="margin-bottom: 1.5rem;">
                    <span class="chart-title"><i class="fa-solid fa-chart-pie" style="color: #2563EB;"></i> Tiến trình dạy các khóa học được phân công</span>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
                    <% if (typeof classes !== 'undefined' && classes.length > 0) { %>
                        <% classes.forEach(c => { %>
                            <% 
                                const total = c.Course ? c.Course.TotalLessons : 12;
                                const finished = (typeof lessons !== 'undefined') ? lessons.filter(l => l.ClassId === c.Id && l.Status === 2).length : 0;
                                const progressPercent = total > 0 ? (finished / total * 100) : 0;
                            %>
                            <div style="background-color: var(--white); border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between; gap: 1rem;">
                                <div>
                                    <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--text-dark);"><%= c.ClassName %></h3>
                                    <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                        <span>Khóa học: <strong><%= c.Course ? c.Course.Title : '' %></strong></span>
                                        <% if (c.Course) { %>
                                        <button type="button" 
                                            style="font-size: 0.75rem; padding: 0.2rem 0.5rem; line-height: 1; border: 1px solid #93C5FD; color: #3B82F6; border-radius: var(--radius-sm); background: transparent; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem;"
                                            data-id="<%= c.Course.Id %>"
                                            data-code="<%= c.Course.CourseCode %>"
                                            data-title="<%= c.Course.Title %>"
                                            data-desc="<%= c.Course.Description || '' %>"
                                            data-price="<%= c.Course.BasePrice %>"
                                            data-lessons="<%= c.Course.TotalLessons %>"
                                            data-tags="<%= c.Course.MetadataTags || '' %>"
                                            data-image="<%= c.Course.ImageUrl || '' %>"
                                            onclick="handleEditCourseClick(this)">
                                            <i class="fa-solid fa-pen-to-square"></i> Sửa khóa học
                                        </button>
                                        <% } %>
                                    </p>
                                    
                                    <div style="margin-top: 1rem;">
                                        <div style="display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.25rem;">
                                            <span>Đã dạy: <%= finished %> / <%= total %> buổi</span>
                                            <span><%= progressPercent.toFixed(0) %>% hoàn thành</span>
                                        </div>
                                        <div style="background-color: var(--border-color); height: 8px; border-radius: 4px; overflow: hidden; width: 100%;">
                                            <div style="background-color: #2563EB; width: <%= progressPercent.toFixed(0) %>%; height: 100%;"></div>
                                        </div>
                                    </div>
                                </div>
                                <div style="border-top: 1px solid var(--border-color); padding-top: 0.75rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
                                    <span style="font-size: 0.8rem; color: var(--text-muted);">Khai giảng: <%= new Date(c.StartDate).toLocaleDateString('vi-VN') %></span>
                                    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                                        <a href="/Teacher/CreateExam/<%= c.Id %>" class="btn-custom" style="font-size: 0.78rem; padding: 0.35rem 0.75rem; text-decoration: none; background: linear-gradient(135deg, #7C3AED, #5B21B6);">
                                            <i class="fa-solid fa-file-circle-check"></i> Tạo bài kiểm tra
                                        </a>
                                        <a href="/Teacher/ClassReport/<%= c.Id %>" class="btn-secondary-custom" style="font-size: 0.78rem; padding: 0.35rem 0.75rem; text-decoration: none;"><i class="fa-solid fa-chart-line"></i> Chi tiết AI</a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Tab: Khóa Học Của Tôi -->
        <div class="tab-content" id="tabMyCourses">
            <div class="chart-container-custom">
                <div class="chart-header" style="justify-content: space-between; margin-bottom: 1.5rem;">
                    <span class="chart-title"><i class="fa-solid fa-book-open" style="color: #2563EB;"></i> Khóa Học Của Tôi</span>
                </div>

                <% 
                    const myCourses = [];
                    const myCourseIds = new Set();
                    if (typeof classes !== 'undefined' && classes.length > 0) {
                        classes.forEach(c => {
                            if (c.Course && !myCourseIds.has(c.Course.Id)) {
                                myCourseIds.add(c.Course.Id);
                                myCourses.push(c.Course);
                            }
                        });
                    }
                %>

                <div class="table-wrapper">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>Mã Khóa</th>
                                <th>Tên Khóa Học</th>
                                <th>Số Buổi</th>
                                <th>Học Phí Gốc</th>
                                <th style="text-align: right;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (myCourses.length > 0) { %>
                                <% myCourses.forEach(c => { %>
                                    <tr>
                                        <td style="font-weight: 600;"><%= c.CourseCode %></td>
                                        <td>
                                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                                <% if (c.ImageUrl) { %>
                                                    <img src="<%= c.ImageUrl %>" alt="<%= c.Title %>" style="width: 50px; height: 35px; border-radius: 4px; object-fit: cover; border: 1px solid #E2E8F0;" />
                                                <% } else { %>
                                                    <div style="width: 50px; height: 35px; border-radius: 4px; background: #F1F5F9; display: flex; align-items: center; justify-content: center; color: #94A3B8; font-size: 0.75rem; border: 1px solid #E2E8F0;"><i class="fa-regular fa-image"></i></div>
                                                <% } %>
                                                <strong><%= c.Title %></strong>
                                            </div>
                                        </td>
                                        <td><%= c.TotalLessons %> buổi</td>
                                        <td><%= Number(c.BasePrice).toLocaleString("vi-VN") %> đ</td>
                                        <td style="text-align: right;">
                                            <button type="button" 
                                                style="padding: 0.35rem 0.75rem; border: 1px solid #93C5FD; color: #3B82F6; border-radius: var(--radius-sm); background: transparent; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.78rem; font-weight: 700;"
                                                data-id="<%= c.Id %>"
                                                data-code="<%= c.CourseCode %>"
                                                data-title="<%= c.Title %>"
                                                data-desc="<%= c.Description || '' %>"
                                                data-price="<%= c.BasePrice %>"
                                                data-lessons="<%= c.TotalLessons %>"
                                                data-tags="<%= c.MetadataTags || '' %>"
                                                data-image="<%= c.ImageUrl || '' %>"
                                                onclick="handleEditCourseClick(this)">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                                Sửa
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 2rem;">Bạn chưa có khóa học nào được phân công.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab: Đánh giá KPI học viên -->
        <div class="tab-content" id="tabStudentKpi">
            <div class="chart-container-custom">
                <div class="chart-header" style="margin-bottom: 1.5rem;">
                    <span class="chart-title"><i class="fa-solid fa-user-graduate" style="color: #2563EB;"></i> Chỉ số chất lượng học tập của Học Viên (KPI)</span>
                </div>
                <div class="table-wrapper">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>Học viên</th>
                                <th>Điểm TB bài tập</th>
                                <th>Tỉ lệ nộp bài</th>
                                <th>Tỉ lệ đi học (Chuyên cần)</th>
                                <th>Xếp loại học lực</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof studentKpis !== 'undefined' && studentKpis.length > 0) { %>
                                <% studentKpis.forEach(sk => { %>
                                    <tr>
                                        <td><strong><%= sk.FullName %></strong></td>
                                        <td style="font-weight: 700; color: <%= sk.AverageGrade >= 8 ? '#10B981' : sk.AverageGrade >= 5 ? '#F59E0B' : '#EF4444' %>">
                                            <%= Number(sk.AverageGrade).toFixed(1) %> / 10
                                        </td>
                                        <td><%= (sk.AssignmentCompletionRate * 100).toFixed(0) %>%</td>
                                        <td><%= (sk.AttendanceRate * 100).toFixed(0) %>%</td>
                                        <td>
                                            <span class="badge-custom <%= sk.Status === 'Hoàn thành tốt' ? 'badge-success' : sk.Status === 'Ổn định' ? 'badge-info' : 'badge-danger' %>">
                                                <%= sk.Status %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">Chưa có dữ liệu đánh giá học lực học sinh.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab: Đánh giá KPI giảng viên -->
        <div class="tab-content" id="tabTeacherKpi">
            <div class="chart-container-custom">
                <div class="chart-header" style="margin-bottom: 1.5rem;">
                    <span class="chart-title"><i class="fa-solid fa-award" style="color: #2563EB;"></i> Chỉ số hiệu suất giảng dạy cá nhân (KPI Giảng viên)</span>
                </div>

                <div class="stats-grid" style="margin-bottom: 2rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
                    <div class="stat-card" style="background: white; padding: 1.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
                        <span class="stat-title" style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;"><i class="fa-solid fa-calendar-check"></i> Số buổi dạy hoàn thành</span>
                        <span class="stat-value" style="display: block; font-size: 1.8rem; font-weight: 800; color: var(--text-dark);"><%= typeof teacherLessonsTaught !== 'undefined' ? teacherLessonsTaught : 0 %> buổi</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted); display: block; margin-top: 0.25rem;">Đã ghi nhận trên hệ thống</span>
                    </div>

                    <div class="stat-card" style="background: white; padding: 1.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
                        <span class="stat-title" style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;"><i class="fa-solid fa-users"></i> Chuyên cần lớp trung bình</span>
                        <span class="stat-value" style="display: block; font-size: 1.8rem; font-weight: 800; color: #10B981;"><%= typeof teacherAvgAttendance !== 'undefined' ? (teacherAvgAttendance * 100).toFixed(0) : 100 %>%</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted); display: block; margin-top: 0.25rem;">Số lượng học sinh đi học đầy đủ</span>
                    </div>

                    <div class="stat-card" style="background: white; padding: 1.5rem; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);">
                        <span class="stat-title" style="display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem;"><i class="fa-solid fa-book"></i> Lớp học phụ trách</span>
                        <span class="stat-value" style="display: block; font-size: 1.8rem; font-weight: 800; color: var(--text-dark);"><%= typeof classes !== 'undefined' ? classes.length : 0 %> lớp</span>
                        <span style="font-size: 0.8rem; color: var(--text-muted); display: block; margin-top: 0.25rem;">Đang hoạt động tích cực</span>
                    </div><!-- end stat-card lop hoc -->
                </div><!-- end stats grid -->

                <div style="background-color: #EFF6FF; padding: 1.5rem; border-radius: var(--radius-lg); margin-top: 1.5rem;">
                    <h4 style="font-weight: 700; color: #1E40AF; margin-bottom: 0.5rem;"><i class="fa-solid fa-robot"></i> Đánh giá chất lượng từ hệ thống AI</h4>
                    <p style="font-size: 0.95rem; color: #1E3A8A; line-height: 1.5; margin: 0;">
                        Giáo viên hoàn thành tốt chỉ tiêu giảng dạy lớp học. Tỉ lệ chuyên cần trung bình của học viên đạt <strong><%= typeof teacherAvgAttendance !== 'undefined' ? (teacherAvgAttendance * 100).toFixed(0) : 100 %>%</strong>.
                        Tích cực giao bài tập về nhà và thực hiện chấm điểm đúng thời hạn. Hãy tiếp tục duy trì kết quả giảng dạy hiện tại!
                    </p>
                </div>

            </div><!-- Closes tabTeacherKpi chart-container -->
        </div><!-- Closes tabTeacherKpi tab-content -->

        <!-- Tab: Thông tin giới thiệu -->
        <div class="tab-content" id="tabTeacherProfile" style="display:none;">
            <!-- Presentation Mode: Preview card exactly as shown on public page -->
            <div id="profileViewContainer" style="display: block;">
                <div style="display: grid; grid-template-columns: 350px 1fr; gap: 2.5rem; align-items: start; background: white; padding: 2rem; border-radius: 16px; border: 1px solid #E2E8F0; box-shadow: 0 4px 20px rgba(0,0,0,0.05); position: relative;">
                    
                    <!-- LEFT COLUMN: Public teacher card preview -->
                    <div>
                        <p style="font-size: 0.8rem; font-weight: 700; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.85rem 0; text-align: center;"><i class="fa-solid fa-eye"></i> Xem trước card công khai</p>
                        
                        <div style="background: white; border: 1px solid #E8EAF0; border-radius: 16px; padding: 2.25rem 1.75rem 1.75rem; text-align: center; box-shadow: 0 4px 15px rgba(30,27,75,0.06); position: relative;">
                            <!-- Avatar + badge -->
                            <div style="position: relative; display: inline-block; margin-bottom: 1.25rem;">
                                <div style="width: 120px; height: 120px; border-radius: 50%; border: 4px solid rgba(79,70,229,0.12); overflow: hidden; background: #EEF2F6; margin: 0 auto; cursor: pointer; position: relative;"
                                     onclick="openAvatarEditor()" title="Nhấp để chỉnh sửa ảnh" id="viewAvatarWrapper">
                                    <% if (typeof teacherUser !== 'undefined' && teacherUser && teacherUser.AvatarUrl) { %>
                                            <img id="viewAvatarImg" src="<%= teacherUser.AvatarUrl %>" style="width:100%; height:100%; object-fit:cover;">
                                    <% } else { %>
                                            <div id="viewAvatarInitial" style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:3.2rem; font-weight:800; color:#4F46E5; background:#E0E7FF;">
                                                <%= typeof teacherUser !== 'undefined' && teacherUser && teacherUser.FullName ? teacherUser.FullName.charAt(0).toUpperCase() : 'G' %>
                                            </div>
                                    <% } %>
                                    <div id="viewAvatarHover" style="position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.4);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s;pointer-events:none;">
                                        <i class="fa-solid fa-pen" style="color:white;font-size:1.2rem;"></i>
                                    </div>
                                </div>
                                <span id="viewSubjectBadge" style="position:absolute; bottom:-8px; left:50%; transform:translateX(-50%); background:#4F46E5; color:white; font-size:0.75rem; font-weight:700; padding:3px 12px; border-radius:999px; white-space:nowrap; box-shadow:0 3px 10px rgba(79,70,229,0.35);">
                                    <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.Subject ? teacherProfile.Subject : 'Chưa cập nhật' %>
                                </span>
                            </div>

                            <!-- Name & title -->
                            <h3 id="viewName" style="font-size: 1.25rem; font-weight: 850; color: #4F46E5; margin: 0.8rem 0 0.25rem 0;">
                                <%= typeof teacherUser !== 'undefined' && teacherUser && teacherUser.FullName ? teacherUser.FullName : '' %>
                            </h3>
                            <p id="viewTitle" style="font-size: 0.88rem; font-weight: 700; color: #64748B; margin: 0 0 1.25rem 0;">
                                <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherTitle ? teacherProfile.TeacherTitle : 'Giáo viên tiêu biểu' %>
                            </p>

                            <!-- Bio -->
                            <p id="viewBioVal" style="font-size: 0.82rem; color: #64748B; line-height: 1.6; margin: 0 0 1.5rem 0; text-align: left; white-space: pre-line;">
                                <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherBio ? teacherProfile.TeacherBio : 'Giảng viên giàu kinh nghiệm ôn luyện và bồi dưỡng kiến thức toàn diện cho các em học viên.' %>
                            </p>

                            <!-- Stats row -->
                            <div style="border-top: 1px solid #F1F5F9; padding-top: 1.15rem; display: flex; justify-content: space-between; gap: 0.5rem;">
                                <div style="flex:1; text-align:center;">
                                    <span id="viewExpVal" style="display:block; font-size:1.3rem; font-weight:850; color:#4F46E5;">
                                        <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherExperience !== null ? teacherProfile.TeacherExperience : 5 %>+
                                    </span>
                                    <span style="font-size:0.7rem; color:#94A3B8; text-transform:uppercase; font-weight:700; letter-spacing:0.04em;">Năm KN</span>
                                </div>
                                <div style="flex:1; text-align:center;">
                                    <span id="viewStudentsVal" style="display:block; font-size:1.3rem; font-weight:850; color:#4F46E5;">
                                        <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherStudents !== null ? teacherProfile.TeacherStudents : 100 %>+
                                    </span>
                                    <span style="font-size:0.7rem; color:#94A3B8; text-transform:uppercase; font-weight:700; letter-spacing:0.04em;">Học sinh</span>
                                </div>
                                <div style="flex:1; text-align:center;">
                                    <span style="display:block; font-size:1.3rem; font-weight:850; color:#4F46E5;">
                                        <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherRating !== null ? parseFloat(teacherProfile.TeacherRating).toFixed(1) : '4.8' %> ⭐
                                    </span>
                                    <span style="font-size:0.7rem; color:#94A3B8; text-transform:uppercase; font-weight:700; letter-spacing:0.04em;">Đánh giá</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: Detailed information layout to fill space -->
                    <div style="flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; min-height: 440px;">
                        <div>
                            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #dac2b6; padding-bottom: 0.75rem; margin-bottom: 1.5rem;">
                                <h3 style="font-size: 1.2rem; font-weight: 850; color: #1E1B4B; margin: 0;"><i class="fa-solid fa-address-card" style="color: #4F46E5;"></i> Hồ Sơ Giảng Viên Chi Tiết</h3>
                                <button class="btn-custom" onclick="showProfileEditMode()" style="padding: 0.45rem 1rem; font-size: 0.83rem; background: linear-gradient(135deg, #4F46E5, #7C3AED); border-radius: 8px; font-weight: 700; display: inline-flex; align-items: center; gap: 0.4rem; border: none;">
                                    <i class="fa-solid fa-pen-to-square"></i> Chỉnh sửa thông tin
                                </button>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.5rem;">
                                <div style="background: #faf8f0; padding: 0.85rem 1.1rem; border-radius: 10px; border: 1px solid #dac2b6;">
                                    <span style="font-size: 0.7rem; color: #94A3B8; text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 0.25rem;">Họ và Tên</span>
                                    <span style="font-size: 0.95rem; font-weight: 750; color: #1E1B4B;"><%= typeof teacherUser !== 'undefined' && teacherUser ? teacherUser.FullName : '' %></span>
                                </div>
                                <div style="background: #faf8f0; padding: 0.85rem 1.1rem; border-radius: 10px; border: 1px solid #dac2b6;">
                                    <span style="font-size: 0.7rem; color: #94A3B8; text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 0.25rem;">Môn giảng dạy chính</span>
                                    <span style="font-size: 0.95rem; font-weight: 750; color: #1E1B4B;"><%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.Subject ? teacherProfile.Subject : 'Chưa thiết lập' %></span>
                                </div>
                            </div>

                            <div style="background: #faf8f0; padding: 1.1rem; border-radius: 10px; border: 1px solid #dac2b6; margin-bottom: 1.5rem;">
                                <span style="font-size: 0.7rem; color: #94A3B8; text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 0.4rem;">Tiểu sử & Phương châm giảng dạy</span>
                                <p id="viewBioValDetail" style="font-size: 0.88rem; color: #334155; line-height: 1.65; margin: 0; white-space: pre-line; font-weight: 500;">
                                    <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherBio ? teacherProfile.TeacherBio : 'Giảng viên chưa cập nhật thông tin giới thiệu.' %>
                                </p>
                            </div>

                        </div>

                        <p style="font-size:0.75rem; color:#94A3B8; margin-top: 1.5rem; text-align: left; border-top: 1px dashed #E2E8F0; padding-top: 0.75rem;">
                            <i class="fa-solid fa-circle-info"></i> Bản xem trước giúp bạn thấy được giao diện thẻ hiển thị của mình trên danh sách giáo viên công khai của hệ thống.
                        </p>
                    </div>

                </div>
            </div>

            <!-- Edit Mode Container -->
            <div id="profileEditContainer" style="display: none;">
                <div class="chart-container-custom" style="padding: 2.5rem; border-radius: 16px; border: 1px solid #E2E8F0;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid #F1F5F9; padding-bottom: 1rem;">
                        <span class="chart-title" style="font-size: 1.25rem;"><i class="fa-solid fa-pen-to-square" style="color: #4F46E5;"></i> Cập Nhật Hồ Sơ Giảng Viên</span>
                        <button class="btn-secondary-custom" onclick="hideProfileEditMode()" style="padding: 0.5rem 1rem; font-size: 0.85rem;">
                            <i class="fa-solid fa-arrow-left"></i> Quay lại
                        </button>
                    </div>

                    <!-- Two-column layout: Form LEFT, Preview RIGHT -->
                    <div style="display: grid; grid-template-columns: 1fr 320px; gap: 2.5rem; align-items: start;">

                        <!-- LEFT: Form -->
                        <form id="formTeacherPublicProfile" onsubmit="submitTeacherProfile(event)" enctype="multipart/form-data">
                            
                            <!-- Row 1: Full Name and Avatar File Upload Input -->
                            <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Họ và Tên <span style="color: #EF4444;">*</span></label>
                                    <input type="text" class="form-input-custom" name="fullName"
                                        value="<%= typeof teacherUser !== 'undefined' && teacherUser ? teacherUser.FullName : '' %>"
                                        placeholder="Nhập họ và tên giảng viên..." required>
                                </div>
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Ảnh đại diện</label>
                                    <input type="hidden" id="removeAvatarFlag" name="removeAvatar" value="">
                                    <!-- Hidden real file input -->
                                    <input type="file" id="avatarFileInput" name="avatarFile" accept="image/*"
                                        onchange="previewAvatarImage(this)" style="display:none;">

                                    <%
                                        const hasAvatar = typeof teacherUser !== 'undefined' && teacherUser && teacherUser.AvatarUrl;
                                        const savedAvatarUrl = hasAvatar ? teacherUser.AvatarUrl : '';
                                        const savedAvatarName = hasAvatar ? teacherUser.AvatarUrl.split('/').pop() : '';
                                    %>

                                    <!-- Custom file picker row — looks like native file input -->
                                    <div style="display:flex; align-items:center; border:1px solid #CBD5E1; border-radius:6px; overflow:hidden; background:white; font-size:0.85rem; height:36px;">
                                        <!-- "Chọn tệp" trigger button -->
                                        <label for="avatarFileInput"
                                            style="flex-shrink:0; cursor:pointer; background:#F1F5F9; border-right:1px solid #CBD5E1; padding:0 0.75rem; height:100%; display:flex; align-items:center; font-size:0.82rem; color:#374151; font-weight:500; white-space:nowrap; user-select:none;">
                                            Chọn tệp
                                        </label>
                                        <!-- Filename display -->
                                        <span id="avatarFileName" style="flex:1; padding:0 0.6rem; color:#64748B; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            <%= savedAvatarName || 'Chưa chọn tệp nào' %>
                                        </span>
                                        <!-- Red X — only visible when file/avatar exists -->
                                        <button type="button" id="avatarClearBtn" onclick="clearAvatarFile()"
                                            style="display:<%= hasAvatar ? 'flex' : 'none' %>; flex-shrink:0; align-items:center; justify-content:center; background:#EF4444; border:none; color:white; width:20px; height:20px; border-radius:3px; font-size:0.65rem; font-weight:900; cursor:pointer; margin-right:0.4rem; padding:0;"
                                            title="Xóa ảnh">✕</button>
                                    </div>
                                </div>
                            </div>

                            <!-- Row 2: Title and Subject -->
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Học vị</label>
                                    <input type="text" class="form-input-custom" name="teacherTitle"
                                        value="<%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherTitle ? teacherProfile.TeacherTitle : '' %>"
                                        placeholder="Ví dụ: Thạc sĩ, Tiến sĩ...">
                                </div>
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Môn giảng dạy chính</label>
                                    <input type="text" class="form-input-custom" name="subject"
                                        value="<%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.Subject ? teacherProfile.Subject : '' %>"
                                        placeholder="Ví dụ: Toán học, Vật lý...">
                                </div>
                            </div>

                            <!-- Row 3: Experience and Students (Rating is completely removed!) -->
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem;">
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Số năm kinh nghiệm</label>
                                    <input type="number" class="form-input-custom" name="teacherExperience" min="0" max="60"
                                        value="<%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherExperience !== null ? teacherProfile.TeacherExperience : 5 %>">
                                </div>
                                <div class="form-group-custom">
                                    <label class="form-label-custom">Số học sinh đã dạy</label>
                                    <input type="number" class="form-input-custom" name="teacherStudents" min="0"
                                        value="<%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherStudents !== null ? teacherProfile.TeacherStudents : 100 %>">
                                </div>
                            </div>

                            <!-- Row 4: Bio -->
                            <div class="form-group-custom" style="margin-bottom: 1.75rem;">
                                <label class="form-label-custom">Tiểu sử & Giới thiệu ngắn</label>
                                <textarea class="form-input-custom" name="teacherBio" rows="12"
                                    style="resize: vertical; font-size: 0.9rem; line-height: 1.5;"
                                    placeholder="Viết vài dòng giới thiệu về bản thân, thành tích nổi bật, phương pháp giảng dạy..."><%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherBio ? teacherProfile.TeacherBio : '' %></textarea>
                            </div>

                            <!-- Hidden items -->
                            <input type="hidden" name="phone" value="<%= typeof teacherUser !== 'undefined' && teacherUser ? teacherUser.Phone : '' %>">

                            <div style="display: flex; justify-content: flex-end; gap: 0.75rem;">
                                <button type="button" class="btn-secondary-custom" onclick="hideProfileEditMode()" style="padding: 0.75rem 1.5rem;">Hủy</button>
                                <button type="submit" id="btnSaveTeacherProfile" class="btn-custom" style="padding: 0.75rem 1.75rem; display: flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, #4F46E5, #7C3AED); border: none;">
                                    <i class="fa-solid fa-floppy-disk"></i> Lưu hồ sơ công khai
                                </button>
                            </div>
                        </form>

                        <!-- RIGHT: Live Preview Card (Without Rating) -->
                        <div>
                            <p style="font-size: 0.78rem; font-weight: 700; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.75rem 0;">Xem trước trên trang chủ</p>
                            <div id="teacherPreviewCard" style="background: white; border: 1px solid #E2E8F0; border-radius: 14px; padding: 1.75rem; text-align: center; box-shadow: 0 4px 20px rgba(30,58,138,0.08); transition: all 0.3s; position: relative;">
                                <div style="position: relative; display: inline-block; margin-bottom: 1.25rem;">
                                    <!-- Avatar container is clickable to open crop editor -->
                                    <div style="position: relative; width: 88px; height: 88px; border-radius: 50%; border: 3px solid rgba(79, 70, 229, 0.15); overflow: hidden; background: #EEF2F6; margin: 0 auto; cursor: pointer;" 
                                         onclick="openAvatarEditor()"
                                         id="previewAvatarContainer"
                                         title="Nhấp để chỉnh sửa ảnh">
                                        <% if (typeof teacherUser !== 'undefined' && teacherUser && teacherUser.AvatarUrl) { %>
                                            <img id="previewAvatarImg" src="<%= teacherUser.AvatarUrl %>" style="width: 100%; height: 100%; object-fit: cover;">
                                            <div id="previewAvatarInitial" style="width:100%;height:100%;display:none;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;color:#4F46E5;">
                                                <%= typeof teacherUser !== 'undefined' && teacherUser && teacherUser.FullName ? teacherUser.FullName.charAt(0).toUpperCase() : 'G' %>
                                            </div>
                                        <% } else { %>
                                            <img id="previewAvatarImg" src="" style="width: 100%; height: 100%; object-fit: cover; display: none;">
                                            <div id="previewAvatarInitial" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;color:#4F46E5;">
                                                <%= typeof teacherUser !== 'undefined' && teacherUser && teacherUser.FullName ? teacherUser.FullName.charAt(0).toUpperCase() : 'G' %>
                                            </div>
                                        <% } %>
                                        <!-- Hover Overlay to edit preview avatar -->
                                        <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.4); display: none; align-items: center; justify-content: center; color: white; border-radius: 50%;" id="previewAvatarHoverOverlay">
                                            <i class="fa-solid fa-pencil" style="font-size: 1.1rem;"></i>
                                        </div>
                                    </div>
                                    <span id="previewSubjectBadge" style="position:absolute;bottom:-6px;left:50%;transform:translateX(-50%);background:#4F46E5;color:white;font-size:0.68rem;font-weight:700;padding:3px 10px;border-radius:999px;white-space:nowrap;box-shadow: 0 2px 6px rgba(79, 70, 229, 0.2);">
                                        <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.Subject ? teacherProfile.Subject : 'Môn học' %>
                                    </span>
                                </div>
                                <h3 id="previewName" style="font-size: 0.95rem; font-weight: 800; color: #1E1B4B; margin: 0.75rem 0 0.2rem 0;">
                                    <%= typeof teacherUser !== 'undefined' && teacherUser && teacherUser.FullName ? teacherUser.FullName : '' %>
                                </h3>
                                <p id="previewTitle" style="font-size: 0.78rem; font-weight: 700; color: #4F46E5; margin: 0 0 0.5rem 0;">
                                    <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherTitle ? teacherProfile.TeacherTitle : 'Thạc sĩ' %>
                                </p>
                                <p id="previewBio" style="font-size: 0.78rem; color: #64748B; line-height: 1.5; margin: 0 0 1rem 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-align: left;">
                                    <%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherBio ? teacherProfile.TeacherBio : 'Giảng viên giàu kinh nghiệm tại trung tâm.' %>
                                </p>
                                <div style="display: flex; justify-content: space-around; border-top: 1px solid #F1F5F9; padding-top: 0.75rem;">
                                    <div style="text-align:center; flex: 1;">
                                        <span id="previewExp" style="display:block;font-size:1rem;font-weight:800;color:#4F46E5;"><%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherExperience !== null ? teacherProfile.TeacherExperience : 5 %>+</span>
                                        <span style="font-size:0.62rem;color:#94a3b8;text-transform:uppercase;font-weight:600;">Năm KN</span>
                                    </div>
                                    <div style="width: 1px; background: #F1F5F9; margin: 0 5px;"></div>
                                    <div style="text-align:center; flex: 1;">
                                        <span id="previewStudents" style="display:block;font-size:1rem;font-weight:800;color:#4F46E5;"><%= typeof teacherProfile !== 'undefined' && teacherProfile && teacherProfile.TeacherStudents !== null ? teacherProfile.TeacherStudents : 100 %>+</span>
                                        <span style="font-size:0.62rem;color:#94a3b8;text-transform:uppercase;font-weight:600;">Học sinh</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div><!-- end two-column grid -->
                </div>
            </div>
        </div>

        </div> <!-- Closes teacher-content-body -->
    </div> <!-- Closes main-content -->
</div> <!-- Closes dashboard-layout -->

<!-- Modal: Thêm Buổi Học Mới -->
<div class="modal-custom" id="lessonModal" style="display: none; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15,23,42,0.6); z-index: 2000;">
    <div class="modal-content-custom" style="max-width: 520px; background: white; border-radius: var(--radius-lg); padding: 2rem; width: 90%;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="font-weight: 700; font-size: 1.25rem; margin: 0;">Thêm Buổi Học Mới</h3>
            <span style="cursor: pointer; font-size: 1.25rem;" onclick="closeModal('lessonModal')">&times;</span>
        </div>
        <form action="/Teacher/CreateLesson" method="post" enctype="multipart/form-data">
            <div class="form-group-custom">
                <label class="form-label-custom">Chọn Lớp Học</label>
                <select name="classId" class="form-input-custom" required>
                    <% if (typeof classes !== 'undefined') { %>
                        <% classes.forEach(c => { %>
                            <option value="<%= c.Id %>"><%= c.ClassName %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            
            <div class="form-group-custom">
                <label class="form-label-custom">Tên / Tiêu đề buổi học</label>
                <input type="text" name="title" class="form-input-custom" placeholder="Ví dụ: Buổi 5: Thực hành và thảo luận" required />
            </div>

            <div class="form-group-custom">
                <label class="form-label-custom">Ngày học</label>
                <input type="date" name="lessonDate" class="form-input-custom" value="<%= new Date().toISOString().slice(0, 10) %>" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group-custom">
                    <label class="form-label-custom">Giờ bắt đầu</label>
                    <input type="text" name="startTimeStr" class="form-input-custom" placeholder="HH:mm (ví dụ 18:00)" value="18:00" required />
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Giờ kết thúc</label>
                    <input type="text" name="endTimeStr" class="form-input-custom" placeholder="HH:mm (ví dụ 19:30)" value="19:30" required />
                </div>
            </div>
            
            <div class="form-group-custom">
                <label class="form-label-custom">Link phòng học online (Zoom, Meet,...)</label>
                <input type="url" name="meetingUrl" class="form-input-custom" placeholder="https://zoom.us/j/..." />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group-custom">
                    <label class="form-label-custom">ID Phòng học</label>
                    <input type="text" name="meetingId" class="form-input-custom" placeholder="Ví dụ: 999 888 777" />
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Mật khẩu (Passcode)</label>
                    <input type="text" name="meetingPassword" class="form-input-custom" placeholder="Ví dụ: 123" />
                </div>
            </div>

            <div class="form-group-custom" style="margin-bottom: 1.5rem;">
                <label class="form-label-custom">Tài liệu đính kèm (PDF, Word, Excel, Hình ảnh...)</label>
                <input type="file" name="document" class="form-input-custom" />
            </div>

            <button type="submit" class="btn-custom" style="width: 100%;"><i class="fa-solid fa-save"></i> Thêm Buổi Học</button>
        </form>
    </div>
</div>
 
<!-- Modal: Sửa Buổi Học -->
<div class="modal-custom" id="editLessonModal" style="display: none; align-items: center; justify-content: center; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15,23,42,0.6); z-index: 2000;">
    <div class="modal-content-custom" style="max-width: 520px; background: white; border-radius: var(--radius-lg); padding: 2rem; width: 90%;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="font-weight: 700; font-size: 1.25rem; margin: 0;">Cập Nhật Thông Tin Buổi Học</h3>
            <span style="cursor: pointer; font-size: 1.25rem;" onclick="closeModal('editLessonModal')">&times;</span>
        </div>
        <form action="/Teacher/UpdateLesson" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id" id="editLessonId" />
            
            <div class="form-group-custom">
                <label class="form-label-custom">Tên / Tiêu đề buổi học</label>
                <input type="text" name="title" id="editLessonTitle" class="form-input-custom" required />
            </div>
            
            <div class="form-group-custom">
                <label class="form-label-custom">Link phòng học online (Zoom, Meet,...)</label>
                <input type="url" name="meetingUrl" id="editLessonMeetingUrl" class="form-input-custom" placeholder="https://zoom.us/j/..." />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group-custom">
                    <label class="form-label-custom">ID Phòng học</label>
                    <input type="text" name="meetingId" id="editLessonMeetingId" class="form-input-custom" placeholder="Ví dụ: 999 888 777" />
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Mật khẩu (Passcode)</label>
                    <input type="text" name="meetingPassword" id="editLessonMeetingPassword" class="form-input-custom" placeholder="Ví dụ: 123" />
                </div>
            </div>

            <div class="form-group-custom">
                <label class="form-label-custom">Link Video Xem Lại (Replay/Recording URL)</label>
                <input type="url" name="videoUrl" id="editLessonVideoUrl" class="form-input-custom" placeholder="Ví dụ: https://youtube.com/watch?v=... hoặc Drive..." />
            </div>

            <div class="form-group-custom">
                <label class="form-label-custom">Tài liệu đính kèm hiện tại</label>
