    // Apply cropped avatar to preview card and form state
    function applyAvatarCrop() {
        if (!avatarCropper) return;

        avatarCropper.getCroppedCanvas({
            width: 300,
            height: 300,
            fillColor: '#ffffff'
        }).toBlob((blob) => {
            croppedAvatarBlob = blob;
            
            // Get cropped data URL to display as preview instantly
            const dataUrl = avatarCropper.getCroppedCanvas().toDataURL();
            
            const previewImg = document.getElementById('previewAvatarImg');
            const previewInitial = document.getElementById('previewAvatarInitial');
            if (previewImg) {
                previewImg.src = dataUrl;
                previewImg.style.display = 'block';
            }
            if (previewInitial) {
                previewInitial.style.display = 'none';
            }

            // Also update the large banner avatar in view-mode showcase
            let viewAvatarImg = document.getElementById('viewAvatarImg');
            const viewAvatarInitial = document.getElementById('viewAvatarInitial');
            if (viewAvatarImg) {
                viewAvatarImg.src = dataUrl;
                viewAvatarImg.style.display = 'block';
            } else if (viewAvatarInitial) {
                // Create img element if only initial was shown
                viewAvatarImg = document.createElement('img');
                viewAvatarImg.id = 'viewAvatarImg';
                viewAvatarImg.style.cssText = 'width:100%; height:100%; object-fit:cover;';
                viewAvatarImg.src = dataUrl;
                viewAvatarInitial.parentNode.insertBefore(viewAvatarImg, viewAvatarInitial);
                viewAvatarInitial.style.display = 'none';
            }

            closeModal('avatarCropModal');
        }, 'image/png');
    }

    // Teacher Profile form submit
    async function submitTeacherProfile(event) {
        event.preventDefault();
        const btn = document.getElementById('btnSaveTeacherProfile');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang lưu...';

        const formData = new FormData(document.getElementById('formTeacherPublicProfile'));
        
        // Append cropped avatar file if exists
        if (croppedAvatarBlob) {
            formData.delete('avatarFile');
            formData.append('avatarFile', croppedAvatarBlob, 'avatar.png');
        }

        try {
            const resp = await fetch('/Profile/UpdateDetails', { method: 'POST', body: formData });
            const result = await resp.json();
            if (result.success) {
                // Reset cropped avatar state
                croppedAvatarBlob = null;

                // Update presentation Showcase View mode DOM elements instantly
                const formName = document.querySelector('input[name="fullName"]').value;
                const formTitle = document.querySelector('input[name="teacherTitle"]').value;
                const formSubject = document.querySelector('input[name="subject"]').value;
                const formExp = document.querySelector('input[name="teacherExperience"]').value;
                const formStudents = document.querySelector('input[name="teacherStudents"]').value;
                const formBio = document.querySelector('textarea[name="teacherBio"]').value;

                document.getElementById('viewName').textContent = formName;
                document.getElementById('viewTitle').textContent = formTitle || 'Giảng viên';
                document.getElementById('viewSubjectBadge').textContent = formSubject || 'Chưa cập môn';
                document.getElementById('viewExpVal').textContent = (formExp || '0') + '+';
                document.getElementById('viewStudentsVal').textContent = (formStudents || '0') + '+';
                document.getElementById('viewBioVal').textContent = formBio || 'Giảng viên giàu kinh nghiệm ôn luyện và bồi dưỡng kiến thức toàn diện cho các em học viên.';
                const bioDetail = document.getElementById('viewBioValDetail');
                if (bioDetail) bioDetail.textContent = formBio || 'Giảng viên chưa cập nhật thông tin giới thiệu.';

                if (result.avatarUrl) {
                    // Update main showcase view mode avatar
                    let viewAvatarImg = document.getElementById('viewAvatarImg');
                    let viewAvatarInitial = document.getElementById('viewAvatarInitial');
                    if (!viewAvatarImg) {
                        const parent = viewAvatarInitial.parentNode;
                        viewAvatarInitial.remove();
                        viewAvatarImg = document.createElement('img');
                        viewAvatarImg.id = 'viewAvatarImg';
                        viewAvatarImg.style.width = '100%';
                        viewAvatarImg.style.height = '100%';
                        viewAvatarImg.style.objectFit = 'cover';
                        parent.appendChild(viewAvatarImg);
                    }
                    viewAvatarImg.src = result.avatarUrl;
                    viewAvatarImg.style.display = 'block';

                    // Update navbar avatar
                    const navbarAvatars = document.querySelectorAll('img[src*="/uploads/avatar"], img.avatar, .user-avatar img');
                    navbarAvatars.forEach(img => {
                        img.src = result.avatarUrl;
                    });
                } else {
                    const viewAvatarInitial = document.getElementById('viewAvatarInitial');
                    if (viewAvatarInitial && formName) {
                        viewAvatarInitial.textContent = formName.charAt(0).toUpperCase();
                    }
                }

                if (typeof showToastNotification === 'function') {
                    showToastNotification('Cập nhật thông tin giới thiệu thành công!', 'success');
                } else {
                    alert('Cập nhật thành công!');
                }

                // Slide back to the beautiful full-screen presentation mode card!
                hideProfileEditMode();
            } else {
                if (typeof showToastNotification === 'function') {
                    showToastNotification(result.message || 'Lỗi khi cập nhật.', 'error');
                } else {
                    alert(result.message || 'Lỗi khi cập nhật.');
                }
            }
        } catch(err) {
            console.error(err);
            if (typeof showToastNotification === 'function') {
                showToastNotification('Có lỗi xảy ra khi kết nối máy chủ.', 'error');
            }
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

