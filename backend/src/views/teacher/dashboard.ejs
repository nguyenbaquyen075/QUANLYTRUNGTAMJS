<script>
    function switchTab(tabId) {
        // hide all tab contents
        const contents = document.querySelectorAll('.tab-content');
        contents.forEach(c => {
            c.classList.remove('active');
            c.style.display = 'none';
        });

        // deactivate all tab buttons
        const buttons = document.querySelectorAll('.sidebar .teacher-tab-btn');
        buttons.forEach(b => b.classList.remove('active'));

        // show target
        const targetEl = document.getElementById(tabId);
        if (targetEl) {
            targetEl.classList.add('active');
            targetEl.style.display = 'block';
        }

        // scroll content body back to top
        const contentBody = document.querySelector('.teacher-content-body');
        if (contentBody) contentBody.scrollTop = 0;
        
        // Find and activate sidebar button
        const activeBtn = Array.from(buttons).find(b => b.getAttribute('onclick').includes(tabId));
        if (activeBtn) activeBtn.classList.add('active');
    }

    // Teacher Profile toggling functions
    function showProfileEditMode() {
        const view = document.getElementById('profileViewContainer');
        const edit = document.getElementById('profileEditContainer');
        if (view && edit) {
            view.style.display = 'none';
            edit.style.display = 'block';
        }
    }
    function hideProfileEditMode() {
        const view = document.getElementById('profileViewContainer');
        const edit = document.getElementById('profileEditContainer');
        if (view && edit) {
            view.style.display = 'block';
            edit.style.display = 'none';
        }
    }

    // Interactive Avatar Picker Hover for Live Preview Card
    (function initAvatarPickerHover() {
        const picker = document.getElementById('previewAvatarContainer');
        const overlay = document.getElementById('previewAvatarHoverOverlay');
        if (picker && overlay) {
            picker.addEventListener('mouseenter', () => {
                overlay.style.display = 'flex';
            });
            picker.addEventListener('mouseleave', () => {
                overlay.style.display = 'none';
            });
        }
    })();

    // Open crop modal for the CURRENT saved avatar (edit without choosing new file)
    function openAvatarEditor() {
        const viewImg = document.getElementById('viewAvatarImg');
        const previewImg = document.getElementById('previewAvatarImg');

        // Determine currently displayed image src (cropped preview takes priority)
        const currentSrc = (previewImg && previewImg.style.display !== 'none' && previewImg.src && previewImg.src !== window.location.href)
            ? previewImg.src
            : (viewImg ? viewImg.src : null);

        if (currentSrc) {
            // Has existing avatar — open crop modal directly with current image
            openModal('avatarCropModal');
            const image = document.getElementById('avatarCropperImage');
            image.src = currentSrc;

            if (avatarCropper) { avatarCropper.destroy(); avatarCropper = null; }

            avatarCropper = new Cropper(image, {
                aspectRatio: 1,
                viewMode: 1,
                dragMode: 'move',
                autoCropArea: 0.9,
                restore: false,
                guides: false,
                center: true,
                highlight: false,
                cropBoxMovable: true,
                cropBoxResizable: true,
                toggleDragModeOnDblclick: false
            });
        } else {
            // No avatar yet — open file picker
            showProfileEditMode();
            document.getElementById('avatarFileInput').click();
        }
    }

    // Preview loaded local avatar image with Cropper
    let avatarCropper = null;
    let croppedAvatarBlob = null;

    function previewAvatarImage(input) {
        if (input.files && input.files[0]) {
            const file = input.files[0];
            const reader = new FileReader();
            reader.onload = function(e) {
                // Update filename display and show X button
                const fileNameEl = document.getElementById('avatarFileName');
                const clearBtn = document.getElementById('avatarClearBtn');
                if (fileNameEl) fileNameEl.textContent = file.name;
                if (clearBtn) clearBtn.style.display = 'flex';
                // Clear removeAvatar flag since user chose a new file
                document.getElementById('removeAvatarFlag').value = '';

                // Open crop modal
                openModal('avatarCropModal');
                
                const image = document.getElementById('avatarCropperImage');
                image.src = e.target.result;

                if (avatarCropper) {
                    avatarCropper.destroy();
                }

                // Initialize circular cropper (aspect ratio 1:1)
                avatarCropper = new Cropper(image, {
                    aspectRatio: 1, // square
                    viewMode: 1,
                    dragMode: 'move',
                    autoCropArea: 0.9,
                    restore: false,
                    guides: false,
                    center: true,
                    highlight: false,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: false,
                    ready: function() {
                        const containerData = this.cropper.getContainerData();
                        const imageData = this.cropper.getImageData();
                        const scale = Math.max(
                            containerData.width / imageData.naturalWidth,
                            containerData.height / imageData.naturalHeight
                        );
                        this.cropper.zoomTo(scale);
                    }
                });
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Clear avatar file selection — reset to "Chọn ảnh" state
    function clearAvatarFile() {
        // Reset file input
        document.getElementById('avatarFileInput').value = '';
        croppedAvatarBlob = null;

        // Signal to server to remove avatar
        document.getElementById('removeAvatarFlag').value = 'true';

        // Reset filename and hide X button
        const fileNameEl = document.getElementById('avatarFileName');
        const clearBtn = document.getElementById('avatarClearBtn');
        if (fileNameEl) fileNameEl.textContent = 'Chưa chọn tệp nào';
        if (clearBtn) clearBtn.style.display = 'none';

        // Also clear banner avatar
        const viewAvatarImg = document.getElementById('viewAvatarImg');
        const viewAvatarInitial = document.getElementById('viewAvatarInitial');
        if (viewAvatarImg) { viewAvatarImg.src = ''; viewAvatarImg.style.display = 'none'; }
        if (viewAvatarInitial) viewAvatarInitial.style.display = 'flex';

