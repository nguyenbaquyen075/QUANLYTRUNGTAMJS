            function handleBottomButtonClick() {
                if (!isQuiz && !isTF && !isExam) {
                    submitFormDirect();
                } else if (currentQ === totalQuestions - 1) {
                    submitFormDirect();
                } else {
                    goNext();
                }
            }

            let isReviewMode = false;
            let totalDuration = 2700; // default 45 mins
            let remainingTime = 2700;
            let timerInterval = null;

            function startTimer(duration) {
                totalDuration = duration;
                remainingTime = duration;
                let timer = duration;
                const timerEl = document.getElementById('timerDisplay');
                if (!timerEl) return;
                timerInterval = setInterval(() => {
                    remainingTime = timer;
                    const h = Math.floor(timer / 3600), m = Math.floor((timer % 3600) / 60), s = timer % 60;
                    timerEl.textContent = (h > 0 ? (h.toString().padStart(2, '0') + ':') : '') + m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
                    const dmTimerEl = document.getElementById('danhMucTimerDisplay');
                    if (dmTimerEl) {
                        dmTimerEl.textContent = (h > 0 ? (h.toString().padStart(2, '0') + ':') : '') + m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
                    }
                    if (timer < 120) timerEl.style.color = '#ba1a1a';
                    if (--timer < 0) { clearInterval(timerInterval); alert("Hết thời gian!"); submitFormDirect(); }
                }, 1000);
            }

            function submitFormDirect() {
                if (isQuiz || isTF || isExam) {
                    // Count unanswered
                    let unanswered = 0;
                    for (let i = 0; i < totalQuestions; i++) {
                        const qObj = allQuestions[i];
                        if (qObj.type === 'tf' || qObj.type === 'examDS') {
                            const tfAns = qObj.type === 'tf' ? tfAnswers[qObj.originalIdx] : examAnswers.tf[qObj.originalIdx];
                            let answeredCount = 0;
                            ['a', 'b', 'c', 'd'].forEach(letter => {
                                if (tfAns && tfAns[letter] !== null && tfAns[letter] !== undefined) answeredCount++;
                            });
                            if (answeredCount < 4) unanswered++;
                        } else {
                            const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1 && flatAnswers[qi] !== '';
                            if (!getAnswered(i)) unanswered++;
                        }
                    }
                    if (unanswered > 0) {
                        alert('Bạn còn ' + unanswered + ' câu chưa hoàn thành. Vui lòng hoàn thành tất cả các câu hỏi trước khi nộp bài!');
                        return;
                    }

                    // pack content
                    let contentToSave = '';
                    if (isQuiz) {
                        contentToSave = JSON.stringify(answers);
                    } else if (isTF) {
                        contentToSave = JSON.stringify(tfAnswers);
                    } else if (isExam) {
                        contentToSave = JSON.stringify(examAnswers);
                    }
                    document.getElementById('assignmentContentInput').value = contentToSave;
                } else {
                    const essayEl = document.getElementById('essayText');
                    const essayFileEl = document.getElementById('essayFile');
                    if (essayEl) {
                        const textVal = essayEl.value.trim();
                        const fileVal = essayFileEl ? essayFileEl.value.trim() : '';
                        if (!textVal && !fileVal) {
                            alert('Vui lòng hoàn thành bài làm tự luận (nhập văn bản hoặc tải file đính kèm) trước khi nộp bài!');
                            return;
                        }
                        document.getElementById('assignmentContentInput').value = textVal;
                    }
                }

                showSubmitResult();
            }

            function calculateScore() {
                let score = null;
                let message = '';
                let showCircle = false;

                if (isQuiz) {
                    let totalMaxPoints = 0;
                    let totalCorrectPoints = 0;
                    rawQuizData.forEach((q, idx) => {
                        const pt = parseFloat(q.points) || 1;
                        totalMaxPoints += pt;
                        if (answers[idx] === q.correct_index) {
                            totalCorrectPoints += pt;
                        }
                    });
                    score = totalMaxPoints > 0 ? (totalCorrectPoints / totalMaxPoints) * 10.0 : 0.0;
                    message = `Bạn đã hoàn thành bài thi trắc nghiệm!`;
                    showCircle = true;
                } else if (isTF) {
                    let totalMaxPoints = 0;
                    let totalCorrectPoints = 0;
                    rawTFData.forEach((q, idx) => {
                        if (q.items) {
                            ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                                if (q.items[ii]) {
                                    const subPt = parseFloat(q.items[ii].points !== undefined ? q.items[ii].points : 0.25);
                                    totalMaxPoints += subPt;
                                    const studentAns = tfAnswers[idx] ? tfAnswers[idx][letter] : null;
                                    if (studentAns === q.items[ii].answer) {
                                        totalCorrectPoints += subPt;
                                    }
                                }
                            });
                        }
                    });
                    score = totalMaxPoints > 0 ? (totalCorrectPoints / totalMaxPoints) * 10.0 : 0.0;
                    message = `Bạn đã hoàn thành bài thi Đúng/Sai!`;
                    showCircle = true;
                } else if (isExam) {
                    let totalMaxPoints = 0;
                    let totalCorrectPoints = 0;
                    let hasEssay = (rawExamData.essay && rawExamData.essay.length > 0);

                    if (rawExamData.quiz) {
                        rawExamData.quiz.forEach((q, idx) => {
                            const pt = parseFloat(q.points) || 1;
                            totalMaxPoints += pt;
                            if (examAnswers.quiz[idx] === q.correct_index) {
                                totalCorrectPoints += pt;
                            }
                        });
                    }

                    if (rawExamData.tf) {
                        rawExamData.tf.forEach((q, idx) => {
                            if (q.items) {
                                ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                                    if (q.items[ii]) {
                                        const subPt = parseFloat(q.items[ii].points !== undefined ? q.items[ii].points : 0.25);
                                        totalMaxPoints += subPt;
                                        const studentAns = examAnswers.tf[idx] ? examAnswers.tf[idx][letter] : null;
                                        if (studentAns === q.items[ii].answer) {
                                            totalCorrectPoints += subPt;
                                        }
                                    }
                                });
                            }
                        });
                    }
                    score = totalMaxPoints > 0 ? (totalCorrectPoints / totalMaxPoints) * 10.0 : 0.0;
                    if (hasEssay) {
                        showCircle = false;
                        message = `Đã nộp bài làm của bạn. Phần tự luận đang chờ giáo viên chấm điểm.`;
                    } else {
                        showCircle = true;
                        message = `Bạn đã hoàn thành bài kiểm tra!`;
                    }
                } else {
                    showCircle = false;
                    message = `Đã nộp bài làm của bạn.`;
                }

                return { score, message, showCircle };
            }

            let confettiActive = false;
            let confettiCanvas = null;
            let confettiCtx = null;
            let confettiPieces = [];

            function startConfetti() {
                if (confettiActive) return;
                confettiCanvas = document.createElement('canvas');
                confettiCanvas.style.position = 'fixed';
                confettiCanvas.style.top = '0';
                confettiCanvas.style.left = '0';
                confettiCanvas.style.width = '100vw';
                confettiCanvas.style.height = '100vh';
                confettiCanvas.style.pointerEvents = 'none';
                confettiCanvas.style.zIndex = '110';
                document.body.appendChild(confettiCanvas);

                confettiCtx = confettiCanvas.getContext('2d');
                confettiCanvas.width = window.innerWidth;
                confettiCanvas.height = window.innerHeight;

                window.addEventListener('resize', resizeConfettiCanvas);

                confettiActive = true;
                confettiPieces = [];
                const colors = ['#2563EB', '#10B981', '#F59E0B', '#EF4444', '#EC4899', '#8B5CF6'];

                for (let i = 0; i < 150; i++) {
                    confettiPieces.push({
                        x: Math.random() * confettiCanvas.width,
                        y: Math.random() * -confettiCanvas.height,
                        size: Math.random() * 8 + 6,
                        rotation: Math.random() * 360,
                        rotationSpeed: Math.random() * 10 - 5,
                        speedY: Math.random() * 5 + 4,
                        speedX: Math.random() * 4 - 2,
                        color: colors[Math.floor(Math.random() * colors.length)]
                    });
                }

                requestAnimationFrame(updateConfetti);
                setTimeout(stopConfetti, 4000);
            }

            function resizeConfettiCanvas() {
                if (confettiCanvas) {
                    confettiCanvas.width = window.innerWidth;
                    confettiCanvas.height = window.innerHeight;
                }
            }

            function updateConfetti() {
                if (!confettiActive) return;
                confettiCtx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);

                let stillFalling = false;
                confettiPieces.forEach(p => {
                    p.y += p.speedY;
                    p.x += p.speedX;
                    p.rotation += p.rotationSpeed;

                    if (p.y < confettiCanvas.height) stillFalling = true;

                    const twistScale = Math.cos(p.rotation * Math.PI / 180);

                    confettiCtx.save();
                    confettiCtx.translate(p.x, p.y);
                    confettiCtx.rotate(p.rotation * Math.PI / 180);
                    confettiCtx.fillStyle = p.color;
                    confettiCtx.fillRect(-p.size / 2 * twistScale, -p.size / 2, p.size * twistScale, p.size);
                    confettiCtx.restore();

                    if (p.y > confettiCanvas.height) {
                        p.y = -20;
                        p.x = Math.random() * confettiCanvas.width;
                    }
                });

                if (stillFalling && confettiActive) {
                    requestAnimationFrame(updateConfetti);
                }
            }

            function stopConfetti() {
                confettiActive = false;
                if (confettiCanvas && confettiCanvas.parentNode) {
                    confettiCanvas.parentNode.removeChild(confettiCanvas);
                }
                window.removeEventListener('resize', resizeConfettiCanvas);
            }

            function showSubmitResult() {
                const { score, message, showCircle } = calculateScore();

                const modal = document.getElementById('scoreModal');
                const modalTitle = document.getElementById('scoreModalTitle');
                const circleWrapper = document.getElementById('scoreCircleWrapper');
                const scoreValue = document.getElementById('scoreValue');
                const circleProgress = document.getElementById('scoreCircleProgress');
                const statsContainer = document.getElementById('scoreStatsContainer');

                let correctCount = 0;
                let wrongCount = 0;
                let totalCount = 0;

                if (isQuiz) {
                    totalCount = rawQuizData.length;
                    rawQuizData.forEach((q, idx) => {
                        if (answers[idx] === q.correct_index) correctCount++;
                        else wrongCount++;
                    });
                } else if (isTF) {
                    rawTFData.forEach((q, idx) => {
                        if (q.items) {
                            ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                                if (q.items[ii]) {
                                    totalCount++;
                                    const studentAns = tfAnswers[idx] ? tfAnswers[idx][letter] : null;
                                    if (studentAns === q.items[ii].answer) correctCount++;
                                    else wrongCount++;
                                }
                            });
                        }
                    });
                } else if (isExam) {
                    if (rawExamData.quiz) {
                        totalCount += rawExamData.quiz.length;
                        rawExamData.quiz.forEach((q, idx) => {
                            if (examAnswers.quiz[idx] === q.correct_index) correctCount++;
                            else wrongCount++;
                        });
                    }
                    if (rawExamData.tf) {
                        rawExamData.tf.forEach((q, idx) => {
                            if (q.items) {
                                ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                                    if (q.items[ii]) {
                                        totalCount++;
                                        const studentAns = examAnswers.tf[idx] ? examAnswers.tf[idx][letter] : null;
                                        if (studentAns === q.items[ii].answer) correctCount++;
                                        else wrongCount++;
                                    }
                                });
                            }
                        });
                    }
                }

                const elapsed = totalDuration - remainingTime;
                const m = Math.floor(elapsed / 60).toString().padStart(2, '0');
                const s = (elapsed % 60).toString().padStart(2, '0');
                const timeStr = `${m}:${s}`;

                if (showCircle && score !== null) {
                    circleWrapper.style.display = 'flex';
                    statsContainer.style.display = 'grid';
                    scoreValue.textContent = score.toFixed(1);

                    // Set circle progress stroke-dashoffset (circumference = 251.2)
                    const strokeDashoffset = 251.2 - (251.2 * score / 10.0);
                    circleProgress.setAttribute('stroke-dashoffset', strokeDashoffset);

                    // Populate stats
                    document.getElementById('statsCorrect').textContent = correctCount;
                    document.getElementById('statsWrong').textContent = wrongCount;
                    document.getElementById('statsTime').textContent = timeStr;

                    if (score >= 8.5) {
                        modalTitle.textContent = "Hoàn thành xuất sắc!";
                        modalTitle.style.color = "#1e3a8a";
                        if (score === 10.0) {
                            circleProgress.setAttribute('stroke', '#10B981'); // emerald green
                        } else {
                            circleProgress.setAttribute('stroke', '#a25d23'); // orange-brown
                        }

                        // Trigger Confetti!
                        startConfetti();
                    } else if (score >= 5.0) {
                        modalTitle.textContent = "Hoàn thành bài kiểm tra";
                        modalTitle.style.color = "#1e3a8a";
                        circleProgress.setAttribute('stroke', '#2563eb');
                    } else {
                        modalTitle.textContent = "Bài kiểm tra đã nộp";
                        modalTitle.style.color = "#9a3412";
                        circleProgress.setAttribute('stroke', '#ea580c');
                    }
                } else {
                    // Essay only
                    circleWrapper.style.display = 'none';
                    statsContainer.style.display = 'none';
                    modalTitle.textContent = "Nộp bài tự luận thành công";
                }

                if (showCircle && score !== null) {
                    document.getElementById('leaderboardSection').style.display = 'block';
                    loadLeaderboard(score);
                } else {
                    document.getElementById('leaderboardSection').style.display = 'none';
                }

                modal.classList.remove('hidden');
                setTimeout(() => {
                    const container = document.getElementById('scoreModalContainer');
                    if (container) {
                        container.classList.remove('scale-95');
                        container.classList.add('scale-100');
                    }
                }, 10);
            }

            function loadLeaderboard(simulatedScore) {
                const listEl = document.getElementById('leaderboardList');
                const rankEl = document.getElementById('myRankDisplay');
                if (!listEl) return;

                fetch(`/Student/AssignmentLeaderboard/${assignmentId}?simulatedScore=${simulatedScore !== null ? simulatedScore : ''}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            if (rankEl) {
                                rankEl.textContent = `Hạng: ${data.rank} / ${data.total}`;
                            }
                            let html = '';
                            const medals = {
                                1: '🥇',
                                2: '🥈',
                                3: '🥉'
                            };
                            const medalBgs = {
                                1: 'bg-amber-100 text-amber-600',
                                2: 'bg-slate-100 text-slate-600',
                                3: 'bg-orange-100 text-orange-600'
                            };
                            data.top3.forEach((sub, idx) => {
                                const place = idx + 1;
                                const medal = medals[place] || place.toString();
                                const bgCls = medalBgs[place] || 'bg-slate-50 text-slate-500';

                                html += `<div class="flex items-center justify-between bg-white/60 p-2.5 rounded-xl border border-blue-50">
                            <span class="font-bold text-slate-700 flex items-center gap-2">
                                <span class="w-5 h-5 ${bgCls} rounded-full flex items-center justify-center font-black text-[10px]">${place}</span>
                                <span>${sub.fullName}</span>
                            </span>
                            <span class="font-extrabold text-[#1e3a8a]">${Number(sub.grade).toFixed(1)}</span>
                        </div>`;
                            });
                            if (data.top3.length === 0) {
                                html = '<div class="text-center text-slate-400 py-2">Chưa có lượt nộp bài nào.</div>';
                            }
