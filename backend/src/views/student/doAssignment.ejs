        </div><!-- end #examRoot -->

        <script>
            const assignmentId = "<%= assignmentId %>";
            const assignmentType = <%= assignmentType %>;
            const isQuiz = <%= isQuiz ? 'true' : 'false' %>;
            const isTF = <%= isTF ? 'true' : 'false' %>;
            const isExam = <%= isExam ? 'true' : 'false' %>;

            let rawQuizData = [];
            let rawTFData = [];
            let rawExamData = { quiz: [], tf: [], essay: [] };

            try {
                if (isQuiz) {
                    rawQuizData = <%- JSON.stringify(parsedQuizData) %>;
                } else if (isTF) {
                    rawTFData = <%- JSON.stringify(parsedTFData) %>;
                } else if (isExam) {
                    rawExamData = <%- JSON.stringify(parsedExamData) %>;
                }
            } catch (e) {
                console.error("Script parse error:", e);
            }

            let currentQ = 0;
            const answers = new Array(rawQuizData.length).fill(-1);
            const tfAnswers = new Array(rawTFData.length).fill(null).map(() => ({ a: null, b: null, c: null, d: null }));
            const examAnswers = {
                quiz: new Array((rawExamData.quiz || []).length).fill(-1),
                tf: new Array((rawExamData.tf || []).length).fill(null).map(() => ({ a: null, b: null, c: null, d: null })),
                essay: new Array((rawExamData.essay || []).length).fill('')
            };

            function autoResize(el) {
                el.style.height = 'auto';
                el.style.height = el.scrollHeight + 'px';
            }

            function triggerAutoResizeAll() {
                setTimeout(() => {
                    document.querySelectorAll('textarea.auto-resize').forEach(el => {
                        autoResize(el);
                    });
                }, 100);
            }

            let tabSwitchCount = 0;
            document.addEventListener("visibilitychange", function () {
                if (document.visibilityState === 'hidden' && (isQuiz || isExam || isTF)) {
                    tabSwitchCount++;
                    if (tabSwitchCount > 3) {
                        alert("Bạn đã thoát tab quá 3 lần. Hệ thống tự động nộp bài!");
                        submitFormDirect();
                    } else {
                        alert("Cảnh báo! Bạn đã rời khỏi giao diện làm bài. Lần " + tabSwitchCount + "/3");
                    }
                }
            });

            // ===== UNIFIED ONE-AT-A-TIME RENDERER =====
            // Build a flat list of all questions across all types
            let allQuestions = []; // { type: 'quiz'|'tf'|'examTN'|'examDS'|'examTL', data, originalIdx, sectionLabel? }

            if (isQuiz) {
                rawQuizData.forEach((q, i) => allQuestions.push({ type: 'quiz', data: q, originalIdx: i }));
            } else if (isTF) {
                rawTFData.forEach((q, i) => allQuestions.push({ type: 'tf', data: q, originalIdx: i }));
            } else if (isExam) {
                const order = rawExamData.sectionOrder || [];
                let tnIdx = 0, dsIdx = 0, tlIdx = 0;
                order.forEach((sec, sIdx) => {
                    const label = ['I', 'II', 'III', 'IV'][sIdx] || (sIdx + 1);
                    if (sec === 'tn') {
                        (rawExamData.quiz || []).forEach((q, i) => allQuestions.push({ type: 'examTN', data: q, originalIdx: tnIdx++, sectionLabel: 'Phần ' + label + ': TRẮC NGHIỆM' }));
                    } else if (sec === 'ds') {
                        (rawExamData.tf || []).forEach((q, i) => allQuestions.push({ type: 'examDS', data: q, originalIdx: dsIdx++, sectionLabel: 'Phần ' + label + ': ĐÚNG/SAI' }));
                    } else if (sec === 'tl') {
                        (rawExamData.essay || []).forEach((q, i) => allQuestions.push({ type: 'examTL', data: q, originalIdx: tlIdx++, sectionLabel: 'Phần ' + label + ': TỰ LUẬN' }));
                    }
                });
                // Fallback if no sectionOrder
                if (order.length === 0) {
                    (rawExamData.quiz || []).forEach((q, i) => allQuestions.push({ type: 'examTN', data: q, originalIdx: i }));
                    (rawExamData.tf || []).forEach((q, i) => allQuestions.push({ type: 'examDS', data: q, originalIdx: i }));
                    (rawExamData.essay || []).forEach((q, i) => allQuestions.push({ type: 'examTL', data: q, originalIdx: i }));
                }
            }

            const totalQuestions = allQuestions.length;
            // answers tracking per flat index
            const flatAnswers = new Array(totalQuestions).fill(null);

            window.addEventListener('DOMContentLoaded', () => {
                restoreDraft();
                if (isQuiz || isTF || isExam) {
                    renderQuestion(0);
                    updateNavBar();
                    startTimer(2700);
                }
                triggerAutoResizeAll();
            });

            function renderQuestion(idx) {
                if (idx < 0 || idx >= totalQuestions) return;
                const container = document.getElementById('quizContainer');
                const dmContainer = document.getElementById('danhMucQuizContainer');
                if (!container && !dmContainer) return;
                const qObj = allQuestions[idx];
                const { type, data, originalIdx, sectionLabel } = qObj;
                currentQ = idx;

                let sectionBadge = '';
                if (sectionLabel) {
                    const color = type === 'examTN' ? 'text-blue-800 bg-blue-50' : (type === 'examDS' ? 'text-emerald-800 bg-emerald-50' : 'text-amber-800 bg-amber-50');
                    sectionBadge = `<span class="text-xs font-bold px-3 py-1 ${color} rounded-full uppercase mr-2">${sectionLabel}</span>`;
                }

                let html = `<section class="bg-white/80 backdrop-blur-md rounded-xl p-lg soft-shadow border border-outline-variant question-card">
            <div class="flex items-center gap-2 mb-md">
                ${sectionBadge}
                <span class="text-xs font-bold px-3 py-1 bg-surface-container text-on-surface-variant rounded-full uppercase">CÂU ${originalIdx + 1}</span>
            </div>`;

                if (type === 'quiz' || type === 'examTN') {
                    const opts = ['A', 'B', 'C', 'D'];
                    const curAns = type === 'quiz' ? answers[originalIdx] : examAnswers.quiz[originalIdx];
                    html += `<div class="text-base font-semibold text-on-surface mb-xl whitespace-pre-wrap">${data.question || data.question_text || ''}</div>`;
                    html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-md">`;
                    opts.forEach((letter, optIdx) => {
                        const sel = curAns === optIdx;
                        const isCorrectOption = optIdx === data.correct_index;
                        const isSelectedOption = curAns === optIdx;

                        let labelCls = 'group flex items-center p-md border rounded-xl transition-all ';
                        let badgeHtml = '';
                        let numCls = 'w-10 h-10 flex items-center justify-center rounded-lg font-bold transition-all mr-4 shrink-0 ';

                        if (isReviewMode) {
                            if (isCorrectOption) {
                                labelCls += 'border-emerald-500 bg-emerald-50 text-emerald-900';
                                numCls += 'bg-emerald-600 text-white';
                                badgeHtml = '<span class="text-xs font-bold text-emerald-600 ml-auto flex items-center gap-1"><span class="material-symbols-outlined text-sm">check_circle</span> Đáp án đúng</span>';
                            } else if (isSelectedOption) {
                                labelCls += 'border-rose-500 bg-rose-50 text-rose-900';
                                numCls += 'bg-rose-600 text-white';
                                badgeHtml = '<span class="text-xs font-bold text-rose-600 ml-auto flex items-center gap-1"><span class="material-symbols-outlined text-sm">cancel</span> Bạn chọn sai</span>';
                            } else {
                                labelCls += 'border-outline-variant opacity-60';
                                numCls += 'bg-surface-container text-on-surface-variant';
                            }
                        } else {
                            labelCls += sel ? 'border-primary bg-primary/5 cursor-pointer hover:border-primary/50' : 'border-outline-variant cursor-pointer hover:border-primary/50';
                            numCls += sel ? 'bg-primary text-white' : 'bg-surface-container group-hover:bg-primary/10';
                        }

