            function flatAnswerChange(flatIdx, optIdx) {
                const qObj = allQuestions[flatIdx];
                flatAnswers[flatIdx] = optIdx;
                if (qObj.type === 'quiz') answers[qObj.originalIdx] = optIdx;
                else if (qObj.type === 'examTN') examAnswers.quiz[qObj.originalIdx] = optIdx;
                saveDraft();
                updateNavBar();
                renderQuestion(flatIdx);
            }

            function flatTFAnswer(flatIdx, itemIdx, val) {
                const qObj = allQuestions[flatIdx];
                const letters = ['a', 'b', 'c', 'd'];
                if (qObj.type === 'tf') {
                    if (!tfAnswers[qObj.originalIdx]) tfAnswers[qObj.originalIdx] = {};
                    tfAnswers[qObj.originalIdx][letters[itemIdx]] = val;
                } else {
                    if (!examAnswers.tf[qObj.originalIdx]) examAnswers.tf[qObj.originalIdx] = {};
                    examAnswers.tf[qObj.originalIdx][letters[itemIdx]] = val;
                }
                flatAnswers[flatIdx] = true; // mark answered
                saveDraft();
                updateNavBar();
                renderQuestion(flatIdx); // re-render to update button styles
            }

            function flatEssayAnswer(originalIdx, val) {
                examAnswers.essay[originalIdx] = val;
                const flatIdx = currentQ;
                flatAnswers[flatIdx] = val;
                saveDraft();
            }

            function onAnswerChange(qIdx, optIdx) { flatAnswerChange(currentQ, parseInt(optIdx)); }
            function onExamTNChange(qIdx, optIdx) { flatAnswerChange(currentQ, parseInt(optIdx)); }

            function goPrev() { if (currentQ > 0) renderQuestion(currentQ - 1); }
            function goNext() { if (currentQ < totalQuestions - 1) renderQuestion(currentQ + 1); }
            function goToQuestion(idx) { renderQuestion(idx); }

            function isQuestionCorrect(qi) {
                const qObj = allQuestions[qi];
                if (qObj.type === 'quiz') {
                    return answers[qObj.originalIdx] === qObj.data.correct_index;
                } else if (qObj.type === 'examTN') {
                    return examAnswers.quiz[qObj.originalIdx] === qObj.data.correct_index;
                } else if (qObj.type === 'tf') {
                    if (!qObj.data.items) return false;
                    let correct = true;
                    ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                        if (qObj.data.items[ii]) {
                            const studentAns = tfAnswers[qObj.originalIdx] ? tfAnswers[qObj.originalIdx][letter] : null;
                            if (studentAns !== qObj.data.items[ii].answer) correct = false;
                        }
                    });
                    return correct;
                } else if (qObj.type === 'examDS') {
                    if (!qObj.data.items) return false;
                    let correct = true;
                    ['a', 'b', 'c', 'd'].forEach((letter, ii) => {
                        if (qObj.data.items[ii]) {
                            const studentAns = examAnswers.tf[qObj.originalIdx] ? examAnswers.tf[qObj.originalIdx][letter] : null;
                            if (studentAns !== qObj.data.items[ii].answer) correct = false;
                        }
                    });
                    return correct;
                }
                return null; // essay or other
            }

            function updateNavBar() {
                const total = totalQuestions;
                const navBar = document.getElementById('questionNavBar');
                if (!navBar || total === 0) return;

                let html = '';
                const MAX_SHOW = 5;
                const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1;

                const mkBtn = (qi) => {
                    let cls = '';
                    if (isReviewMode) {
                        const corr = isQuestionCorrect(qi);
                        if (qi === currentQ) {
                            cls = 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full text-xs font-bold cursor-pointer ring-2 ring-primary ring-offset-2 ' +
                                (corr === true ? 'bg-emerald-600 text-white' : (corr === false ? 'bg-rose-600 text-white' : 'bg-slate-600 text-white'));
                        } else {
                            cls = 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border text-xs font-bold cursor-pointer ' +
                                (corr === true ? 'bg-emerald-100 border-emerald-500 text-emerald-800' : (corr === false ? 'bg-rose-100 border-rose-500 text-rose-800' : 'bg-slate-100 border-slate-300 text-slate-600'));
                        }
                    } else {
                        cls = qi === currentQ
                            ? 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full bg-white text-primary border-2 border-primary text-xs font-bold cursor-pointer'
                            : (getAnswered(qi)
                                ? 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full bg-primary text-white text-xs font-bold cursor-pointer'
                                : 'w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant text-xs font-medium cursor-pointer hover:border-primary hover:text-primary');
                    }
                    return `<button type="button" class="${cls}" onclick="goToQuestion(${qi})">${qi + 1}</button>`;
                };

                // Render all question buttons so they can wrap dynamically
                for (let qi = 0; qi < total; qi++) {
                    html += mkBtn(qi);
                }
                if (navBar) navBar.innerHTML = html;
                const dmNavBar = document.getElementById('danhMucBottomNavBar');
                if (dmNavBar) {
                    dmNavBar.innerHTML = `<span class="text-[#1e40af] font-extrabold text-lg px-4">Câu ${currentQ + 1} / ${total}</span>`;
                }

                // Update modal dots
                document.querySelectorAll('.q-modal-dot').forEach(btn => {
                    const qi = parseInt(btn.dataset.qidx);
                    let cls = 'q-modal-dot aspect-square flex items-center justify-center rounded-full text-sm transition-all border ';
                    if (isReviewMode) {
                        const corr = isQuestionCorrect(qi);
                        if (qi === currentQ) {
                            cls += 'ring-2 ring-[#27448d] ring-offset-2 font-bold ' +
                                (corr === true ? 'bg-emerald-600 text-white border-emerald-600' : (corr === false ? 'bg-rose-600 text-white border-rose-600' : 'bg-slate-600 text-white border-slate-600'));
                        } else {
                            cls += 'font-medium ' + (corr === true ? 'bg-emerald-100 border-emerald-500 text-emerald-800' : (corr === false ? 'bg-rose-100 border-rose-500 text-rose-800' : 'bg-slate-100 border-slate-300 text-slate-600'));
                        }
                    } else {
                        if (qi === currentQ) cls += 'bg-white text-[#27448d] border-2 border-[#27448d] font-bold';
                        else if (getAnswered(qi)) cls += 'bg-[#27448d] text-white border-[#27448d] font-bold';
                        else cls += 'border border-gray-200 text-gray-700 bg-white font-medium hover:bg-gray-50';
                    }
                    btn.className = cls;
                });
            }

            function toggleQuestionList() {
                const root = document.getElementById('examRoot');
                if (!root) return;

                const isTurningOn = !root.classList.contains('danhmuccauhoi-mode');
                root.classList.toggle('danhmuccauhoi-mode');

                if (isTurningOn) {
                    // Rebuild the side list grid
                    const grid = document.getElementById('danhMucQuestionGrid');
                    if (grid) {
                        const getAnswered = (qi) => flatAnswers[qi] !== null && flatAnswers[qi] !== undefined && flatAnswers[qi] !== -1;
                        grid.innerHTML = allQuestions.map((qObj, qi) => {
                            let cls = 'q-modal-dot aspect-square flex items-center justify-center rounded-full text-sm transition-all border ';
                            if (isReviewMode) {
                                const corr = isQuestionCorrect(qi);
                                if (qi === currentQ) {
                                    cls += 'ring-2 ring-[#27448d] ring-offset-2 font-bold ' +
                                        (corr === true ? 'bg-emerald-600 text-white border-emerald-600' : (corr === false ? 'bg-rose-600 text-white border-rose-600' : 'bg-slate-600 text-white border-slate-600'));
                                } else {
                                    cls += 'font-medium ' + (corr === true ? 'bg-emerald-100 border-emerald-500 text-emerald-800' : (corr === false ? 'bg-rose-100 border-rose-500 text-rose-800' : 'bg-slate-100 border-slate-300 text-slate-600'));
                                }
                            } else {
                                if (qi === currentQ) cls += 'bg-white text-[#27448d] border-2 border-[#27448d] font-bold';
                                else if (getAnswered(qi)) cls += 'bg-[#27448d] text-white border-[#27448d] font-bold';
                                else cls += 'border border-gray-200 text-gray-700 bg-white font-medium hover:bg-gray-50';
                            }
                            return `<button type="button" class="${cls}" data-qidx="${qi}" onclick="goToQuestion(${qi});">${qi + 1}</button>`;
                        }).join('');
                    }
                }
                updateNavBar();
            }

            function saveDraft() {
                let contentToSave = isQuiz ? JSON.stringify(answers) : (isTF ? JSON.stringify(tfAnswers) : (isExam ? JSON.stringify(examAnswers) : (document.getElementById('essayText') ? document.getElementById('essayText').value : '')));
                localStorage.setItem('submission_draft_' + assignmentId, JSON.stringify({ content: contentToSave, fileUrl: document.getElementById('essayFile') ? document.getElementById('essayFile').value : '' }));
            }

            function restoreDraft() {
                const draftStr = localStorage.getItem('submission_draft_' + assignmentId);
                if (!draftStr) return;
                try {
                    const draft = JSON.parse(draftStr);
                    if (draft.fileUrl) {
                        const el = document.getElementById('essayFile'); if (el) el.value = draft.fileUrl;
                        const st = document.getElementById('uploadStatus'); if (st) st.innerHTML = 'Đã phục hồi file: <a href="' + draft.fileUrl + '" target="_blank" class="text-blue-600 underline">Xem</a>';
                    }
                    if (isQuiz) JSON.parse(draft.content).forEach((ans, idx) => { if (ans !== -1) answers[idx] = ans; });
                    else if (isTF) JSON.parse(draft.content).forEach((val, idx) => { if (val) { tfAnswers[idx] = val;['a', 'b', 'c', 'd'].forEach((l, i) => { if (val[l]) selectTFAnswer(idx, i, val[l]); }); } });
                    else if (isExam) {
                        const parsed = JSON.parse(draft.content);
                        if (parsed.quiz) parsed.quiz.forEach((ans, idx) => { if (ans !== -1) selectExamQuizAnswer(idx, ans); });
                        if (parsed.tf) parsed.tf.forEach((val, idx) => { if (val) ['a', 'b', 'c', 'd'].forEach((l, i) => { if (val[l]) selectExamTFAnswer(idx, i, val[l]); }); });
                        if (parsed.essay) document.querySelectorAll('textarea.auto-resize').forEach((t, i) => { if (parsed.essay[i]) { t.value = parsed.essay[i]; examAnswers.essay[i] = parsed.essay[i]; } });
                    } else { const el = document.getElementById('essayText'); if (el) el.value = draft.content; }
                } catch (e) { console.error(e); }
            }

            function uploadFile() {
                const fileInput = document.getElementById('fileUploadInput'), statusEl = document.getElementById('uploadStatus');
                if (!fileInput.files.length) return;
                const formData = new FormData(); formData.append("file", fileInput.files[0]);
                statusEl.textContent = "Đang tải...";
                fetch("/Student/UploadFile", { method: "POST", body: formData }).then(r => r.json()).then(data => {
                    if (data.success) {
                        document.getElementById('essayFile').value = data.fileUrl;
                        statusEl.innerHTML = "Thành công: <a href='" + data.fileUrl + "' target='_blank' class='text-blue-600 underline'>" + fileInput.files[0].name + "</a>";
                        saveDraft();
                    } else statusEl.textContent = "Lỗi: " + data.message;
                });
            }
