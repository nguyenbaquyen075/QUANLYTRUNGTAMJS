                                                    <div style="text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem;">
                                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                            <span class="badge-custom badge-success" style="font-size: 0.75rem; padding: 0.35rem 0.75rem;">Đã hoàn thành</span>
                                                            <button type="button" class="btn-secondary-custom" style="font-size: 0.72rem; padding: 0.25rem 0.5rem; text-decoration: none;" onclick="openSubmissionDetailModalById('<%= q.Id %>')">
                                                                <i class="fa-solid fa-eye"></i> Xem bài làm
                                                            </button>
                                                        </div>
                                                        <% if (sub) { %>
                                                            <script>
                                                                if (!window.studentSubmissions) window.studentSubmissions = {};
                                                                window.studentSubmissions['<%= q.Id %>'] = {
                                                                    AssignmentTitle: <%- JSON.stringify(q.Title) %>,
