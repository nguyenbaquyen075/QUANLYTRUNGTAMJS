<script>
    function switchDashboardTab(tabId) {
        // Toggle Active menu class
        document.querySelectorAll('.sidebar-item').forEach(btn => {
            if (btn.getAttribute('data-tab') === tabId) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Toggle Active pane
        document.querySelectorAll('.tab-pane').forEach(pane => {
            if (pane.id === `tab-${tabId}`) {
                pane.classList.add('active');
            } else {
                pane.classList.remove('active');
            }
        });
    }

    // Auto navigate to deep linked tabs if hash exists
    window.addEventListener('DOMContentLoaded', () => {
        const hash = window.location.hash.substring(1);
        if (hash && document.getElementById(`tab-${hash}`)) {
            switchDashboardTab(hash);
        }
    });

    function openModal(id) {
        document.getElementById(id).style.display = 'flex';
    }

    function closeModal(id) {
        document.getElementById(id).style.display = 'none';
    }

    function openLessonDetailModal(l) {
        document.getElementById('detailLessonClass').textContent = l.ClassName;
        document.getElementById('detailLessonTitle').textContent = l.Title;
        document.getElementById('detailLessonTeacher').textContent = l.TeacherName;
        document.getElementById('detailLessonDate').textContent = l.DateStr;
        document.getElementById('detailLessonTime').textContent = l.TimeStr;
        
        // Status badge style & text
        const statusBadge = document.getElementById('detailLessonStatus');
        if (l.Status == 1) {
            statusBadge.textContent = 'Đang học';
            statusBadge.className = 'badge-custom badge-danger';
            statusBadge.style.backgroundColor = '#EF4444';
            statusBadge.style.color = 'white';
        } else if (l.Status == 2) {
            statusBadge.textContent = 'Đã kết thúc';
            statusBadge.className = 'badge-custom';
            statusBadge.style.backgroundColor = '#F1F5F9';
            statusBadge.style.color = '#64748B';
        } else if (l.Status == 3) {
            statusBadge.textContent = 'Đã hủy';
            statusBadge.className = 'badge-custom badge-danger';
            statusBadge.style.backgroundColor = '#64748B';
            statusBadge.style.color = 'white';
        } else {
            statusBadge.textContent = 'Sắp diễn ra';
            statusBadge.className = 'badge-custom badge-warning';
            statusBadge.style.backgroundColor = '';
            statusBadge.style.color = '';
        }
        
        // Meeting Info
        const meetingSection = document.getElementById('detailLessonMeetingSection');
        if (l.MeetingUrl && l.Status != 2) {
            meetingSection.style.display = 'block';
            document.getElementById('detailLessonMeetingId').textContent = l.MeetingId || 'Không có ID';
            document.getElementById('detailLessonMeetingPassword').textContent = l.MeetingPassword || 'Không có mật khẩu';
            document.getElementById('detailLessonMeetingBtn').href = l.MeetingUrl;
        } else {
            meetingSection.style.display = 'none';
        }
        
        // Video replay
        const videoSection = document.getElementById('detailLessonVideoSection');
        const videoBtn = document.getElementById('detailLessonVideoBtn');
        const videoLockMsg = document.getElementById('detailLessonVideoLocked');
        if (l.VideoUrl) {
            videoSection.style.display = 'block';
            if (l.IsAttended) {
                videoBtn.style.display = 'flex';
                videoBtn.href = l.VideoUrl;
                if (videoLockMsg) videoLockMsg.style.display = 'none';
            } else {
                videoBtn.style.display = 'none';
                if (videoLockMsg) videoLockMsg.style.display = 'flex';
            }
        } else {
            videoSection.style.display = 'none';
        }
        
        // Documents
        const docContainer = document.getElementById('detailLessonDocContainer');
        docContainer.innerHTML = '';
        if (l.DocumentUrl) {
            const docBox = document.createElement('div');
            docBox.style.cssText = 'display: flex; align-items: center; justify-content: space-between; padding: 0.75rem; background: #ECFDF5; border-radius: 8px; border: 1px solid #A7F3D0; margin-top: 0.5rem;';
            docBox.innerHTML = `
                <span style="font-size: 0.85rem; color: #065F46; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 70%;" title="${l.DocumentName || 'Xem tài liệu'}"><i class="fa-solid fa-file-pdf"></i> ${l.DocumentName || 'Tài liệu học tập'}</span>
                <a href="${l.DocumentUrl}" target="_blank" class="btn-custom" style="font-size: 0.78rem; padding: 0.3rem 0.75rem; text-decoration: none; background: #059669; border-color: #059669; color: white;"><i class="fa-solid fa-download"></i> Tải xuống</a>
            `;
            docContainer.appendChild(docBox);
        } else {
            const emptyMsg = document.createElement('p');
            emptyMsg.style.cssText = 'margin: 0; font-size: 0.85rem; color: #64748B; font-style: italic;';
            emptyMsg.textContent = 'Giảng viên chưa đính kèm tài liệu cho buổi học này.';
            docContainer.appendChild(emptyMsg);
        }
        
        openModal('lessonDetailsModal');
    }

    function openLessonDetailModalById(lessonId) {
        if (!window.studentLessons || !window.studentLessons[lessonId]) {
            alert('Không tìm thấy dữ liệu buổi học.');
            return;
        }
        openLessonDetailModal(window.studentLessons[lessonId]);
    }

    function openSubmissionDetailModalById(assignmentId) {
        if (!window.studentSubmissions || !window.studentSubmissions[assignmentId]) {
            alert('Không tìm thấy dữ liệu bài làm.');
            return;
        }
        const data = window.studentSubmissions[assignmentId];
        
        document.getElementById('subModalTitle').textContent = data.AssignmentTitle || 'Chi tiết bài làm';
        document.getElementById('subModalInstruction').textContent = data.AssignmentInstruction || 'Không có mô tả hoặc đề bài.';
        
        const attachmentSection = document.getElementById('subModalAssignAttachment');
        if (data.AssignmentAttachmentUrl) {
            attachmentSection.style.display = 'block';
            document.getElementById('subModalAssignAttachmentLink').href = data.AssignmentAttachmentUrl;
        } else {
            attachmentSection.style.display = 'none';
        }
        
        document.getElementById('subModalSubmittedAt').textContent = data.SubmittedAt || '-';
        
        const contentBox = document.getElementById('subModalContent');
        const quizContainer = document.getElementById('subModalQuizContainer');
        
        if (data.AssignmentType == 0) { // QUIZ (Trắc nghiệm)
            contentBox.style.display = 'none';
            quizContainer.style.display = 'flex';
            quizContainer.innerHTML = '';
            
            let quizQuestions = [];
            let answersParsed = [];
            try {
                quizQuestions = JSON.parse(data.QuizData || '[]');
                answersParsed = JSON.parse(data.SubmissionContent || '[]');
            } catch(e) {
                console.error(e);
            }
            
            if (Array.isArray(quizQuestions) && quizQuestions.length > 0) {
                quizQuestions.forEach((q, qIdx) => {
                    const studentAns = Array.isArray(answersParsed) ? answersParsed[qIdx] : -1;
                    const correctAns = q.correct_index;
                    const opts = ['A', 'B', 'C', 'D'];
                    
                    const qDiv = document.createElement('div');
                    qDiv.style.cssText = 'border-bottom: 1px dashed #E2E8F0; padding-bottom: 1rem;';
                    
                    let optionsHtml = '';
                    opts.forEach((letter, optIdx) => {
                        let bgStyle = 'background: white; border: 1px solid #E2E8F0; color: #1E293B;';
                        let icon = '';
                        if (optIdx == correctAns) {
                            bgStyle = 'background: #DEF7EC; border: 1px solid #31C48D; color: #03543F; font-weight: 600;';
                            icon = ' <span style="margin-left: auto; color: #31C48D; font-size: 0.8rem; font-weight: bold; display: flex; align-items: center; gap: 0.2rem;"><i class="fa-solid fa-circle-check"></i> Đáp án đúng</span>';
                        } else if (optIdx == studentAns) {
                            bgStyle = 'background: #FDE8E8; border: 1px solid #F8B4B4; color: #9B1C1C;';
                            icon = ' <span style="margin-left: auto; color: #F8B4B4; font-size: 0.8rem; font-weight: bold; display: flex; align-items: center; gap: 0.2rem;"><i class="fa-solid fa-circle-xmark"></i> Bạn chọn sai</span>';
                        }
                        
                        optionsHtml += `
                            <div style="padding: 0.5rem; border-radius: 8px; font-size: 0.85rem; display: flex; align-items: center; text-align: left; ${bgStyle}">
                                <strong style="margin-right: 0.4rem;">${letter}.</strong> ${q.options ? (q.options[optIdx] || '') : ''}
                                ${icon}
                            </div>
                        `;
                    });
                    
                    qDiv.innerHTML = `
                        <div style="font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; display: flex; align-items: flex-start; gap: 0.4rem;">
                            <span style="background: var(--primary); color: white; border-radius: 4px; padding: 0.05rem 0.35rem; font-size: 0.75rem; flex-shrink: 0; margin-top: 0.1rem;">Câu ${qIdx + 1}</span>
                            <span>${q.question || q.question_text || ''}</span>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr; gap: 0.5rem; margin-top: 0.5rem;">
                            ${optionsHtml}
                        </div>
