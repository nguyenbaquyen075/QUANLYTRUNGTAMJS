                                        <span class="badge-custom badge-success" style="font-size: 0.8rem; padding: 0.4rem 0.8rem;"><i class="fa-solid fa-check"></i> Đang học</span>
                                    <% } else { %>
                                        <a href="/Home/Courses" class="btn-custom" style="font-size: 0.8rem; padding: 0.45rem 1rem; text-decoration: none;"><i class="fa-solid fa-cart-shopping"></i> Mua ngay</a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <!-- TAB 3: LỊCH HỌC -->
        <div id="tab-schedule" class="tab-pane">
            <div style="margin-bottom: 2rem;">
                <h2 style="font-size: 1.5rem; font-weight: 800; color: #0F172A; margin: 0;">Lịch Học Lớp</h2>
                <p style="color: #64748B; margin: 0.25rem 0 0 0; font-size: 0.9rem;">Xem và theo dõi lịch trình chi tiết các buổi học trực tuyến theo từng lớp học.</p>
            </div>

            <% if (typeof enrollments === 'undefined' || enrollments.length === 0) { %>
                <div style="text-align: center; padding: 4rem 2rem; background: white; border-radius: 16px; border: 1px solid #E2E8F0;">
                    <i class="fa-regular fa-calendar-xmark" style="font-size: 3rem; color: #94A3B8; margin-bottom: 1rem;"></i>
                    <h4 style="font-weight: 700; color: #0F172A; margin: 0;">Bạn chưa tham gia lớp học nào</h4>
                    <p style="color: #64748B; font-size: 0.85rem; margin-top: 0.5rem;">Vui lòng đăng ký khóa học để xem lịch lớp học.</p>
                </div>
            <% } else { %>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <% enrollments.forEach((e, idx) => { %>
                        <% const classLessons = typeof lessons !== 'undefined' && lessons ? lessons.filter(l => l.ClassId === e.ClassId) : []; %>
                        
                        <details class="course-accordion">
                            <summary>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <div style="width: 40px; height: 40px; border-radius: 10px; background: rgba(30, 58, 138, 0.08); color: #1e3a8a; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <i class="fa-solid fa-graduation-cap"></i>
                                    </div>
                                    <div style="text-align: left;">
                                        <span style="font-size: 0.78rem; color: #64748B; display: block; font-weight: 500;"><%= e.Class && e.Class.Course ? e.Class.Course.Title : 'Khóa học' %></span>
                                        <strong style="font-size: 1.05rem; color: #1E293B;"><%= e.Class ? e.Class.ClassName : '' %></strong>
                                    </div>
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 0.75rem; background: #E2E8F0; color: #475569; padding: 0.2rem 0.6rem; border-radius: 9999px; font-weight: 600;"><%= classLessons.length %> buổi học</span>
                                    <i class="fa-solid fa-chevron-down text-slate-400"></i>
                                </div>
                            </summary>
                            <div class="course-accordion-content">
                                <% if (classLessons.length === 0) { %>
                                    <p style="text-align: center; color: #64748B; font-size: 0.85rem; margin: 1.5rem 0;">Chưa có lịch học nào được tạo cho lớp học này.</p>
                                <% } else { %>
                                    <% classLessons.forEach(l => { %>
                                        <% const isPast = new Date(l.LessonDate) < new Date(); %>
                                        <div class="schedule-item" style="margin-bottom: 0.5rem; <%= isPast ? 'opacity: 0.75;' : '' %> cursor: pointer; transition: background 0.15s;" onmouseover="this.style.background='#faf8f0'" onmouseout="this.style.background='transparent'" onclick="if(!event.target.closest('a') && !event.target.closest('button')) openLessonDetailModalById('<%= l.Id %>')">
                                            <script>
                                                if (!window.studentLessons) window.studentLessons = {};
                                                window.studentLessons['<%= l.Id %>'] = {
                                                    Title: <%- JSON.stringify(l.Title) %>,
                                                    DateStr: '<%= new Date(l.LessonDate).toLocaleDateString("vi-VN") %>',
                                                    TimeStr: '<%= formatTime(l.StartTime) %> - <%= formatTime(l.EndTime) %>',
                                                    MeetingUrl: '<%= l.MeetingUrl || "" %>',
                                                    MeetingId: '<%= l.MeetingId || "" %>',
                                                    MeetingPassword: '<%= l.MeetingPassword || "" %>',
                                                    VideoUrl: '<%= l.VideoUrl || "" %>',
                                                    DocumentUrl: '<%= l.DocumentUrl || "" %>',
                                                    DocumentName: <%- JSON.stringify(l.DocumentName || "") %>,
                                                    ClassName: <%- JSON.stringify(e.Class ? e.Class.ClassName : "") %>,
                                                    TeacherName: <%- JSON.stringify((e.Class && e.Class.Teacher) ? e.Class.Teacher.FullName : "Chưa phân công") %>,
                                                    Status: <%= l.Status %>,
                                                    IsAttended: <%= l.IsAttended ? 'true' : 'false' %>
                                                };
                                            </script>
                                            <div style="display: flex; align-items: center; gap: 1.25rem;">
                                                <div style="background: #EFF6FF; color: var(--primary); border-radius: 12px; width: 52px; height: 52px; display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid #BFDBFE;">
                                                    <span style="font-size: 0.65rem; text-transform: uppercase; font-weight: 800;">T. <%= new Date(l.LessonDate).getMonth() + 1 %></span>
                                                    <strong style="font-size: 1.2rem; font-weight: 800; line-height: 1.1;"><%= new Date(l.LessonDate).getDate() %></strong>
                                                </div>
                                                <div>
                                                    <h4 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #1E293B;"><%= l.Title %></h4>
                                                    <p style="margin: 0.2rem 0 0 0; font-size: 0.8rem; color: #64748B;"><i class="fa-regular fa-clock"></i> Giờ học: <%= formatTime(l.StartTime) %> - <%= formatTime(l.EndTime) %></p>
                                                </div>
                                            </div>
                                            <div>
                                                <% if (l.Status === 1) { %>
                                                    <div style="display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
                                                        <span class="badge-custom badge-danger" style="font-size: 0.75rem; padding: 0.4rem 0.8rem; background-color: #EF4444; color: white;">Đang diễn ra</span>
                                                        <a href="/Student/Classroom/<%= l.ClassId %>" class="btn-custom" style="background: #10B981; border-color: #10B981; color: white; font-size: 0.8rem; padding: 0.5rem 1rem; text-decoration: none; font-weight: 700; border-radius: 8px; display: inline-flex; align-items: center; gap: 0.25rem;"><i class="fa-solid fa-circle-play"></i> Vào học</a>
                                                    </div>
                                                <% } else if (!isPast) { %>
                                                    <span class="badge-custom badge-warning" style="font-size: 0.75rem; padding: 0.4rem 0.8rem;">Sắp diễn ra</span>
                                                <% } else { %>
                                                    <span class="badge-custom" style="font-size: 0.75rem; padding: 0.4rem 0.8rem; background: #F1F5F9; color: #64748B;">Lớp đã đóng</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } %>
                            </div>
                        </details>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- TAB 4: BÀI TẬP VỀ NHÀ -->
        <div id="tab-assignments" class="tab-pane">
            <div style="margin-bottom: 2rem;">
                <h2 style="font-size: 1.5rem; font-weight: 800; color: #0F172A; margin: 0;">Bài Tập Về Nhà</h2>
