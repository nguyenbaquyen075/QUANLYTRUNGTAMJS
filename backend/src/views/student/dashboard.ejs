                quizContainer.innerHTML = '<p style="font-size:0.85rem; color:#64748B; font-style:italic;">Không có dữ liệu câu hỏi.</p>';
            }
        } else if (data.AssignmentType == 2) { // TRUE_FALSE (Đúng/Sai)
            contentBox.style.display = 'none';
            quizContainer.style.display = 'flex';
            quizContainer.innerHTML = '';
            
            let tfQuestions = [];
            let answersParsed = {};
            try {
                tfQuestions = JSON.parse(data.QuizData || '[]');
                answersParsed = JSON.parse(data.SubmissionContent || '{}');
            } catch(e) {
                console.error(e);
            }
            
