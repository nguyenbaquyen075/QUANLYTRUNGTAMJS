                                                                    AssignmentAttachmentUrl: '',
                                                                    SubmissionContent: <%- JSON.stringify(sub.Content || '') %>,
                                                                    SubmissionFileUrl: '',
                                                                    Grade: '<%= sub.Grade !== null ? sub.Grade : "10" %>',
                                                                    TeacherComment: <%- JSON.stringify(sub.TeacherComment || 'Hệ thống tự động chấm điểm.') %>,
                                                                    SubmittedAt: '<%= new Date(sub.SubmittedAt).toLocaleString("vi-VN") %>',
                                                                    GradedAt: '<%= sub.GradedAt ? new Date(sub.GradedAt).toLocaleString("vi-VN") : "" %>',
                                                                    AssignmentType: <%= q.AssignmentType %>,
