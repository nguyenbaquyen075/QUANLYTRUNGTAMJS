                examQuestions.essay.forEach((q, qIdx) => {
                    const studentAns = (answersParsed && answersParsed.essay) ? answersParsed.essay[qIdx] : '';
                    
                    const qDiv = document.createElement('div');
                    qDiv.style.cssText = 'border-bottom: 1px dashed #E2E8F0; padding-bottom: 1rem; margin-left: 0.5rem;';
                    
