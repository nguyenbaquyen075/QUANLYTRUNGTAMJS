    function showCourseProgressDetails(classId) {
        const data = window.courseLessonsMap[classId];
        if (!data) return;

        // Set header info
        document.getElementById('progressModalClass').textContent = data.ClassName;
        document.getElementById('progressModalCourseTitle').textContent = data.CourseTitle;
        document.getElementById('progressModalTeacher').textContent = 'Giảng viên phụ trách: ' + data.TeacherName;

        // Set progress bar
        document.getElementById('progressModalPercent').textContent = data.Percent + '%';
        document.getElementById('progressModalBar').style.width = data.Percent + '%';
        document.getElementById('progressModalStats').textContent = `Đã học: ${data.Finished} / ${data.Total} buổi`;

        // Render lessons
        const container = document.getElementById('progressModalLessonsContainer');
        container.innerHTML = '';

        if (data.Lessons.length === 0) {
            container.innerHTML = '<p style="font-size: 0.85rem; color: #94A3B8; font-style: italic; margin: 0;">Chưa có buổi học nào được tạo cho lớp này.</p>';
        } else {
            data.Lessons.forEach(l => {
                let attText = 'Chưa học';
                let attColor = '#64748B';
                let attBg = '#F1F5F9';

                if (l.IsFinished) {
                    if (l.AttendanceStatus === 0) { attText = 'Có mặt'; attColor = '#10B981'; attBg = '#ECFDF5'; }
                    else if (l.AttendanceStatus === 1) { attText = 'Đi muộn'; attColor = '#D97706'; attBg = '#FFFBEB'; }
                    else if (l.AttendanceStatus === 2) { attText = 'Vắng có phép'; attColor = '#2563EB'; attBg = '#EFF6FF'; }
                    else if (l.AttendanceStatus === 3) { attText = 'Vắng không phép'; attColor = '#EF4444'; attBg = '#FEF2F2'; }
                    else { attText = 'Đã kết thúc'; attColor = '#475569'; attBg = '#E2E8F0'; }
                } else if (l.Status === 1) {
                    attText = 'Đang diễn ra'; attColor = '#2563EB'; attBg = '#EFF6FF';
                }

                let replayButtons = '';
                if (l.IsFinished && (l.VideoUrl || l.DocumentUrl)) {
                    replayButtons = `<div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">`;
                    if (l.VideoUrl) {
                        if (l.IsAttended) {
                            replayButtons += `<a href="${l.VideoUrl}" target="_blank" class="btn-custom" style="font-size: 0.72rem; padding: 0.25rem 0.6rem; text-decoration: none; background: #2563EB; border-color: #2563EB; color: white;">Xem lại video</a>`;
                        } else {
                            replayButtons += `<button type="button" onclick="alert('Bạn chưa được điểm danh buổi học này. Video xem lại chỉ có thể truy cập sau khi giáo viên xác nhận điểm danh.')" style="font-size: 0.72rem; padding: 0.25rem 0.6rem; background: #FEF3C7; border: 1px dashed #D97706; border-radius: 6px; color: #92400E; cursor: pointer; display: inline-flex; align-items: center; gap: 0.3rem;"><i class="fa-solid fa-lock"></i> Xem lại video</button>`;
                        }
                    }
                    if (l.DocumentUrl) {
                        replayButtons += `<a href="${l.DocumentUrl}" target="_blank" class="btn-custom" style="font-size: 0.72rem; padding: 0.25rem 0.6rem; text-decoration: none; background: #E2E8F0; border-color: #E2E8F0; color: #334155;">Tài liệu</a>`;
                    }
                    replayButtons += `</div>`;
                }

                const item = document.createElement('div');
                item.style.cssText = 'background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 10px; padding: 0.85rem 1rem; display: flex; flex-direction: column; gap: 0.5rem;';
                item.innerHTML = `
                    <div style="display: flex; justify-content: space-between; align-items: start; gap: 1rem;">
                        <div>
                            <span style="font-size: 0.7rem; color: #94A3B8; font-weight: 600; display: block; margin-bottom: 0.15rem;">BUỔI ${l.Idx} • ${l.DateStr}</span>
                            <strong style="font-size: 0.88rem; color: #1F2937; display: block; line-height: 1.4;">${l.Title}</strong>
                        </div>
                        <span style="font-size: 0.7rem; font-weight: 700; color: ${attColor}; background: ${attBg}; padding: 0.2rem 0.6rem; border-radius: 4px; white-space: nowrap; height: fit-content;">${attText}</span>
                    </div>
                    ${replayButtons}
                `;
                container.appendChild(item);
            });
        }

        openModal('courseProgressModal');
    }
</script>
