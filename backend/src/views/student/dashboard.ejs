                                                        <strong style="display: block; font-size: 0.9rem; font-weight: 800; color: #10B981; margin: 0;">Điểm: <%= sub && sub.Grade !== null ? Number(sub.Grade).toFixed(1) : '10' %>/10</strong>
                                                    </div>
                                                <% } else { %>
                                                    <a href="/Student/DoAssignment/<%= q.Id %>" class="btn-custom" style="font-size: 0.8rem; padding: 0.45rem 1rem; background: #10B981; border-color: #10B981; text-decoration: none;"><i class="fa-solid fa-circle-play"></i> Bắt đầu Test</a>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } %>
                            </div>
                        </details>
                    <% }) %>
                </div>
