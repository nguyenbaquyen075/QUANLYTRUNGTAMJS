                <% if (typeof submissions === 'undefined' || submissions.length === 0) { %>
                    <p style="color: #64748B; font-size: 0.85rem; text-align: center; padding: 2rem 0;">Chưa có điểm số nào được công bố.</p>
                <% } else { %>
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 0.85rem;">
                            <thead>
                                <tr style="border-bottom: 2px solid #F1F5F9; color: #475569; font-weight: 600;">
                                    <th style="padding: 0.75rem;">Bài kiểm tra / Bài tập</th>
                                    <th style="padding: 0.75rem;">Lớp học</th>
                                    <th style="padding: 0.75rem;">Ngày nộp</th>
                                    <th style="padding: 0.75rem; text-align: center;">Điểm số</th>
                                    <th style="padding: 0.75rem;">Lời phê giáo viên</th>
                                    <th style="padding: 0.75rem; text-align: center;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% submissions.forEach(s => { %>
                                    <tr style="border-bottom: 1px solid #F1F5F9; transition: background 0.15s;" onmouseover="this.style.background='#F8FAFC'" onmouseout="this.style.background='transparent'">
                                        <td style="padding: 0.75rem; font-weight: 600; color: #0F172A;"><%= s.Assignment ? s.Assignment.Title : '' %></td>
                                        <td style="padding: 0.75rem; color: #64748B;"><%= s.Assignment && s.Assignment.Lesson && s.Assignment.Lesson.Class ? s.Assignment.Lesson.Class.ClassName : '' %></td>
                                        <td style="padding: 0.75rem; color: #64748B;"><%= new Date(s.SubmittedAt).toLocaleString('vi-VN') %></td>
                                        <td style="padding: 0.75rem; text-align: center;">
                                            <% if (s.Grade !== null) { %>
                                                <strong style="color: #10B981; font-size: 0.95rem;"><%= Number(s.Grade).toFixed(1) %> / 10</strong>
                                            <% } else { %>
                                                <span style="color: #94A3B8; font-style: italic;">Chờ chấm</span>
                                            <% } %>
                                        </td>
                                        <td style="padding: 0.75rem; color: #475569; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= s.TeacherComment || '' %>">
                                            <%= s.TeacherComment || 'Chưa có nhận xét' %>
                                        </td>
                                        <td style="padding: 0.75rem; text-align: center;">
                                            <button type="button" class="btn-secondary-custom" style="padding: 0.25rem 0.6rem; font-size: 0.78rem;" onclick="openSubmissionDetailModalById('<%= s.AssignmentId %>')">
                                                <i class="fa-solid fa-eye"></i> Xem bài
                                            </button>
                                            <script>
                                                if (!window.studentSubmissions) window.studentSubmissions = {};
                                                window.studentSubmissions['<%= s.AssignmentId %>'] = {
                                                    AssignmentTitle: <%- JSON.stringify(s.Assignment ? s.Assignment.Title : '') %>,
                                                    AssignmentInstruction: <%- JSON.stringify(s.Assignment ? s.Assignment.Instruction || '' : '') %>,
                                                    AssignmentAttachmentUrl: '<%= s.Assignment ? s.Assignment.AttachmentUrl || "" : "" %>',
                                                    SubmissionContent: <%- JSON.stringify(s.Content || '') %>,
                                                    SubmissionFileUrl: '<%= s.FileUrl || "" %>',
                                                    Grade: '<%= s.Grade !== null ? s.Grade : "" %>',
                                                    TeacherComment: <%- JSON.stringify(s.TeacherComment || '') %>,
                                                    SubmittedAt: '<%= new Date(s.SubmittedAt).toLocaleString("vi-VN") %>',
                                                    GradedAt: '<%= s.GradedAt ? new Date(s.GradedAt).toLocaleString("vi-VN") : "" %>',
                                                    AssignmentType: <%= s.Assignment ? s.Assignment.AssignmentType : 1 %>,
                                                    QuizData: <%- JSON.stringify((s.Assignment && s.Assignment.QuizData) ? s.Assignment.QuizData : '') %>
                                                };
                                            </script>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>

