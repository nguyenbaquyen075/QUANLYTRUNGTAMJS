                                        <i class="fa-solid fa-book-open-reader"></i>
                                    </div>
                                    <div style="text-align: left;">
                                        <span style="font-size: 0.78rem; color: #64748B; display: block; font-weight: 500;"><%= e.Class && e.Class.Course ? e.Class.Course.Title : 'Khóa học' %></span>
                                        <strong style="font-size: 1.05rem; color: #1E293B;"><%= e.Class ? e.Class.ClassName : '' %></strong>
                                    </div>
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 0.75rem; background: #E2E8F0; color: #475569; padding: 0.2rem 0.6rem; border-radius: 9999px; font-weight: 600;"><%= classAssignments.length %> bài tập</span>
                                    <i class="fa-solid fa-chevron-down text-slate-400"></i>
                                </div>
                            </summary>
                            <div class="course-accordion-content">
                                <% if (classAssignments.length === 0) { %>
                                    <p style="text-align: center; color: #64748B; font-size: 0.85rem; margin: 1.5rem 0;">Chưa có bài tập tự luận nào được giao cho lớp học này.</p>
                                <% } else { %>
                                    <% classAssignments.forEach(a => { %>
                                        <% const isSub = isSubmitted(a.Id); %>
                                        <% const sub = getSubmission(a.Id); %>
                                        <% const isOverdue = new Date(a.DueDate) < new Date() && !isSub; %>
                                        
                                        <div class="homework-item" style="margin-bottom: 0.5rem;">
                                            <div>
                                                <h4 style="margin: 0; font-size: 0.95rem; font-weight: 700; color: #1E293B;"><%= a.Title %></h4>
                                                <p style="margin: 0.2rem 0 0 0; font-size: 0.8rem; color: <%= isOverdue ? '#EF4444' : '#64748B' %>; font-weight: <%= isOverdue ? '700' : 'normal' %>">
                                                    <i class="fa-regular fa-calendar-xmark"></i> Hạn nộp: <%= new Date(a.DueDate).toLocaleString('vi-VN') %>
                                                </p>
                                            </div>
                                            <div style="display: flex; align-items: center; gap: 1rem;">
                                                <% if (isSub) { %>
                                                    <div style="text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem;">
                                                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                                                            <span class="badge-custom badge-success" style="font-size: 0.75rem; padding: 0.35rem 0.75rem;">Đã nộp bài</span>
                                                            <button type="button" class="btn-secondary-custom" style="font-size: 0.72rem; padding: 0.25rem 0.5rem; text-decoration: none;" onclick="openSubmissionDetailModalById('<%= a.Id %>')">
                                                                <i class="fa-solid fa-eye"></i> Xem bài làm
                                                            </button>
                                                        </div>
                                                        <% if (sub) { %>
                                                            <script>
                                                                if (!window.studentSubmissions) window.studentSubmissions = {};
                                                                window.studentSubmissions['<%= a.Id %>'] = {
                                                                    AssignmentTitle: <%- JSON.stringify(a.Title) %>,
                                                                    AssignmentInstruction: <%- JSON.stringify(a.Instruction || '') %>,
                                                                    AssignmentAttachmentUrl: '<%= a.AttachmentUrl || "" %>',
                                                                    SubmissionContent: <%- JSON.stringify(sub.Content || '') %>,
                                                                    SubmissionFileUrl: '<%= sub.FileUrl || "" %>',
                                                                    Grade: '<%= sub.Grade !== null ? sub.Grade : "" %>',
                                                                    TeacherComment: <%- JSON.stringify(sub.TeacherComment || '') %>,
                                                                    SubmittedAt: '<%= new Date(sub.SubmittedAt).toLocaleString("vi-VN") %>',
                                                                    GradedAt: '<%= sub.GradedAt ? new Date(sub.GradedAt).toLocaleString("vi-VN") : "" %>',
                                                                    AssignmentType: <%= a.AssignmentType %>,
                                                                    QuizData: <%- JSON.stringify(a.QuizData || '') %>
                                                                };
                                                            </script>
                                                        <% } %>
                                                        <% if (sub && sub.Grade !== null) { %>
                                                            <span style="display: block; font-size: 0.85rem; font-weight: 800; color: #10B981; margin: 0;">Điểm: <%= Number(sub.Grade).toFixed(1) %>/10</span>
                                                        <% } else { %>
                                                            <span style="display: block; font-size: 0.72rem; color: #64748B; margin: 0;">Chờ chấm điểm</span>
                                                        <% } %>
                                                    </div>
                                                <% } else if (isOverdue) { %>
                                                    <span class="badge-custom" style="font-size: 0.75rem; padding: 0.35rem 0.75rem; background: #FEE2E2; color: #EF4444;">Quá hạn nộp</span>
                                                <% } else { %>
                                                    <a href="/Student/DoAssignment/<%= a.Id %>" class="btn-custom" style="font-size: 0.8rem; padding: 0.45rem 1rem; text-decoration: none;"><i class="fa-solid fa-pen-to-square"></i> Làm bài ngay</a>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } %>
                            </div>
                        </details>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- TAB 5: BÀI KIỂM TRA -->
