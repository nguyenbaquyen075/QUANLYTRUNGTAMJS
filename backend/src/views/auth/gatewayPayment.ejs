<% title = "Cổng Thanh Toán Trực Tuyến"; %>

<%
    const courseTitle = (typeof invoice !== 'undefined' && invoice && invoice.Class && invoice.Class.Course) ? invoice.Class.Course.Title : '';
    const paymentContent = (typeof invoice !== 'undefined' && invoice) ? `CKHP ${invoice.InvoiceCode}` : '';
    const amount = (typeof invoice !== 'undefined' && invoice) ? invoice.Amount : 0;
    const invoiceId = (typeof invoice !== 'undefined' && invoice) ? invoice.Id : '';
    const courseId = (typeof invoice !== 'undefined' && invoice && invoice.Class) ? invoice.Class.CourseId : '';
%>

<style>
    .gateway-container {
        max-width: 850px;
        margin: 3.5rem auto;
        padding: 0 1.25rem;
    }
    .gateway-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.03);
        overflow: hidden;
    }
    .gateway-header {
        background: #F8FAFC;
        border-bottom: 1px solid #E2E8F0;
        padding: 2rem 1.5rem;
    }
    .brand-tab {
        flex: 1;
        text-align: center;
        padding: 1.25rem 1rem;
        border: 2px solid #E2E8F0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        background: #ffffff;
    }
    .brand-tab:hover {
        border-color: #CBD5E1;
        transform: translateY(-2px);
    }
    .brand-tab.active-momo {
        border-color: #A50064;
        background: #FFF0F6;
    }
    .brand-tab.active-vnpay {
        border-color: #005BAA;
        background: #F0F7FF;
    }
    .brand-tab.active-zalopay {
        border-color: #007BEE;
        background: #F0F9FF;
    }
    .qr-container {
        background: #F8FAFC;
        border: 1.5px dashed #CBD5E1;
        border-radius: 12px;
        padding: 1.5rem;
        display: inline-block;
    }
    .timer-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: #FEF2F2;
        color: #EF4444;
        font-weight: 700;
        padding: 0.4rem 1rem;
        border-radius: 9999px;
        font-size: 0.9rem;
    }
    .copy-btn {
        background: var(--primary);
        color: white;
        border: none;
        padding: 0.35rem 0.85rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .copy-btn:hover {
        background: var(--primary-hover);
    }
    .btn-confirm {
        background: #10B981;
        color: white;
        font-weight: 700;
        padding: 0.85rem 2rem;
        border-radius: 10px;
        border: none;
        transition: all 0.2s;
    }
    .btn-confirm:hover {
        background: #059669;
        transform: translateY(-1px);
    }
</style>

<div class="gateway-container">
    <div class="gateway-card">
        
        <!-- Header -->
        <div class="gateway-header text-center">
            <h2 class="fw-bold mb-2 text-dark"><i class="fa-solid fa-shield-halved text-primary me-2"></i>Cổng Thanh Toán Trực Tuyến Mock</h2>
            <p class="text-muted mb-0">Đăng ký khóa học: <strong><%= courseTitle %></strong></p>
        </div>

        <div class="card-body p-4 p-md-5">
            
            <!-- Step 1: Choose Wallet / Method -->
            <h5 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-wallet text-primary me-2"></i>Bước 1: Chọn ví điện tử hoặc cổng thanh toán</h5>
            <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
                <div class="brand-tab active-momo" id="tabMomo" onclick="switchGateway('Momo')">
                    <img src="https://upload.wikimedia.org/wikipedia/vi/f/fe/MoMo_Logo.svg" alt="MoMo" style="height: 35px; max-width: 80px; object-fit: contain; margin-bottom: 0.25rem;" />
                    <div class="small fw-bold d-block text-dark mt-1">Ví MoMo</div>
                </div>
                <div class="brand-tab" id="tabVNPay" onclick="switchGateway('VNPay')">
                    <img src="https://images.vietnamnet.vn/files/2019/12/3/vnpay-1.jpg" alt="VNPay" style="height: 35px; max-width: 80px; object-fit: contain; margin-bottom: 0.25rem;" />
                    <div class="small fw-bold d-block text-dark mt-1">VNPay QR</div>
                </div>
                <div class="brand-tab" id="tabZaloPay" onclick="switchGateway('ZaloPay')">
                    <img src="https://cdn.haitrieu.com/wp-content/uploads/2022/10/Logo-ZaloPay-Square.png" alt="ZaloPay" style="height: 35px; max-width: 80px; object-fit: contain; margin-bottom: 0.25rem;" />
                    <div class="small fw-bold d-block text-dark mt-1">ZaloPay</div>
                </div>
            </div>

            <!-- Step 2: Display QR and Info -->
            <div class="row g-4 align-items-center" style="display: flex; flex-direction: row; flex-wrap: wrap;">
                <!-- QR Column -->
                <div class="col-md-6 text-center border-end" style="flex: 1; min-width: 280px; text-align: center;">
                    <div class="qr-container mb-3">
                        <img id="gatewayQr" src="" alt="QR Code Payment" style="width: 220px; height: 220px; object-fit: contain;" />
                    </div>
                    <div class="mb-2">
                        <div class="timer-badge">
                            <i class="fa-regular fa-clock"></i>
                            <span id="countdown">10:00</span>
                        </div>
                    </div>
                    <small class="text-muted d-block" style="display: block; margin-top: 0.5rem;">Mã QR sẽ hết hạn sau thời gian đếm ngược.</small>
                </div>

                <!-- Detail Column -->
                <div class="col-md-6 ps-md-4" style="flex: 1; min-width: 280px; padding-left: 2rem;">
                    <h5 class="fw-bold mb-4 text-dark"><i class="fa-solid fa-circle-info text-primary me-2"></i>Thông tin thanh toán</h5>
                    
                    <div class="mb-3" style="margin-bottom: 1rem;">
                        <label class="text-muted small d-block" style="display:block; font-size:0.75rem; color:#64748B;">Đơn vị nhận</label>
                        <span class="fw-bold text-dark fs-6" id="merchantName" style="font-weight: 700;">TRUNG TAM HOC THEM ONLINE</span>
                    </div>

                    <div class="mb-3" style="margin-bottom: 1rem;">
                        <label class="text-muted small d-block" style="display:block; font-size:0.75rem; color:#64748B;">Số tiền học phí</label>
                        <span class="fw-bold text-danger fs-4" style="font-weight: 800; color: #EF4444; font-size: 1.4rem;"><%= Number(amount).toLocaleString("vi-VN") %> đ</span>
                    </div>

                    <div class="mb-3" style="margin-bottom: 1rem;">
                        <label class="text-muted small d-block" style="display:block; font-size:0.75rem; color:#64748B; margin-bottom: 0.25rem;">Nội dung thanh toán (Bắt buộc giữ nguyên)</label>
                        <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3 border" style="display: flex; align-items: center; background: #F8FAFC; border: 1px solid #E2E8F0; padding: 0.5rem; border-radius: 8px;">
                            <span class="fw-bold text-dark font-monospace text-break" id="payContent" style="font-weight: 700; font-family: monospace;"><%= paymentContent %></span>
                            <button type="button" class="copy-btn ms-auto" style="margin-left: auto;" onclick="copyText('payContent', this)">Copy</button>
                        </div>
                    </div>

                    <div class="alert alert-warning border-0 rounded-3 p-3 mb-0 small" style="background: #FFFBEB; border: 1px solid #FDE68A; padding: 1rem; border-radius: 8px; font-size: 0.85rem; color: #B45309;">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        Vui lòng thực hiện chuyển khoản chính xác số tiền và nội dung để tài khoản được kích hoạt ngay lập tức.
                    </div>
                </div>
            </div>

            <hr class="my-4" style="margin: 2rem 0; border: 0; border-top: 1px solid #E2E8F0;" />

            <!-- Confirm Form -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3" style="display: flex; justify-content: space-between; align-items: center;">
                <a href="/Auth/Checkout?courseId=<%= courseId %>" class="text-muted text-decoration-none order-2 order-md-1" style="color: #64748B; text-decoration: none;">
                    <i class="fa-solid fa-chevron-left me-1"></i>Thay đổi phương thức thanh toán
                </a>
                
                <form method="post" action="/Auth/ConfirmGatewayPayment" class="order-1 order-md-2" id="gatewayConfirmForm">
                    <input type="hidden" name="invoiceId" value="<%= invoiceId %>" />
                    <input type="hidden" name="gateway" id="selectedGateway" value="Momo" />
                    <button type="submit" class="btn btn-confirm">
                        <i class="fa-solid fa-circle-check me-2"></i>Tôi đã thanh toán thành công
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    const amountStr = "<%= amount %>";
    const paymentContent = "<%= paymentContent %>";

    const qrConfigs = {
        Momo: {
            color: "a50064",
            data: `momo://pay?phone=0987654321&amount=${amountStr}&note=${paymentContent}`
        },
        VNPay: {
            color: "005baa",
            data: `vnpay://pay?amount=${amountStr}&note=${paymentContent}`
        },
        ZaloPay: {
            color: "007bee",
            data: `zalopay://pay?amount=${amountStr}&note=${paymentContent}`
        }
    };

    function switchGateway(gateway) {
        // Reset tabs
        document.getElementById("tabMomo").className = "brand-tab";
        document.getElementById("tabVNPay").className = "brand-tab";
        document.getElementById("tabZaloPay").className = "brand-tab";

        // Set active tab
        document.getElementById("tab" + gateway).className = "brand-tab active-" + gateway.toLowerCase();

        // Update hidden field
        document.getElementById("selectedGateway").value = gateway;

        // Update QR Code Image
        const config = qrConfigs[gateway];
        const qrImg = document.getElementById("gatewayQr");
        qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&color=${config.color}&data=${encodeURIComponent(config.data)}`;
    }

    // Copy helper
    function copyText(elementId, btn) {
        const text = document.getElementById(elementId).innerText;
        navigator.clipboard.writeText(text).then(() => {
            const originalText = btn.innerText;
            btn.innerText = "Copied!";
            btn.style.background = "#10B981";
            btn.style.color = "white";
            setTimeout(() => {
                btn.innerText = originalText;
                btn.style.background = "";
                btn.style.color = "";
            }, 1500);
        });
    }

    // Init & Countdown
    document.addEventListener("DOMContentLoaded", function () {
        // Init default Momopay QR
        switchGateway("Momo");

        // Countdown Timer
        let minutes = 9;
        let seconds = 59;
        const countdownEl = document.getElementById("countdown");

        const interval = setInterval(() => {
            if (seconds === 0) {
                if (minutes === 0) {
                    clearInterval(interval);
                    countdownEl.innerText = "Hết hạn";
                    return;
                }
                minutes--;
                seconds = 59;
            } else {
                seconds--;
            }

            const minStr = minutes < 10 ? "0" + minutes : minutes;
            const secStr = seconds < 10 ? "0" + seconds : seconds;
            countdownEl.innerText = `${minStr}:${secStr}`;
        }, 1000);
    });

    document.getElementById('gatewayConfirmForm').addEventListener('submit', function() {
        const btn = this.querySelector('.btn-confirm');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Đang xác thực giao dịch...';
    });
</script>
