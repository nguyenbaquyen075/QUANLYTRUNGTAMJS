<!DOCTYPE html>
<html class="scroll-smooth" lang="vi">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>Đăng Ký Tài Khoản - Trung Tâm Học Thêm Online</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    "colors": {
                        "primary": "#1e3a8a", // Deeper Edu Blue (Blue 900)
                        "on-primary": "#ffffff",
                        "primary-container": "#dbeafe",
                        "on-primary-container": "#172554",
                        "secondary": "#2563eb", // More saturated Blue 600
                        "surface": "#fdfbf7",
                        "on-surface": "#0b1120",
                        "surface-variant": "#f6f4eb",
                        "on-surface-variant": "#334155",
                        "outline": "#94a3b8",
                        "background": "#fdfbf7",
                        "on-background": "#0b1120",
                        "surface-container-low": "#faf8f0",
                        "surface-container": "#f6f4eb",
                        "surface-container-high": "#f0eee2",
                        "surface-container-highest": "#eae8d8",
                        "surface-container-lowest": "#ffffff",
                        "outline-variant": "#cbd5e1",
                        "vibrant-blue": "#1d4ed8", // Darker Blue 700
                        "vibrant-sky": "#0369a1" // Darker Sky 800
                    },
                    "borderRadius": {
                        "DEFAULT": "0.5rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "max-width": "1280px",
                        "gutter": "24px",
                        "margin-mobile": "16px",
                        "margin-desktop": "64px",
                        "base": "8px"
                    },
                    "fontFamily": {
                        "sans": ["Inter", "Manrope", "sans-serif"],
                        "serif": ["Source Serif 4", "serif"]
                    }
                }
            }
        }
    </script>
</head>
<body class="antialiased font-sans bg-surface">
    <%- include('../partials/home-navbar', { activePage: '', isLoggedIn: (typeof isLoggedIn !== 'undefined' ? isLoggedIn : false), currentUserFullName: (typeof currentUserFullName !== 'undefined' ? currentUserFullName : ''), currentUserRole: (typeof currentUserRole !== 'undefined' ? currentUserRole : null) }) %>
    <main class="pt-0">
        
<style>
  .glass-premium {
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .blended-gradient {
      background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
  }

    .register-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 7rem 2rem 3rem 2rem;
        position: relative;
        overflow: hidden;
        box-sizing: border-box;
    }
    .register-container::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: linear-gradient(180deg, rgba(255,255,255,0.45) 0%, rgba(219,234,254,0.35) 100%),
                          url('/images/ryunosuke-kikuno-uIRtLhPN_nQ-unsplash.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        filter: brightness(0.88);
        z-index: 0;
    }
    .register-container::after {
        content: '';
        position: absolute;
        bottom: -20%;
        left: -10%;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(30, 58, 138, 0.06) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
    }
    .register-card {
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: 1.5px solid rgba(255, 255, 255, 0.6);
        border-radius: 24px;
        padding: 2.5rem 2.25rem;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 24px 48px -12px rgba(30, 58, 138, 0.18), 0 0 0 1px rgba(255,255,255,0.3) inset;
        animation: fadeSlideIn 0.4s ease;
        position: relative;
        z-index: 1;
    }
    @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .register-card h2 { color: #0b1120 !important; }
    .register-card p { color: #334155 !important; }
    .form-label-custom {
        color: #334155 !important;
        font-weight: 700;
        font-size: 0.82rem;
        margin-bottom: 0.5rem;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .register-card .form-input-custom {
        background: #ffffff !important;
        border: 1.5px solid rgba(30, 58, 138, 0.15) !important;
        color: #0b1120 !important;
        border-radius: 12px;
        padding: 0.7rem 1rem;
        width: 100%;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }
    .register-card .form-input-custom::placeholder { color: #94a3b8 !important; }
    .register-card .form-input-custom:focus {
        outline: none;
        border-color: #1e3a8a !important;
        background: #ffffff !important;
        box-shadow: 0 0 0 3px rgba(30, 58, 138, 0.1) !important;
    }
    .register-card select.form-input-custom option {
        background: #ffffff;
        color: #0b1120;
    }
    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, #1e3a8a 0%, #172554 100%);
        color: #fff;
        border: none;
        padding: 0.9rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        box-shadow: 0 8px 24px rgba(30, 58, 138, 0.2);
    }
    .btn-submit:hover {
        background: linear-gradient(135deg, #2563eb 0%, #1e3a8a 100%);
        transform: translateY(-2px);
        box-shadow: 0 16px 32px rgba(30, 58, 138, 0.3);
    }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .register-divider {
        border-top: 1px solid rgba(30, 58, 138, 0.1);
        padding-top: 1.25rem;
        margin-top: 1.5rem;
        text-align: center;
        font-size: 0.9rem;
        color: #334155;
    }
    .register-divider a { color: #1e3a8a; font-weight: 700; text-decoration: none; }
    .register-divider a:hover { text-decoration: underline; }
    .reg-icon-box {
        width: 64px; height: 64px; border-radius: 18px;
        background: rgba(30, 58, 138, 0.05);
        border: 1.5px solid rgba(30, 58, 138, 0.1);
        color: #1e3a8a;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.75rem; margin-bottom: 1rem;
        box-shadow: 0 8px 24px rgba(30, 58, 138, 0.08);
        transition: all 0.3s ease;
    }
    .error-box {
        color: #ba1a1a;
        font-size: 0.88rem;
        font-weight: 600;
        background: #ffdad6;
        border: 1px solid #ffdad6;
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
        margin-bottom: 1.25rem;
    }
</style>

<div class="register-container">
    <div class="register-card">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div class="reg-icon-box">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h2 style="font-size: 1.55rem; font-weight: 800; margin-bottom: 0.25rem;">Tạo Tài Khoản Mới</h2>
            <p style="font-size: 0.9rem; margin-top: 0.25rem;">Đăng ký để bắt đầu hành trình học tập.</p>
        </div>

        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="error-box"><i class="fa-solid fa-circle-exclamation"></i> <%= errorMessage %></div>
        <% } %>

        <form action="/Auth/Register" method="post" autocomplete="off" id="registerForm">
            <div class="form-group-custom">
                <label class="form-label-custom">Họ và Tên</label>
                <input type="text" name="fullName" class="form-input-custom" placeholder="Nguyễn Văn A" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Email</label>
                <input type="email" name="email" class="form-input-custom" placeholder="email@example.com" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Số điện thoại</label>
                <input type="tel" name="phone" class="form-input-custom" placeholder="0901234567" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Mật khẩu</label>
                <input type="password" name="password" class="form-input-custom" placeholder="Tối thiểu 6 ký tự" required autocomplete="new-password" />
            </div>
            <div class="form-group-custom" style="margin-bottom: 2rem;">
                <label class="form-label-custom">Vai trò</label>
                <select name="role" class="form-input-custom">
                    <option value="STUDENT">Học Viên</option>
                    <option value="TEACHER">Giáo Viên</option>
                    <option value="PARENT">Phụ Huynh</option>
                </select>
            </div>
            <button type="submit" class="btn-submit" id="submitBtn">
                <i class="fa-solid fa-user-check"></i> Đăng Ký Ngay
            </button>
        </form>

        <div class="register-divider">
            Đã có tài khoản? <a href="/Auth/Login">Đăng nhập</a>
        </div>
    </div>
</div>

<script>
    document.getElementById('registerForm').addEventListener('submit', function() {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...';
    });
</script>

    </main>
</body>
</html>