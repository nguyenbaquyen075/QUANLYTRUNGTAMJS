<% title = "Trung Tâm Thông Báo"; %>

<style>
    .notif-container {
        max-width: 800px;
        margin: 0 auto;
    }
    .notif-card {
        background-color: var(--white);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 1.5rem;
        margin-bottom: 1rem;
        box-shadow: var(--shadow-sm);
        display: flex;
        gap: 1.25rem;
        transition: all 0.2s ease;
        position: relative;
        cursor: pointer;
    }
    .notif-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
        border-color: var(--primary-200);
    }
    .notif-card.unread {
        border-left: 5px solid var(--primary-color);
        background-color: #F8FAFC;
    }
    .notif-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: var(--primary-light);
        color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .notif-card.unread .notif-icon {
        background-color: rgba(37, 99, 235, 0.15);
    }
    .notif-body {
        flex: 1;
    }
    .notif-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .notif-badge {
        font-size: 0.68rem;
        font-weight: 800;
        background-color: var(--primary-color);
        color: white;
        padding: 0.15rem 0.5rem;
        border-radius: 9999px;
        text-transform: uppercase;
    }
    .notif-content {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }
    .notif-time {
        font-size: 0.78rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
    }
    .empty-state i {
        font-size: 3.5rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-inner">
        <div class="breadcrumb-custom">
            <a href="/"><i class="fa-solid fa-house"></i> Trang chủ</a>
            <i class="fa-solid fa-chevron-right" style="font-size: 0.65rem;"></i>
            <span>Thông báo</span>
        </div>
        <h1><i class="fa-solid fa-bell"></i> Thông Báo Hệ Thống</h1>
        <p>Xem toàn bộ cập nhật, tin nhắn hỗ trợ, bài tập và phản hồi học tập từ trung tâm.</p>
    </div>
</div>

<div class="section-container">
    <div class="notif-container">
        <% if (typeof notifications !== 'undefined' && notifications && notifications.length > 0) { %>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <span style="font-weight: 600; color: var(--text-dark); font-size: 1.1rem;">Danh sách thông báo (<%= notifications.length %>)</span>
                <button onclick="markAllAsRead()" class="btn-secondary-custom" style="padding: 0.45rem 1rem; font-size: 0.85rem;">
                    <i class="fa-solid fa-envelope-open"></i> Đánh dấu tất cả đã đọc
                </button>
            </div>

            <% notifications.forEach(notif => { %>
                <div class="notif-card <%= notif.IsRead ? '' : 'unread' %>" onclick="handleNotificationClick(<%= notif.Id %>, '<%= notif.LinkUrl %>')">
                    <div class="notif-icon">
                        <% if (notif.Title.includes("Bài tập") || notif.Title.includes("điểm")) { %>
                            <i class="fa-solid fa-book-open"></i>
                        <% } else if (notif.Title.includes("thanh toán") || notif.Title.includes("học phí") || notif.Title.includes("Hóa đơn")) { %>
                            <i class="fa-solid fa-credit-card"></i>
                        <% } else if (notif.Title.includes("Bảo trì") || notif.Title.includes("hệ thống")) { %>
                            <i class="fa-solid fa-screwdriver-wrench"></i>
                        <% } else { %>
                            <i class="fa-solid fa-bell"></i>
                        <% } %>
                    </div>
                    <div class="notif-body">
                        <h4 class="notif-title">
                            <%= notif.Title %>
                            <% if (!notif.IsRead) { %>
                                <span class="notif-badge">Mới</span>
                            <% } %>
                        </h4>
                        <p class="notif-content"><%= notif.Content %></p>
                        <span class="notif-time">
                            <i class="fa-regular fa-clock"></i> 
                            <% 
                                const today = new Date();
                                const notifDate = new Date(notif.CreatedAt);
                                const isToday = today.toDateString() === notifDate.toDateString();
                            %>
                            <% if (isToday) { %>
                                <span>Hôm nay lúc <%= notifDate.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
                            <% } else { %>
                                <span><%= notifDate.toLocaleDateString('vi-VN') %> <%= notifDate.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %></span>
                            <% } %>
                        </span>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <i class="fa-regular fa-bell-slash"></i>
                <h3>Bạn không có thông báo nào</h3>
                <p style="color: var(--text-muted); margin-top: 0.5rem;">Chúng tôi sẽ thông báo cho bạn khi có cập nhật, sự kiện mới hoặc kết quả học tập từ lớp học.</p>
            </div>
        <% } %>
    </div>
</div>

<%- contentFor('scripts') %>
<script>
    async function handleNotificationClick(id, linkUrl) {
        try {
            // Mark as read via AJAX
            await fetch(`/Notification/MarkAsRead`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            });
            
            // Redirect to target URL if it exists
            if (linkUrl && linkUrl !== 'null' && linkUrl !== '') {
                window.location.href = linkUrl;
            } else {
                window.location.reload();
            }
        } catch (err) {
            console.error("Error marking notification as read:", err);
            if (linkUrl) window.location.href = linkUrl;
        }
    }

    async function markAllAsRead() {
        try {
            const response = await fetch('/Notification/MarkAllAsRead', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await response.json();
            if (result.success) {
                window.location.reload();
            }
        } catch (err) {
            console.error("Error marking all as read:", err);
        }
    }
</script>
