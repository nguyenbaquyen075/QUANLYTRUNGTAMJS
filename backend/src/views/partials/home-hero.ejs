<%
/*
  Partial: home-hero.ejs
  Variables expected from parent scope:
    - heroIcon: material symbol name (e.g. 'school', 'diversity_3')
    - heroTitle: string
    - heroDesc: string
    - heroBreadcrumb: string (label for current page)
    - heroStats (optional): array of { value, label }
*/
var _heroIcon = (typeof heroIcon !== 'undefined' && heroIcon) ? heroIcon : 'home';
var _heroTitle = (typeof heroTitle !== 'undefined') ? heroTitle : '';
var _heroDesc = (typeof heroDesc !== 'undefined') ? heroDesc : '';
var _heroBreadcrumb = (typeof heroBreadcrumb !== 'undefined') ? heroBreadcrumb : '';
var _heroStats = (typeof heroStats !== 'undefined' && Array.isArray(heroStats)) ? heroStats : [];
%>
<section class="relative w-full overflow-hidden select-none pt-36 pb-20 border-b border-slate-800/20" style="background-image: radial-gradient(circle at 10% 20%, rgba(15, 23, 42, 0.28) 0%, rgba(15, 23, 42, 0.12) 100%), url('/images/hero-bg.jpg'); background-size: cover; background-position: center bottom;">
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-16 w-full flex flex-col items-center text-center">
    <!-- Breadcrumb -->
    <div class="flex items-center justify-center gap-2 mb-4 text-slate-300 text-sm font-semibold">
      <a href="/" class="text-slate-300 hover:text-white transition-colors" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">Trang chủ</a>
      <span class="text-slate-300/40">/</span>
      <span class="font-bold text-white" style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);"><%= _heroBreadcrumb %></span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl font-black mb-4 leading-tight text-white font-serif" style="text-shadow: 0 2px 6px rgba(0,0,0,0.8), 0 4px 15px rgba(0,0,0,0.5), 0 0 10px rgba(0,0,0,0.4);">
      <%= _heroTitle %>
    </h1>

    <!-- Description -->
    <p class="text-base md:text-lg text-slate-200 max-w-2xl font-bold leading-relaxed" style="text-shadow: 0 1px 3px rgba(0,0,0,0.8), 0 2px 8px rgba(0,0,0,0.5);">
      <%= _heroDesc %>
    </p>

    <!-- Optional Stats -->
    <% if (_heroStats.length > 0) { %>
    <div class="mt-8 flex flex-wrap gap-8 justify-center">
      <% _heroStats.forEach(function(stat, i) { %>
        <% if (i > 0) { %><div class="w-px h-10 bg-outline-variant/30 self-center hidden sm:block"></div><% } %>
        <div class="flex flex-col">
          <span class="text-3xl font-black text-white" style="text-shadow: 0 1px 3px rgba(0,0,0,0.8), 0 2px 8px rgba(0,0,0,0.5);"><%= stat.value %></span>
          <span class="text-xs font-bold text-slate-300/80 uppercase tracking-widest mt-0.5" style="text-shadow: 0 1px 3px rgba(0,0,0,0.8), 0 2px 8px rgba(0,0,0,0.5);"><%= stat.label %></span>
        </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>
